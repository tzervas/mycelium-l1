// nodule: compiler.parse
// @version: 0.1.0
// @license: MIT
// @authors: Tyler Zervas
// @since: 2026-07-05
// @updated: 2026-07-05
// @summary: Self-hosted L1 recursive-descent parser (M-740 Stage 3b; DN-26 ¬ß7.3 row 3). A faithful
//   port of crates/mycelium-l1/src/parse.rs's `parse` entry (source text -> Nodule) over a SELF-
//   CONTAINED copy of the token/lexer types (mirroring compiler.token/compiler.lex) and the AST
//   vocabulary (mirroring compiler.ast) ‚Äî per M-982, cross-nodule EXECUTION is still staged, so
//   this nodule cannot `use compiler.lex.*`/`use compiler.ast.*` and actually RUN them; it
//   redeclares everything needed to go all the way from `source text -> AST` in one nodule,
//   matching crate::parse::parse(src: &str) -> Result<Nodule, ParseError> directly.
nodule compiler.parse;

// M-740 (E18-1, DN-26 ¬ß7.3 Stage 3b). `crates/mycelium-l1/src/parse.rs` stays the trusted
// differential oracle (DN-26 ¬ß7.4) until M-741 ratifies the port. This file is checked against it
// by `crates/mycelium-l1/tests/compiler_stage3.rs` (classification parity + AST structural
// fingerprint over the full L1 conformance corpus).
//
// ‚îÄ‚îÄ FLAG-parse-1 (self-contained; own copy of token+lexer+ast, not `use`-ing the sibling nodules).
// Per M-982 (the task brief's own architecture decision, restating token.myc FLAG-token-4 /
// lex.myc FLAG-lex-0 / ast.myc FLAG-ast-3): cross-nodule EXECUTION is still staged
// (`checkty.rs::check_phylum`'s own doc comment), so `compiler.parse` cannot `use compiler.lex.*`
// or `use compiler.ast.*` and actually RUN them. This nodule therefore incorporates its OWN copy of
// the token kinds, the full lexer, AND the AST data types, then adds the ported parser on top ‚Äî
// giving a complete `source text -> AST` pipeline matching the Rust oracle's `parse(src)` signature
// directly (the cleanest differential). A future stage (post-M-741, once cross-nodule execution
// lands) can delete this duplication and `use` the three sibling nodules instead ‚Äî not this leaf's
// call to make, FLAGged up for DN-26/M-741.
//
// ‚îÄ‚îÄ FLAG-parse-2 (NEW finding ‚Äî flat-namespace collision between the LEXER's keyword-token
// constructors and the AST's keyword-shaped constructors, once both live in ONE self-contained
// nodule). token.myc/lex.myc and ast.myc were each individually free to spell their own bare
// constructors (`Tok::If`, `Tok::Let`, `Tok::Type`, `Tok::Vsa`, `Tok::Int(Bytes)`, ‚Ä¶ in one sibling
// nodule; `Expr::If`, `Expr::Let`, `Item::Type`, `BaseType::Vsa`, `Literal::Int(Binary{64})`, ‚Ä¶ in
// ANOTHER) because Rust namespaces each enum separately and, in the self-hosted surface, the two
// families lived in DIFFERENT nodules with their own flat constructor namespaces (RFC-0006 ¬ß4.3 ‚Äî
// a nodule's constructor namespace is flat, per FLAG-ast-5, but that is a PER-NODULE flatness). This
// port needs BOTH families in the SAME nodule (FLAG-parse-1), which collapses them into ONE flat
// namespace and surfaces a genuinely NEW collision class neither Stage 1/2 (lexer alone) nor
// Stage 3a (AST alone) could hit: every keyword whose surface spelling is ALSO the shape of an AST
// constructor collides (`If`/`Let`/`Match`/`For`/`Swap`/`Wild`/`Spore`/`Consume`/`Colony`/`Lambda`/
// `Fuse`/`Reclaim`/`Type`/`Trait`/`Impl`/`Fn`/`Default`/`Object`/`Lower`/`Derive`/`Use`/`Pub`/`Int`/
// `Vsa`/`KwBinary`/`KwTernary`/`KwDense`/`KwSeq`/`KwBytes`/`KwFloat`/`KwSubstrate` ‚Äî 31 names). Since
// `ast.myc`'s spellings are the already-landed sibling-leaf convention (and are what the AST-shape
// differential/fingerprint cares about matching for the eventual M-741 unification target), THIS
// file's own local `Tok` gets the divergent spelling: every colliding token constructor is
// `T`-prefixed (`TIf`/`TLet`/`TMatch`/‚Ä¶/`TInt`/`TVsa`/`TKwBinary`/‚Ä¶), a fresh prefix class alongside
// the established `Kw-`/`S-`/`G-`/`P-`/`Sp-`/`AP-` conventions (FLAG-token-3/FLAG-ast-4/5). This is
// purely a LOCAL, internal spelling choice ‚Äî invisible outside this nodule (nothing cross-nodule
// compares `Tok`'s constructor names) ‚Äî but it is a REAL, reportable finding for DN-26/M-741: any
// future single-nodule unification of the frontend stages (or any stage that needs two of
// token/ast/‚Ä¶ together) will hit this same class and need the identical prefixing discipline.
// `ScalarTok`/`StrengthTok`'s own payload constructors (`SF16`/‚Ä¶, `GExact`/‚Ä¶) collide with
// `ast.myc`'s `Scalar`/`Strength` constructors of the SAME name for the SAME reason ‚Äî prefixed
// `TS-`/`TG-` here (`TSF16`/‚Ä¶, `TGExact`/‚Ä¶) rather than reusing `token.myc`'s `S-`/`G-` (which are
// themselves now unavailable, claimed by `ast.myc`).
//
// ‚îÄ‚îÄ FLAG-parse-3 (decimal-digit-run -> Binary{32}/{64} conversion NOW LIVES HERE, not deferred
// further). `compiler.token`/`compiler.lex`'s FLAG-token-2/FLAG-lex-2 deferred the `Int` token's
// numeric conversion as "elaboration-shaped work, out of lexer scope" ‚Äî but `compiler.ast`'s
// `WidthRef::Lit`/`Dense`'s dim/`Seq`'s len/`Literal::Int`/`AmbientInt` fields are `Binary{32}`/
// `Binary{64}` (FLAG-ast-2: LOSSLESS, not a narrowing ‚Äî the grammar's digit-run is always
// non-negative). The PARSER is where that conversion is actually needed (constructing those AST
// values), so it lands here: `decimal_to_u32`/`decimal_to_u64` (Horner's-method multiply-accumulate,
// `acc*10 + digit`), built from `add_u`/`shl_u`/`width_cast` (no `mul_s` ‚Äî `mul_s` reads `Binary{N}`
// as SIGNED two's-complement, `lib/std/ternary.myc`'s own established reason to avoid it for
// unsigned scaling; `acc*10 = (acc<<3) + (acc<<1)` via `shl_u` instead). Never-silent caveat
// (FLAG-parse-4 below) on overflow.
//
// ‚îÄ‚îÄ FLAG-parse-4 (u32/u64-range overflow is NOT a parse-time `Err`, unlike the Rust oracle). Rust's
// `u32_lit` explicitly refuses (`ParseError`) a digit run whose value exceeds `u32::MAX`
// (`u32::try_from(n)`). This port's `decimal_to_u32`/`decimal_to_u64` instead compose `add_u`, whose
// own never-silent contract is an interpreter-level `EvalError::Overflow` REFUSAL if the running
// accumulator would exceed the target width ‚Äî so an over-wide literal still fails loudly, but as a
// runtime evaluation trap when the self-hosted parser itself RUNS (via `Evaluator::call`), not as a
// `Result::Err` value the rest of THIS parser's own error-handling machinery can observe/report
// through the normal `PErr` channel. No accept-corpus file exercises an over-range width/dim/int
// literal (verified during authoring), so the Stage-3 gate does not exercise this gap ‚Äî a real,
// documented divergence (G2/VR-5), not a silent one.
//
// ‚îÄ‚îÄ FLAG-parse-5 (no generic parser-combinator; every comma/pipe/plus-separated list production is
// hand-rolled per concrete element type). Rust's `comma_separated`/`comma_separated_until` are
// generic over `impl FnMut(&mut Self) -> Result<T, ParseError>` closures passed at each call site.
// No self-hosted nodule in this corpus yet passes a function VALUE as a parametrized combinator
// argument (RFC-0037 D5 closures exist as of M-704, but this port does not lean on that still-young
// path for its own bootstrap-critical control flow ‚Äî a deliberate, conservative choice, not a
// language limitation). Each list-shaped production here (ctor fields, type params/args, value
// params, call args, match arms, colony hyphae, pattern/type/expr tuples, list-literal elements,
// bound `+`-chains, item/nodule repetition) is its own small hand-rolled recursive function over its
// concrete element type ‚Äî mechanical duplication, but each is 6-12 lines and total-by-construction
// (never a nested/nested-arity mismatch). Every such loop (and every other source-length-bounded
// recursion in this nodule, incl. the lexer copy's token/lexeme scanners) is written in
// ACCUMULATOR + REVERSE direct-tail style ‚Äî `loop(ts, Cons(item, acc))` tail-calls itself and a
// final `rev_acc(acc, Nil)` restores source order ‚Äî the RFC-0041 SS7 W7 amendment-11 shape (PR
// #1166 review fix; the pre-fix Cons-after-return shape ALSO did per-item work on the unwind).
// The ONE exception is `typeparam_names_of_kind` ‚Äî an ast.myc-VERBATIM mirror helper (never called
// on the parse path; only reachable via the mirrored `fnsig_param_names` accessors) kept
// byte-identical to the sibling nodule per the mirror discipline; converting it belongs to the ast
// leaf (FLAGged). See FLAG-parse-11 for why the depth BENEFIT of this shape is currently dormant.
//
// ‚îÄ‚îÄ FLAG-parse-11 (evaluator TCO gap ‚Äî the direct-tail shape's depth benefit is DORMANT today;
// pinned in compiler_stage3.rs, FLAGged up for a kernel-side issue). The L1 evaluator's frame-reuse
// (RFC-0041 SS4.6) fires ONLY when the caller's `InvokePost` frame is directly on top of the CEK
// stack at call time ‚Äî and a `match` arm body evaluates under a `Frame::MatchPop` (scope-restore)
// frame, a `let` body under a `Frame::LetPop`, so a self-call from inside ANY match arm or let
// body is never elided (probed empirically during the PR #1166 patch cycle: a 10,000-iteration
// `match`-arm tail loop trips DepthExceeded{4096} with tco_trace.total_elided == 1; same for a
// let-body tail call; only the bare-body `spin(n) = spin(n)` shape elides ‚Äî the exact shape the
// kernel's own TCO witness test uses). Since every TERMINATING loop needs at least one `match`,
// NO in-language loop can currently iterate past the depth budget, whatever its source shape ‚Äî
// this equally limits compiler.lex/compiler.nodule_header's existing loops (never previously
// exercised past 4096 iterations by any gate). The accumulator+reverse shape here is therefore the
// correct, ready form whose depth benefit LIGHTS UP the moment the kernel widens tail position
// through binder-restoring frames (eagerly truncating scope before a tail call) ‚Äî a
// `crates/mycelium-l1/src/eval.rs` change this leaf must not make (KC-3 FLAG-up, not an in-wave
// core edit).
//
// ‚îÄ‚îÄ FLAG-parse-6 (effect-budget unit multiplier (`KiB`/`MiB`/`GiB`) overflow is NOT checked, unlike
// Rust's `checked_mul`). `shl_u`'s never-silent contract only guards the SHIFT AMOUNT (refuses if
// >= the operand width); it does not detect/refuse when the shifted-out high bits carried a nonzero
// value (an ordinary truncating logical shift). So `raw_u64 shl 30` (the `GiB` multiplier) silently
// drops overflowed bits rather than raising Rust's explicit "budget overflows u64" `ParseError`. No
// accept-corpus effect budget is remotely close to overflowing (verified during authoring) ‚Äî an
// honest, unexercised narrowing (G2/VR-5).
//
// ‚îÄ‚îÄ FLAG-parse-7 (recursion-depth budget threading ‚Äî a value-semantics restatement of
// `self.depth`/`enter_depth`/`leave_depth`, not a behavior change). Rust's `Parser.depth: u32` is a
// single mutable field threaded implicitly through every call; `enter_depth`/`leave_depth` always
// net to zero around any successfully-returning OR erroring guarded call (leave_depth runs
// unconditionally after the guarded body, regardless of Ok/Err). In this value-semantics port,
// `depth: Binary{32}` is an explicit parameter threaded DOWN through every production that can
// reach the expr/type/pattern sub-grammar; because the net effect is always zero, no function needs
// to return an updated depth ‚Äî a caller passes its own ambient depth in and it is unconditionally
// still valid after the callee returns (Ok or Err) exactly as in the mutable-field original. Only
// the five actually-guarded entry points (`parse_type_ref`, `parse_expr`, `parse_pattern`,
// `parse_unary`'s own prefix chain, `parse_consume_expr`) call `enter_depth` to check+charge the
// budget; every other production is a pure pass-through. Item-level productions (never reachable
// from inside an expr/type/pattern recursion) start fresh at depth 0, matching the Rust field's
// always-zero-at-an-item-boundary invariant (each guarded subtree's net effect is zero, so
// `self.depth` is provably 0 whenever a new top-level item/ctor/signature begins).
//
// ‚îÄ‚îÄ FLAG-parse-8 (no error-position fidelity / message-content differential ‚Äî same convention as
// FLAG-lex-7/FLAG-nodule-3). Every `PErr` message is a static/lightly-formatted `Bytes` literal, not
// a byte-for-byte transcription of the oracle's prose; only the Ok/Err CLASSIFICATION is
// differentialed (DN-26 ¬ß7.3's own Stage-3 contract, "Classification parity"). Positions are
// tracked and threaded (never dropped), just not fidelity-compared.
//
// ‚îÄ‚îÄ FLAG-parse-9 (`parse_phylum` ported; both entry points share one gate). `parse` (single-nodule)
// and `parse_phylum` (optional `phylum` header + one-or-more `nodule` blocks) are BOTH ported (the
// task brief's "if porting parse_phylum proves infeasible, narrow honestly" case did not arise ‚Äî
// `parse_phylum` is a thin wrapper reusing `parse_nodule` in a loop, no additional grammar).
//
// Every OTHER narrowing (float literals, ASCII-only whitespace, verbatim-Bytes literal payloads,
// the `Some(Scalar(SF16))`-shaped M-980 combined-match checker bug) carries over VERBATIM from
// FLAG-lex-2/3/4 and FLAG-lex-6 respectively ‚Äî this file's own lexer copy is behaviorally identical
// to `compiler.lex`'s (module the FLAG-parse-2 renaming), so those FLAGs are not re-derived here.

// ‚îÄ‚îÄ generic infrastructure (local; no cross-nodule import ‚Äî FLAG-parse-1) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Option[A] = Some(A) | None;
type Result[A, E] = Ok(A) | Err(E);
type Vec[A] = Nil | Cons(A, Vec[A]);
type Pair[A, B] = Pr(A, B);

// rev_acc: the direct-tail list reversal underpinning every accumulator+reverse list-building
// loop in this nodule (RFC-0041 SS7 W7 amendment 11 -- the TCO acceptance criterion):
// `rev_acc(xs, acc)` = reverse(xs) ++ acc, one direct tail call per cell. Every loop whose depth
// is bounded by SOURCE LENGTH (token/item/arm/segment/byte count) accumulates via
// `loop(ts, Cons(item, acc))` (a direct tail call, so the evaluator's TCO reuses the frame) and
// restores source order with one final `rev_acc(acc, Nil)` -- O(n) work, O(1) eval stack depth.
// Expression/type/pattern NESTING recursion is the depth-budgeted class instead (FLAG-parse-7).
fn rev_acc[A](xs: Vec[A], acc: Vec[A]) => Vec[A] =
  match xs { Nil => acc, Cons(h, rest) => rev_acc(rest, Cons(h, acc)) };

// ‚îÄ‚îÄ Pos (redeclared from compiler.token) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Pos = P(Binary{32}, Binary{32});

fn pos_line(p: Pos) => Binary{32} =
  match p { P(l, _) => l };

fn pos_col(p: Pos) => Binary{32} =
  match p { P(_, c) => c };

// ‚îÄ‚îÄ ScalarTok / StrengthTok (redeclared from compiler.token; `TS-`/`TG-` prefixed ‚Äî FLAG-parse-2,
// since `ast.myc` already claims the bare `SF16`/‚Ä¶/`GExact`/‚Ä¶ spellings for its OWN `Scalar`/
// `Strength` types, which this nodule ALSO declares below) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type ScalarTok = TSF16 | TSBf16 | TSF32 | TSF64;
type StrengthTok = TGExact | TGProven | TGEmpirical | TGDeclared;

// ‚îÄ‚îÄ Tok (redeclared from compiler.token/compiler.lex; every constructor that collides with an AST
// constructor of the same bare name is `T`-prefixed ‚Äî FLAG-parse-2) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Tok =
    Nodule | Phylum | TColony
  | Hypha | TFuse | Mesh | Graft | Cyst | Xloc | Forage | Backbone | Tier | TReclaim
  | TConsume | Grow | TDerive
  | TUse | TPub | TPriv | TType | TTrait | TImpl | TFn | Matured | Thaw
  | TLet | In | TIf | Then | Else | TMatch | TFor | TSwap
  | TDefault | Paradigm | With | TWild | TSpore | To | Policy
  | TLambda | TObject | Via | TLower
  | TKwBinary | TKwTernary | TKwDense | TVsa
  | BinShort | TernShort | EmbShort | HvecShort
  | TKwSeq | TKwBytes | TKwFloat | TKwSubstrate | KwSparse
  | Scalar(ScalarTok) | Strength(StrengthTok)
  | Ident(Bytes)
  | BinLit(Bytes)
  | BytesLit(Bytes)
  | TritLit(Bytes)
  | StrLit(Bytes)
  | TInt(Bytes)
  | FloatLit(Bytes)
  | LParen | RParen | LBrace | RBrace | LBracket | RBracket
  | LAngle | RAngle | Shl | Shr
  | At | AtStdSys
  | Colon | Comma | Semi | Dot | Pipe
  | Plus | Minus | Star | Slash | Percent | Caret | Amp | AmpAmp
  | Eq | EqEq | Arrow | FatArrow | Bang | BangEq | PipePipe
  | Eof;

// ‚îÄ‚îÄ Spanned (redeclared from compiler.token) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Spanned = Sp(Tok, Pos);

fn sp_tok(s: Spanned) => Tok =
  match s { Sp(t, _) => t };

fn sp_pos(s: Spanned) => Pos =
  match s { Sp(_, p) => p };

// ‚îÄ‚îÄ keyword (redeclared from compiler.token/compiler.lex, with FLAG-parse-2's renamed constructors;
// same 64 words, same precedence, same never-silent `None` fallthrough) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn keyword(word: Bytes) => Option[Tok] =
    match bytes_eq(word, "nodule") {
      0b1 => Some(Nodule),
      _ =>
      match bytes_eq(word, "phylum") {
        0b1 => Some(Phylum),
        _ =>
        match bytes_eq(word, "colony") {
          0b1 => Some(TColony),
          _ =>
          match bytes_eq(word, "hypha") {
            0b1 => Some(Hypha),
            _ =>
            match bytes_eq(word, "fuse") {
              0b1 => Some(TFuse),
              _ =>
              match bytes_eq(word, "mesh") {
                0b1 => Some(Mesh),
                _ =>
                match bytes_eq(word, "graft") {
                  0b1 => Some(Graft),
                  _ =>
                  match bytes_eq(word, "cyst") {
                    0b1 => Some(Cyst),
                    _ =>
                    match bytes_eq(word, "xloc") {
                      0b1 => Some(Xloc),
                      _ =>
                      match bytes_eq(word, "forage") {
                        0b1 => Some(Forage),
                        _ =>
                        match bytes_eq(word, "backbone") {
                          0b1 => Some(Backbone),
                          _ =>
                          match bytes_eq(word, "tier") {
                            0b1 => Some(Tier),
                            _ =>
                            match bytes_eq(word, "reclaim") {
                              0b1 => Some(TReclaim),
                              _ =>
                              match bytes_eq(word, "consume") {
                                0b1 => Some(TConsume),
                                _ =>
                                match bytes_eq(word, "grow") {
                                  0b1 => Some(Grow),
                                  _ =>
                                  match bytes_eq(word, "lambda") {
                                    0b1 => Some(TLambda),
                                    _ =>
                                    match bytes_eq(word, "object") {
                                      0b1 => Some(TObject),
                                      _ =>
                                      match bytes_eq(word, "via") {
                                        0b1 => Some(Via),
                                        _ =>
                                        match bytes_eq(word, "lower") {
                                          0b1 => Some(TLower),
                                          _ =>
                                          match bytes_eq(word, "derive") {
                                            0b1 => Some(TDerive),
                                            _ =>
                                            match bytes_eq(word, "use") {
                                              0b1 => Some(TUse),
                                              _ =>
                                              match bytes_eq(word, "pub") {
                                                0b1 => Some(TPub),
                                                _ =>
                                                match bytes_eq(word, "priv") {
                                                0b1 => Some(TPriv),
                                                _ =>
                                                match bytes_eq(word, "type") {
                                                  0b1 => Some(TType),
                                                  _ =>
                                                  match bytes_eq(word, "trait") {
                                                    0b1 => Some(TTrait),
                                                    _ =>
                                                    match bytes_eq(word, "impl") {
                                                      0b1 => Some(TImpl),
                                                      _ =>
                                                    match bytes_eq(word, "fn") {
                                                      0b1 => Some(TFn),
                                                      _ =>
                                                    match bytes_eq(word, "matured") {
                                                      0b1 => Some(Matured),
                                                      _ =>
                                                    match bytes_eq(word, "thaw") {
                                                      0b1 => Some(Thaw),
                                                      _ =>
                                                    match bytes_eq(word, "let") {
                                                      0b1 => Some(TLet),
                                                      _ =>
                                                    match bytes_eq(word, "in") {
                                                      0b1 => Some(In),
                                                      _ =>
                                                    match bytes_eq(word, "if") {
                                                      0b1 => Some(TIf),
                                                      _ =>
                                                    match bytes_eq(word, "then") {
                                                      0b1 => Some(Then),
                                                      _ =>
                                                    match bytes_eq(word, "else") {
                                                      0b1 => Some(Else),
                                                      _ =>
                                                    match bytes_eq(word, "match") {
                                                      0b1 => Some(TMatch),
                                                      _ =>
                                                    match bytes_eq(word, "for") {
                                                      0b1 => Some(TFor),
                                                      _ =>
                                                    match bytes_eq(word, "swap") {
                                                      0b1 => Some(TSwap),
                                                      _ =>
                                                    match bytes_eq(word, "default") {
                                                      0b1 => Some(TDefault),
                                                      _ =>
                                                    match bytes_eq(word, "paradigm") {
                                                      0b1 => Some(Paradigm),
                                                      _ =>
                                                    match bytes_eq(word, "with") {
                                                      0b1 => Some(With),
                                                      _ =>
                                                    match bytes_eq(word, "wild") {
                                                      0b1 => Some(TWild),
                                                      _ =>
                                                    match bytes_eq(word, "spore") {
                                                      0b1 => Some(TSpore),
                                                      _ =>
                                                    match bytes_eq(word, "to") {
                                                      0b1 => Some(To),
                                                      _ =>
                                                    match bytes_eq(word, "policy") {
                                                      0b1 => Some(Policy),
                                                      _ =>
                                                    match bytes_eq(word, "Binary") {
                                                      0b1 => Some(TKwBinary),
                                                      _ =>
                                                    match bytes_eq(word, "Ternary") {
                                                      0b1 => Some(TKwTernary),
                                                      _ =>
                                                    match bytes_eq(word, "Dense") {
                                                      0b1 => Some(TKwDense),
                                                      _ =>
                                                    match bytes_eq(word, "VSA") {
                                                      0b1 => Some(TVsa),
                                                      _ =>
                                                    match bytes_eq(word, "bin") {
                                                      0b1 => Some(BinShort),
                                                      _ =>
                                                    match bytes_eq(word, "tern") {
                                                      0b1 => Some(TernShort),
                                                      _ =>
                                                    match bytes_eq(word, "emb") {
                                                      0b1 => Some(EmbShort),
                                                      _ =>
                                                    match bytes_eq(word, "hvec") {
                                                      0b1 => Some(HvecShort),
                                                      _ =>
                                                    match bytes_eq(word, "Seq") {
                                                      0b1 => Some(TKwSeq),
                                                      _ =>
                                                    match bytes_eq(word, "Bytes") {
                                                      0b1 => Some(TKwBytes),
                                                      _ =>
                                                    match bytes_eq(word, "Float") {
                                                      0b1 => Some(TKwFloat),
                                                      _ =>
                                                    match bytes_eq(word, "Substrate") {
                                                      0b1 => Some(TKwSubstrate),
                                                      _ =>
                                                    match bytes_eq(word, "Sparse") {
                                                      0b1 => Some(KwSparse),
                                                      _ =>
                                                    match bytes_eq(word, "F16") {
                                                      0b1 => Some(Scalar(TSF16)),
                                                      _ =>
                                                    match bytes_eq(word, "BF16") {
                                                      0b1 => Some(Scalar(TSBf16)),
                                                      _ =>
                                                    match bytes_eq(word, "F32") {
                                                      0b1 => Some(Scalar(TSF32)),
                                                      _ =>
                                                    match bytes_eq(word, "F64") {
                                                      0b1 => Some(Scalar(TSF64)),
                                                      _ =>
                                                    match bytes_eq(word, "Exact") {
                                                      0b1 => Some(Strength(TGExact)),
                                                      _ =>
                                                    match bytes_eq(word, "Proven") {
                                                      0b1 => Some(Strength(TGProven)),
                                                      _ =>
                                                    match bytes_eq(word, "Empirical") {
                                                      0b1 => Some(Strength(TGEmpirical)),
                                                      _ =>
                                                    match bytes_eq(word, "Declared") {
                                                      0b1 => Some(Strength(TGDeclared)),
                                                      _ =>
                                                      None
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                    }
                                                  }
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ;

// ‚îÄ‚îÄ lexer (redeclared from compiler.lex, adapted: LexErr -> PErr shared error type,
// FLAG-parse-2's TInt rename for the one Tok::Int construction site) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// tok_count: the number of tokens in a Vec[Spanned] (structural spine-walk; matches only Nil/Cons,
// never Tok itself ‚Äî cheap and safe, see FLAG-lex-6).
fn tok_count(v: Vec[Spanned]) => Binary{32} =
  tok_count_acc(v, 0b0000_0000_0000_0000_0000_0000_0000_0000);

fn tok_count_acc(v: Vec[Spanned], acc: Binary{32}) => Binary{32} =
  match v {
    Nil => acc,
    Cons(_, rest) => tok_count_acc(rest, add_u(acc, 0b0000_0000_0000_0000_0000_0000_0000_0001))
  };

// nth: the token at 0-based index `n`, or `None` if out of range. Lets a differential test inspect
// ONE token's `Tok`/`Pos` at a time without ever matching multiple `Tok` sites in the same nodule
// check pass (FLAG-lex-6's mitigation).
fn nth(v: Vec[Spanned], n: Binary{32}) => Option[Spanned] =
  match v {
    Nil => None,
    Cons(x, rest) => match eq(n, 0b0000_0000_0000_0000_0000_0000_0000_0000) {
      0b1 => Some(x),
      _ => nth(rest, sub_u(n, 0b0000_0000_0000_0000_0000_0000_0000_0001))
    }
  };

// ‚îÄ‚îÄ PErr ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// A lex failure at a source position (mirrors error.rs::ParseError's token-relevant shape ‚Äî DN-26
// ¬ß7.1's small token<->error 2-cycle). The message is a STATIC Bytes literal, not interpolated with
// the offending value (FLAG-lex-7): the Stage-1 gate (DN-26 ¬ß7.3) is defined over the ACCEPT
// corpus, which by definition never triggers a lex error, so message-content fidelity is not
// load-bearing for this stage; never-silent POSITION + occurrence still holds (an error is always
// an explicit Err, never a panic/silent skip).
type PErr = PE(Pos, Bytes);

// ‚îÄ‚îÄ St (lexer position/cursor state; explicit, threaded ‚Äî no mutation in a value-semantics
// language) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type St = S(Binary{32}, Binary{32}, Binary{32});

fn st_i(s: St) => Binary{32} =
  match s { S(i, _, _) => i };

fn st_line(s: St) => Binary{32} =
  match s { S(_, l, _) => l };

fn st_col(s: St) => Binary{32} =
  match s { S(_, _, c) => c };

fn st_pos(s: St) => Pos =
  P(st_line(s), st_col(s));

// ‚îÄ‚îÄ empty_bytes ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// A zero-length Bytes value. The `0x‚Ä¶` literal form REQUIRES at least one hex digit (lexer.rs's own
// never-silent "0x has no hex digits" rule), so there is no direct empty-Bytes literal; a zero-width
// `bytes_slice` (start == end, a valid non-inverted range) is the honest construction.
fn empty_bytes() => Bytes =
  bytes_slice(0x00, 0b0000_0000_0000_0000_0000_0000_0000_0000, 0b0000_0000_0000_0000_0000_0000_0000_0000);

// ‚îÄ‚îÄ byte classification (Exact; total via `lt`/`eq` + the bool bridge, mirrors std.text's
// is_ascii_byte/is_cont_byte pattern) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn bool_and(a: Bool, b: Bool) => Bool =
  match a { True => b, False => False };

fn bool_or(a: Bool, b: Bool) => Bool =
  match a { True => True, False => b };

fn eq_b(a: Binary{8}, b: Binary{8}) => Bool =
  match eq(a, b) { 0b1 => True, _ => False };

fn lt_b(a: Binary{8}, b: Binary{8}) => Bool =
  match lt(a, b) { 0b1 => True, _ => False };

// le_b: a <= b, i.e. NOT (b < a).
fn le_b(a: Binary{8}, b: Binary{8}) => Bool =
  match lt(b, a) { 0b1 => False, _ => True };

fn in_range(c: Binary{8}, lo: Binary{8}, hi: Binary{8}) => Bool =
  bool_and(le_b(lo, c), le_b(c, hi));

// UTF-8 continuation byte: 0x80..0xBF (mirrors lib/std/text.myc::is_cont_byte exactly).
fn is_cont_byte(c: Binary{8}) => Bool =
  in_range(c, 0b1000_0000, 0b1011_1111);

fn is_digit(c: Binary{8}) => Bool =
  in_range(c, 0b0011_0000, 0b0011_1001); // '0'..'9'

fn is_upper(c: Binary{8}) => Bool =
  in_range(c, 0b0100_0001, 0b0101_1010); // 'A'..'Z'

fn is_lower(c: Binary{8}) => Bool =
  in_range(c, 0b0110_0001, 0b0111_1010); // 'a'..'z'

fn is_alpha(c: Binary{8}) => Bool =
  bool_or(is_upper(c), is_lower(c));

fn is_ident_start(c: Binary{8}) => Bool =
  bool_or(is_alpha(c), eq_b(c, 0b0101_1111)); // '_'

fn is_ident_continue(c: Binary{8}) => Bool =
  bool_or(is_ident_start(c), is_digit(c));

fn is_hex_digit(c: Binary{8}) => Bool =
  bool_or(is_digit(c), bool_or(in_range(c, 0b0110_0001, 0b0110_0110), in_range(c, 0b0100_0001, 0b0100_0110))); // 'a'-'f' / 'A'-'F'

fn is_bin_digit(c: Binary{8}) => Bool =
  bool_or(eq_b(c, 0b0011_0000), eq_b(c, 0b0011_0001)); // '0' / '1'

fn is_trit_glyph(c: Binary{8}) => Bool =
  bool_or(eq_b(c, 0b0010_1011), bool_or(eq_b(c, 0b0011_0000), eq_b(c, 0b0010_1101))); // '+' / '0' / '-'

fn is_underscore(c: Binary{8}) => Bool =
  eq_b(c, 0b0101_1111);

fn is_ascii_ws(c: Binary{8}) => Bool =
  bool_or(eq_b(c, 0b0010_0000), bool_or(eq_b(c, 0b0000_1001), bool_or(eq_b(c, 0b0000_1101), eq_b(c, 0b0000_1010)))); // ' ' \t \r \n

fn is_nl_or_cr(c: Binary{8}) => Bool =
  bool_or(eq_b(c, 0b0000_1010), eq_b(c, 0b0000_1101)); // \n / \r

// ‚îÄ‚îÄ source access + position advance ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn src_peek(src: Bytes, i: Binary{32}) => Option[Binary{8}] =
  match lt(i, bytes_len(src)) { 0b1 => Some(bytes_get(src, i)), _ => None };

// step_pos: the position AFTER consuming byte `c` (FLAG-lex-1: bumps line on '\n', else bumps
// column only on a non-continuation byte ‚Äî "count codepoints, not bytes").
fn step_pos(c: Binary{8}, s: St) => St =
  match eq_b(c, 0b0000_1010) {
    True => S(add_u(st_i(s), 0b0000_0000_0000_0000_0000_0000_0000_0001), add_u(st_line(s), 0b0000_0000_0000_0000_0000_0000_0000_0001), 0b0000_0000_0000_0000_0000_0000_0000_0001),
    False => match is_cont_byte(c) {
      True => S(add_u(st_i(s), 0b0000_0000_0000_0000_0000_0000_0000_0001), st_line(s), st_col(s)),
      False => S(add_u(st_i(s), 0b0000_0000_0000_0000_0000_0000_0000_0001), st_line(s), add_u(st_col(s), 0b0000_0000_0000_0000_0000_0000_0000_0001))
    }
  };

// bump: consume one byte at the current position (never-silent no-op at EOF ‚Äî total).
fn bump(src: Bytes, s: St) => St =
  match src_peek(src, st_i(s)) { None => s, Some(c) => step_pos(c, s) };

// advance_n: bump `n` times (used after a run-length scan to jump the cursor past a lexeme).
fn advance_n(src: Bytes, s: St, n: Binary{32}) => St =
  match eq(n, 0b0000_0000_0000_0000_0000_0000_0000_0000) { 0b1 => s, _ => advance_n(src, bump(src, s), sub_u(n, 0b0000_0000_0000_0000_0000_0000_0000_0001)) };

// ‚îÄ‚îÄ trivia (whitespace + `//` comments; discarded, never captured ‚Äî FLAG-lex-5) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn skip_to_eol(src: Bytes, s: St) => St =
  match src_peek(src, st_i(s)) {
    None => s,
    Some(c) => match is_nl_or_cr(c) { True => s, False => skip_to_eol(src, bump(src, s)) }
  };

fn skip_trivia(src: Bytes, s: St) => St =
  match src_peek(src, st_i(s)) {
    None => s,
    Some(c) => match is_ascii_ws(c) {
      True => skip_trivia(src, bump(src, s)),
      False => match eq_b(c, 0b0010_1111) { // '/'
        True => match src_peek(src, add_u(st_i(s), 0b0000_0000_0000_0000_0000_0000_0000_0001)) {
          Some(c2) => match eq_b(c2, 0b0010_1111) {
            True => skip_trivia(src, skip_to_eol(src, s)),
            False => s
          },
          None => s
        },
        False => s
      }
    }
  };

// ‚îÄ‚îÄ run-length scanners (return a length/Pair; the lexeme itself is taken via bytes_slice) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn run_len_ident(src: Bytes, i: Binary{32}) => Binary{32} =
  run_len_ident_acc(src, i, zero32());

fn run_len_ident_acc(src: Bytes, i: Binary{32}, acc: Binary{32}) => Binary{32} =
  match src_peek(src, i) {
    None => acc,
    Some(c) => match is_ident_continue(c) {
      True => run_len_ident_acc(src, add_u(i, one32()), add_u(acc, one32())),
      False => acc
    }
  };

fn run_len_digits(src: Bytes, i: Binary{32}) => Binary{32} =
  run_len_digits_acc(src, i, zero32());

fn run_len_digits_acc(src: Bytes, i: Binary{32}, acc: Binary{32}) => Binary{32} =
  match src_peek(src, i) {
    None => acc,
    Some(c) => match is_digit(c) {
      True => run_len_digits_acc(src, add_u(i, one32()), add_u(acc, one32())),
      False => acc
    }
  };

// scan_bin_run: Pair(total run length INCLUDING `_` separators, count of actual `0`/`1` digits).
fn scan_bin_run(src: Bytes, i: Binary{32}) => Pair[Binary{32}, Binary{32}] =
  scan_bin_run_acc(src, i, zero32(), zero32());

fn scan_bin_run_acc(src: Bytes, i: Binary{32}, len: Binary{32}, digits: Binary{32}) => Pair[Binary{32}, Binary{32}] =
  match src_peek(src, i) {
    None => Pr(len, digits),
    Some(c) => match is_bin_digit(c) {
      True => scan_bin_run_acc(src, add_u(i, one32()), add_u(len, one32()), add_u(digits, one32())),
      False => match is_underscore(c) {
        True => scan_bin_run_acc(src, add_u(i, one32()), add_u(len, one32()), digits),
        False => Pr(len, digits)
      }
    }
  };

// scan_hex_run: Pair(total run length INCLUDING `_` separators, count of actual hex digits).
fn scan_hex_run(src: Bytes, i: Binary{32}) => Pair[Binary{32}, Binary{32}] =
  scan_hex_run_acc(src, i, zero32(), zero32());

fn scan_hex_run_acc(src: Bytes, i: Binary{32}, len: Binary{32}, digits: Binary{32}) => Pair[Binary{32}, Binary{32}] =
  match src_peek(src, i) {
    None => Pr(len, digits),
    Some(c) => match is_hex_digit(c) {
      True => scan_hex_run_acc(src, add_u(i, one32()), add_u(len, one32()), add_u(digits, one32())),
      False => match is_underscore(c) {
        True => scan_hex_run_acc(src, add_u(i, one32()), add_u(len, one32()), digits),
        False => Pr(len, digits)
      }
    }
  };

// scan_trit_run: total count of trit glyphs (`+`/`0`/`-`; no `_` separator in the trit grammar).
fn scan_trit_run(src: Bytes, i: Binary{32}) => Binary{32} =
  scan_trit_run_acc(src, i, zero32());

fn scan_trit_run_acc(src: Bytes, i: Binary{32}, acc: Binary{32}) => Binary{32} =
  match src_peek(src, i) {
    None => acc,
    Some(c) => match is_trit_glyph(c) {
      True => scan_trit_run_acc(src, add_u(i, one32()), add_u(acc, one32())),
      False => acc
    }
  };

// ‚îÄ‚îÄ string literal escape decode (M-910/M-911; \n \t \\ \" \0 \r) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// scan_string_escape: `s` is the position of the char AFTER the backslash. Returns the decoded
// single-byte payload + the position after the escape's closing char.
fn scan_string_escape(src: Bytes, s: St) => Result[Pair[Bytes, St], PErr] =
  match src_peek(src, st_i(s)) {
    None => Err(PE(st_pos(s), "unterminated string literal (trailing backslash)")),
    Some(c) =>
      match eq_b(c, 0b0110_1110) { True => Ok(Pr(0x0a, bump(src, s))), False => // \n
      match eq_b(c, 0b0111_0100) { True => Ok(Pr(0x09, bump(src, s))), False => // \t
      match eq_b(c, 0b0101_1100) { True => Ok(Pr(0x5c, bump(src, s))), False => // \\
      match eq_b(c, 0b0010_0010) { True => Ok(Pr(0x22, bump(src, s))), False => // \"
      match eq_b(c, 0b0011_0000) { True => Ok(Pr(0x00, bump(src, s))), False => // \0
      match eq_b(c, 0b0111_0010) { True => Ok(Pr(0x0d, bump(src, s))), False => // \r
      Err(PE(st_pos(s), "unknown escape sequence (supported: \\n \\t \\\\ \\\" \\0 \\r)"))
      }}}}}}
};

// scan_string: `s` is the position right after the opening `"`. Returns the DECODED content + the
// position right after the closing `"` (never-silent: unterminated / raw newline / bad escape are
// explicit `Err`, matching lexer.rs::lex_string's contract ‚Äî see FLAG-lex-7 for message fidelity).
fn scan_string(src: Bytes, s: St) => Result[Pair[Bytes, St], PErr] =
  scan_string_acc(src, s, empty_bytes());

fn scan_string_acc(src: Bytes, s: St, acc: Bytes) => Result[Pair[Bytes, St], PErr] =
  match src_peek(src, st_i(s)) {
    None => Err(PE(st_pos(s), "unterminated string literal (EOF)")),
    Some(c) => match eq_b(c, 0b0010_0010) { // closing '"'
      True => Ok(Pr(acc, bump(src, s))),
      False => match is_nl_or_cr(c) {
        True => Err(PE(st_pos(s), "unterminated string literal (raw newline)")),
        False => match eq_b(c, 0b0101_1100) { // '\'
          True => match scan_string_escape(src, bump(src, s)) {
            Err(e) => Err(e),
            Ok(pr1) => match pr1 { Pr(esc, s2) => scan_string_acc(src, s2, bytes_concat(acc, esc)) }
          },
          False => scan_string_acc(src, bump(src, s), bytes_concat(acc, bytes_slice(src, st_i(s), add_u(st_i(s), one32()))))
        }
      }
    }
  };

// ‚îÄ‚îÄ multi-char operator dispatchers (each `s` at the FIRST byte, not yet consumed) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn lex_rangle(src: Bytes, s: St) => Pair[Tok, St] =
  let s1 = bump(src, s) in
  match src_peek(src, st_i(s1)) {
    Some(c) => match eq_b(c, 0b0011_1110) { True => Pr(Shr, bump(src, s1)), False => Pr(RAngle, s1) },
    None => Pr(RAngle, s1)
  };

fn lex_langle(src: Bytes, s: St) => Pair[Tok, St] =
  let s1 = bump(src, s) in
  match src_peek(src, st_i(s1)) {
    Some(c) => match eq_b(c, 0b0011_1100) { True => Pr(Shl, bump(src, s1)), False => Pr(LAngle, s1) },
    None => Pr(LAngle, s1)
  };

fn lex_amp(src: Bytes, s: St) => Pair[Tok, St] =
  let s1 = bump(src, s) in
  match src_peek(src, st_i(s1)) {
    Some(c) => match eq_b(c, 0b0010_0110) { True => Pr(AmpAmp, bump(src, s1)), False => Pr(Amp, s1) },
    None => Pr(Amp, s1)
  };

fn lex_pipe(src: Bytes, s: St) => Pair[Tok, St] =
  let s1 = bump(src, s) in
  match src_peek(src, st_i(s1)) {
    Some(c) => match eq_b(c, 0b0111_1100) { True => Pr(PipePipe, bump(src, s1)), False => Pr(Pipe, s1) },
    None => Pr(Pipe, s1)
  };

fn lex_bang(src: Bytes, s: St) => Pair[Tok, St] =
  let s1 = bump(src, s) in
  match src_peek(src, st_i(s1)) {
    Some(c) => match eq_b(c, 0b0011_1101) { True => Pr(BangEq, bump(src, s1)), False => Pr(Bang, s1) },
    None => Pr(Bang, s1)
  };

fn lex_eq(src: Bytes, s: St) => Pair[Tok, St] =
  let s1 = bump(src, s) in
  match src_peek(src, st_i(s1)) {
    Some(c) => match eq_b(c, 0b0011_1110) { True => Pr(FatArrow, bump(src, s1)), False => // '>'
      match eq_b(c, 0b0011_1101) { True => Pr(EqEq, bump(src, s1)), False => Pr(Eq, s1) } }, // '='
    None => Pr(Eq, s1)
  };

fn lex_dash(src: Bytes, s: St) => Pair[Tok, St] =
  let s1 = bump(src, s) in
  match src_peek(src, st_i(s1)) {
    Some(c) => match eq_b(c, 0b0011_1110) { True => Pr(Arrow, bump(src, s1)), False => Pr(Minus, s1) }, // '>'
    None => Pr(Minus, s1)
  };

// `@` vs the atomic `@std-sys` nodule-header marker (M-661; mirrors lexer.rs::lex_at exactly, now
// expressible directly via the `bytes_eq` prim, M-912).
fn lex_at(src: Bytes, s: St) => Pair[Tok, St] =
  let s1 = bump(src, s) in
  let i1 = st_i(s1) in
  match lt(bytes_len(src), add_u(i1, 0b0000_0000_0000_0000_0000_0000_0000_0111)) {
    0b1 => Pr(At, s1), // fewer than 7 bytes remain: cannot be "std-sys"
    _ => match bytes_eq(bytes_slice(src, i1, add_u(i1, 0b0000_0000_0000_0000_0000_0000_0000_0111)), "std-sys") {
      0b1 => match src_peek(src, add_u(i1, 0b0000_0000_0000_0000_0000_0000_0000_0111)) {
        None => Pr(AtStdSys, advance_n(src, s1, 0b0000_0000_0000_0000_0000_0000_0000_0111)),
        Some(nc) => match is_ident_continue(nc) {
          True => Pr(At, s1), // e.g. "@std-system" is NOT the marker (whole-word check)
          False => Pr(AtStdSys, advance_n(src, s1, 0b0000_0000_0000_0000_0000_0000_0000_0111))
        }
      },
      _ => Pr(At, s1)
    }
  };

// ‚îÄ‚îÄ literal lexers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn lex_ident(src: Bytes, s: St) => Pair[Tok, St] =
  let n = run_len_ident(src, st_i(s)) in
  let word = bytes_slice(src, st_i(s), add_u(st_i(s), n)) in
  let s2 = advance_n(src, s, n) in
  match keyword(word) { Some(t) => Pr(t, s2), None => Pr(Ident(word), s2) };

// lex_int: a non-negative decimal digit run, verbatim (FLAG-lex-2: no float extension, no eager
// numeric conversion ‚Äî a structural deviation from lexer.rs, deliberately scoped, no accept-corpus
// input exercises the gap).
fn lex_int(src: Bytes, s: St) => Pair[Tok, St] =
  let n = run_len_digits(src, st_i(s)) in
  let word = bytes_slice(src, st_i(s), add_u(st_i(s), n)) in
  Pr(TInt(word), advance_n(src, s, n));

fn lex_binlit(src: Bytes, s: St) => Result[Pair[Tok, St], PErr] =
  let s1 = advance_n(src, s, 0b0000_0000_0000_0000_0000_0000_0000_0010) in // consume "0b"
  match scan_bin_run(src, st_i(s1)) {
    Pr(len, digits) => match eq(digits, 0b0000_0000_0000_0000_0000_0000_0000_0000) {
      0b1 => Err(PE(st_pos(s), "binary literal `0b` has no digits")),
      _ => let word = bytes_slice(src, st_i(s1), add_u(st_i(s1), len)) in
           Ok(Pr(BinLit(word), advance_n(src, s1, len)))
    }
  };

// Even-hex-digit-count check (RFC-0032 D4: a byte is two hex chars): `and(digits, 1)` masks the
// low bit ‚Äî `0` iff `digits` is even. `and` requires same-width operands; the bare `1` anchors to
// `digits`'s width (Binary{32}, RFC-0012 ambient bare-decimal inference).
fn lex_hexlit(src: Bytes, s: St) => Result[Pair[Tok, St], PErr] =
  let s1 = advance_n(src, s, 0b0000_0000_0000_0000_0000_0000_0000_0010) in // consume "0x"
  match scan_hex_run(src, st_i(s1)) {
    Pr(len, digits) => match eq(digits, 0b0000_0000_0000_0000_0000_0000_0000_0000) {
      0b1 => Err(PE(st_pos(s), "byte-string literal `0x` has no hex digits")),
      _ => match eq(and(digits, 0b0000_0000_0000_0000_0000_0000_0000_0001), 0b0000_0000_0000_0000_0000_0000_0000_0000) {
        0b1 => Ok(Pr(BytesLit(bytes_slice(src, st_i(s1), add_u(st_i(s1), len))), advance_n(src, s1, len))),
        _ => Err(PE(st_pos(s), "byte-string literal `0x` has an odd hex-digit count"))
      }
    }
  };

fn lex_tritlit(src: Bytes, s: St) => Result[Pair[Tok, St], PErr] =
  let s1 = advance_n(src, s, 0b0000_0000_0000_0000_0000_0000_0000_0010) in // consume "0t"
  let n = scan_trit_run(src, st_i(s1)) in
  match eq(n, 0b0000_0000_0000_0000_0000_0000_0000_0000) {
    0b1 => Err(PE(st_pos(s), "balanced-ternary literal `0t` has no trits")),
    _ => Ok(Pr(TritLit(bytes_slice(src, st_i(s1), add_u(st_i(s1), n))), advance_n(src, s1, n)))
  };

fn lex_string(src: Bytes, s: St) => Result[Pair[Tok, St], PErr] =
  match scan_string(src, bump(src, s)) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(content, s2) => Ok(Pr(StrLit(content), s2)) }
  };

// `0` followed by `b`/`x`/`t` opens a base-prefixed literal; otherwise a plain decimal int.
fn lex_zero_prefixed(src: Bytes, s: St) => Result[Pair[Tok, St], PErr] =
  match src_peek(src, add_u(st_i(s), 0b0000_0000_0000_0000_0000_0000_0000_0001)) {
    Some(c2) =>
      match eq_b(c2, 0b0110_0010) { True => lex_binlit(src, s), False => // 'b'
      match eq_b(c2, 0b0111_1000) { True => lex_hexlit(src, s), False => // 'x'
      match eq_b(c2, 0b0111_0100) { True => lex_tritlit(src, s), False => // 't'
      Ok(lex_int(src, s))
      }}},
    None => Ok(lex_int(src, s))
  };

// ‚îÄ‚îÄ next_token: the per-token dispatcher (mirrors lexer.rs::Lexer::run's big `match c { ... }`) ‚îÄ‚îÄ
fn next_token(src: Bytes, s: St) => Result[Pair[Tok, St], PErr] =
  match src_peek(src, st_i(s)) {
    None => Ok(Pr(Eof, s)),
    Some(c) =>
      match eq_b(c, 0b0010_1000) { True => Ok(Pr(LParen, bump(src, s))), False => // (
      match eq_b(c, 0b0010_1001) { True => Ok(Pr(RParen, bump(src, s))), False => // )
      match eq_b(c, 0b0111_1011) { True => Ok(Pr(LBrace, bump(src, s))), False => // {
      match eq_b(c, 0b0111_1101) { True => Ok(Pr(RBrace, bump(src, s))), False => // }
      match eq_b(c, 0b0101_1011) { True => Ok(Pr(LBracket, bump(src, s))), False => // [
      match eq_b(c, 0b0101_1101) { True => Ok(Pr(RBracket, bump(src, s))), False => // ]
      match eq_b(c, 0b0011_1110) { True => Ok(lex_rangle(src, s)), False => // >
      match eq_b(c, 0b0100_0000) { True => Ok(lex_at(src, s)), False => // @
      match eq_b(c, 0b0011_1010) { True => Ok(Pr(Colon, bump(src, s))), False => // :
      match eq_b(c, 0b0010_1100) { True => Ok(Pr(Comma, bump(src, s))), False => // ,
      match eq_b(c, 0b0011_1011) { True => Ok(Pr(Semi, bump(src, s))), False => // ;
      match eq_b(c, 0b0010_1110) { True => Ok(Pr(Dot, bump(src, s))), False => // .
      match eq_b(c, 0b0111_1100) { True => Ok(lex_pipe(src, s)), False => // |
      match eq_b(c, 0b0010_0001) { True => Ok(lex_bang(src, s)), False => // !
      match eq_b(c, 0b0010_1011) { True => Ok(Pr(Plus, bump(src, s))), False => // +
      match eq_b(c, 0b0010_1010) { True => Ok(Pr(Star, bump(src, s))), False => // *
      match eq_b(c, 0b0010_1111) { True => Ok(Pr(Slash, bump(src, s))), False => // /
      match eq_b(c, 0b0010_0101) { True => Ok(Pr(Percent, bump(src, s))), False => // %
      match eq_b(c, 0b0101_1110) { True => Ok(Pr(Caret, bump(src, s))), False => // ^
      match eq_b(c, 0b0010_0110) { True => Ok(lex_amp(src, s)), False => // &
      match eq_b(c, 0b0011_1100) { True => Ok(lex_langle(src, s)), False => // <
      match eq_b(c, 0b0011_1101) { True => Ok(lex_eq(src, s)), False => // =
      match eq_b(c, 0b0010_1101) { True => Ok(lex_dash(src, s)), False => // -
      match eq_b(c, 0b0010_0010) { True => lex_string(src, s), False => // "
      match eq_b(c, 0b0011_0000) { True => lex_zero_prefixed(src, s), False => // 0
      match is_digit(c) { True => Ok(lex_int(src, s)), False =>
      match is_ident_start(c) { True => Ok(lex_ident(src, s)), False =>
      Err(PE(st_pos(s), "unexpected character"))
      }}}}}}}}}}}}}}}}}}}}}}}}}}}
};

// ‚îÄ‚îÄ run / lex ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn run(src: Bytes, s: St) => Result[Vec[Spanned], PErr] =
  run_acc(src, s, Nil : Vec[Spanned]);

fn run_acc(src: Bytes, s: St, acc: Vec[Spanned]) => Result[Vec[Spanned], PErr] =
  let s1 = skip_trivia(src, s) in
  match src_peek(src, st_i(s1)) {
    None => Ok(rev_acc(acc, Cons(Sp(Eof, st_pos(s1)), Nil : Vec[Spanned]))),
    Some(_) => match next_token(src, s1) {
      Err(e) => Err(e),
      Ok(pr) => match pr {
        Pr(tok, s2) => run_acc(src, s2, Cons(Sp(tok, st_pos(s1)), acc))
      }
    }
  };

// lex: tokenize `src` into a `Spanned` stream terminated by `Eof` (mirrors lexer.rs::lex). Comments
// are discarded (FLAG-lex-5); never-silent on any lexically invalid input (an explicit `Err`, never
// a panic or a silently-skipped character).
fn lex(src: Bytes) => Result[Vec[Spanned], PErr] =
  run(src, S(0b0000_0000_0000_0000_0000_0000_0000_0000, 0b0000_0000_0000_0000_0000_0000_0000_0001, 0b0000_0000_0000_0000_0000_0000_0000_0001));

// ‚îÄ‚îÄ AST types (mirrored verbatim from compiler.ast ‚Äî FLAG-parse-1; ast.myc's own local
// Option[A]/Vec[A] redeclare is SKIPPED here, already declared once at file top) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// ‚îÄ‚îÄ Vis (mirrors ast.rs::Vis ‚Äî M-662 cross-nodule visibility) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// Private = no `pub` marker (default); Pub = exported to the phylum's other nodules.
type Vis = Private | Pub;

fn vis_is_pub(v: Vis) => Bool =
  match v { Private => False, Pub => True };

// ‚îÄ‚îÄ Path (mirrors ast.rs::Path ‚Äî a dotted path or bare name) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Path = Pth(Vec[Bytes]);

fn path_segs(p: Path) => Vec[Bytes] =
  match p { Pth(segs) => segs };

// ‚îÄ‚îÄ UsePath (mirrors ast.rs::UsePath ‚Äî M-662 cross-nodule import target) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// `path`; `glob` = True for `use a.b.*`, False for a specific `use a.b.Item`.
type UsePath = UP(Path, Bool);

fn usepath_path(u: UsePath) => Path =
  match u { UP(p, _) => p };

fn usepath_glob(u: UsePath) => Bool =
  match u { UP(_, g) => g };

// ‚îÄ‚îÄ Paradigm (mirrors ast.rs::Paradigm ‚Äî FLAG-ast-4 P-prefix) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Paradigm = PBinary | PTernary | PDense | PVsa;

// paradigm_to_bytes: mirrors `impl Display for Paradigm` (FLAG-ast-7 note: this one IS ported ‚Äî
// a trivial fixed 4-string lookup, unlike WidthRef's).
fn paradigm_to_bytes(p: Paradigm) => Bytes =
  match p {
    PBinary => "Binary",
    PTernary => "Ternary",
    PDense => "Dense",
    PVsa => "VSA"
  };

// ‚îÄ‚îÄ Scalar (mirrors ast.rs::Scalar ‚Äî FLAG-ast-4 S-prefix, reuses token.myc::ScalarTok naming) ‚îÄ‚îÄ
type Scalar = SF16 | SBf16 | SF32 | SF64;

// ‚îÄ‚îÄ Sparsity (mirrors ast.rs::Sparsity ‚Äî FLAG-ast-4 Sp-prefix, both variants collide) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Sparsity = SpDense | SpSparse(Binary{32});

// ‚îÄ‚îÄ AmbientParams (mirrors ast.rs::AmbientParams ‚Äî RFC-0012 ¬ß4.2 paradigm-less repr params;
// FLAG-ast-4/5 AP-prefix) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type AmbientParams =
    APSize(Binary{32})
  | APDense(Binary{32}, Scalar)
  | APVsa(Bytes, Binary{32}, Sparsity);

// ‚îÄ‚îÄ Strength (mirrors ast.rs::Strength ‚Äî the guarantee-lattice tag; FLAG-ast-4 G-prefix) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Strength = GExact | GProven | GEmpirical | GDeclared;

// strength_rank: mirrors `Strength::rank` (u8 -> Binary{8}; Declared=0 .. Exact=3).
fn strength_rank(s: Strength) => Binary{8} =
  match s {
    GDeclared => 0b0000_0000,
    GEmpirical => 0b0000_0001,
    GProven => 0b0000_0010,
    GExact => 0b0000_0011
  };

// strength_meet: mirrors `Strength::meet` ‚Äî the weaker (less-trusted) of the two grades.
fn strength_meet(a: Strength, b: Strength) => Strength =
  match lt(strength_rank(b), strength_rank(a)) {
    0b1 => b,
    _ => a
  };

// strength_satisfies: mirrors `Strength::satisfies` ‚Äî `self.rank() >= demand.rank()`.
fn strength_satisfies(actual: Strength, demand: Strength) => Bool =
  match lt(strength_rank(actual), strength_rank(demand)) {
    0b1 => False,
    _ => True
  };

// ‚îÄ‚îÄ WidthRef (mirrors ast.rs::WidthRef ‚Äî DN-42/M-753 v1 width slot; FLAG-ast-4/5 W-prefix) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type WidthRef = WLit(Binary{32}) | WName(Bytes);

// FLAG-ast-7: no `widthref_to_bytes` ‚Äî the Display impl needs int-to-decimal-string conversion,
// not available self-contained; honest narrowing, not silently dropped.

// ‚îÄ‚îÄ ParamKind (mirrors ast.rs::ParamKind ‚Äî DN-42/M-753 v1; FLAG-ast-5 Pk-prefix) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type ParamKind = PkType | PkWidth;

fn paramkind_eq(a: ParamKind, b: ParamKind) => Bool =
  match a {
    PkType => match b { PkType => True, PkWidth => False },
    PkWidth => match b { PkType => False, PkWidth => True }
  };

// ‚îÄ‚îÄ TraitRef (mirrors ast.rs::TraitRef ‚Äî a bound-position trait reference) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type TraitRef = TRf(Bytes, Vec[TypeRef]);

fn traitref_name(t: TraitRef) => Bytes =
  match t { TRf(n, _) => n };

fn traitref_args(t: TraitRef) => Vec[TypeRef] =
  match t { TRf(_, a) => a };

// ‚îÄ‚îÄ TypeParam (mirrors ast.rs::TypeParam ‚Äî a possibly-bounded fn type parameter) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type TypeParam = TP(Bytes, ParamKind, Vec[TraitRef]);

fn typeparam_name(t: TypeParam) => Bytes =
  match t { TP(n, _, _) => n };

fn typeparam_kind(t: TypeParam) => ParamKind =
  match t { TP(_, k, _) => k };

fn typeparam_bounds(t: TypeParam) => Vec[TraitRef] =
  match t { TP(_, _, b) => b };

// typeparam_names_of_kind: shared filter for fn_sig_param_names / fn_sig_width_param_names below.
// Non-tail, bounded by the fn's OWN type-parameter count (a handful) ‚Äî not source length; the same
// nesting-bounded shape nodule.myc's split_dotted/join_segs use (RFC-0041 ¬ß7 W7 amendment 11).
fn typeparam_names_of_kind(ps: Vec[TypeParam], k: ParamKind) => Vec[Bytes] =
  match ps {
    Nil => Nil,
    Cons(p, rest) =>
      match paramkind_eq(typeparam_kind(p), k) {
        True => Cons(typeparam_name(p), typeparam_names_of_kind(rest, k)),
        False => typeparam_names_of_kind(rest, k)
      }
  };

// ‚îÄ‚îÄ EffectBudget (mirrors one entry of ast.rs::FnSig::effect_budgets ‚Äî FLAG-ast-6) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type EffectBudget = EB(Bytes, Binary{64});

// ‚îÄ‚îÄ FnSig (mirrors ast.rs::FnSig ‚Äî a fn/trait-requirement signature) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// Fields, in order: name, params (bounded type params), value_params, ret, effects (declared
// names), effect_budgets (FLAG-ast-6: an ordered Vec, not a BTreeMap).
type FnSig = FS(Bytes, Vec[TypeParam], Vec[Param], TypeRef, Vec[Bytes], Vec[EffectBudget]);

fn fnsig_name(s: FnSig) => Bytes =
  match s { FS(n, _, _, _, _, _) => n };

fn fnsig_params(s: FnSig) => Vec[TypeParam] =
  match s { FS(_, p, _, _, _, _) => p };

fn fnsig_value_params(s: FnSig) => Vec[Param] =
  match s { FS(_, _, vp, _, _, _) => vp };

fn fnsig_ret(s: FnSig) => TypeRef =
  match s { FS(_, _, _, r, _, _) => r };

fn fnsig_effects(s: FnSig) => Vec[Bytes] =
  match s { FS(_, _, _, _, e, _) => e };

fn fnsig_effect_budgets(s: FnSig) => Vec[EffectBudget] =
  match s { FS(_, _, _, _, _, eb) => eb };

// fnsig_param_names: mirrors `FnSig::param_names` (type-kind params only).
fn fnsig_param_names(s: FnSig) => Vec[Bytes] =
  typeparam_names_of_kind(fnsig_params(s), PkType);

// fnsig_width_param_names: mirrors `FnSig::width_param_names` (width-kind params only).
fn fnsig_width_param_names(s: FnSig) => Vec[Bytes] =
  typeparam_names_of_kind(fnsig_params(s), PkWidth);

// ‚îÄ‚îÄ Param (mirrors ast.rs::Param ‚Äî a value parameter `name: type`) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Param = Prm(Bytes, TypeRef);

fn param_name(p: Param) => Bytes =
  match p { Prm(n, _) => n };

fn param_ty(p: Param) => TypeRef =
  match p { Prm(_, t) => t };

// ‚îÄ‚îÄ TypeRef / BaseType (mirror ast.rs::TypeRef / ast.rs::BaseType ‚Äî mutually recursive; the
// two-pass shell-then-resolve type registration handles this regardless of declaration order,
// see the file header's Box/recursion note) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type TypeRef = TR(BaseType, Option[Strength]);

fn typeref_base(t: TypeRef) => BaseType =
  match t { TR(b, _) => b };

fn typeref_guarantee(t: TypeRef) => Option[Strength] =
  match t { TR(_, g) => g };

// typeref_unguaranteed: mirrors `TypeRef::unguaranteed`.
fn typeref_unguaranteed(b: BaseType) => TypeRef =
  TR(b, None);

// typeref_with_guarantee: mirrors `TypeRef::with_guarantee`.
fn typeref_with_guarantee(b: BaseType, g: Strength) => TypeRef =
  TR(b, Some(g));

// BaseType: mirrors ast.rs::BaseType field-for-field. FLAG-ast-4 renames the 7 repr-keyword
// collisions (Kw-prefix); FLAG-ast-5 renames `Fn` (cross-type collision with `Item::Fn`) to
// `FnArrow`. `Vsa`/`Named`/`Ambient`/`Tuple` are bare (no collision after FLAG-ast-4's Paradigm/
// AmbientParams renames leave them the sole survivor).
type BaseType =
    KwBinary(WidthRef)
  | KwTernary(WidthRef)
  | KwDense(Binary{32}, Scalar)
  | Vsa(Bytes, Binary{32}, Sparsity)
  | KwSubstrate(Bytes)
  | KwSeq(TypeRef, Binary{32})
  | KwBytes
  | KwFloat
  | Named(Bytes, Vec[TypeRef])
  | Ambient(AmbientParams)
  | FnArrow(TypeRef, TypeRef)
  | Tuple(Vec[TypeRef]);

// ‚îÄ‚îÄ ExecutionMode (mirrors ast.rs::ExecutionMode ‚Äî DN-58 ¬ßC `@tier(mode)` request) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type ExecutionMode = Interpreted | Compiled;

// ‚îÄ‚îÄ FnDecl (mirrors ast.rs::FnDecl ‚Äî a function definition) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// Fields, in order: vis, thaw (bool), tier (Option[ExecutionMode]), sig, body.
type FnDecl = FD(Vis, Bool, Option[ExecutionMode], FnSig, Expr);

fn fndecl_vis(f: FnDecl) => Vis =
  match f { FD(v, _, _, _, _) => v };

fn fndecl_thaw(f: FnDecl) => Bool =
  match f { FD(_, t, _, _, _) => t };

fn fndecl_tier(f: FnDecl) => Option[ExecutionMode] =
  match f { FD(_, _, t, _, _) => t };

fn fndecl_sig(f: FnDecl) => FnSig =
  match f { FD(_, _, _, s, _) => s };

fn fndecl_body(f: FnDecl) => Expr =
  match f { FD(_, _, _, _, b) => b };

// ‚îÄ‚îÄ Ctor (mirrors ast.rs::Ctor ‚Äî one constructor of a TypeDecl) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// M-1027 / DN-104: the 3rd field is the `sealed` (`priv`) flag (surface parity with ast.rs::Ctor).
type Ctor = Ctr(Bytes, Vec[TypeRef], Bool);

fn ctor_name(c: Ctor) => Bytes =
  match c { Ctr(n, _, _) => n };

fn ctor_fields(c: Ctor) => Vec[TypeRef] =
  match c { Ctr(_, f, _) => f };

// ctor_sealed: the per-constructor `priv` seal (M-1027 / DN-104).
fn ctor_sealed(c: Ctor) => Bool =
  match c { Ctr(_, _, s) => s };

// ‚îÄ‚îÄ TypeDecl (mirrors ast.rs::TypeDecl ‚Äî `type Name<params> = Ctor | ‚Ä¶`) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type TypeDecl = TD(Vis, Bytes, Vec[Bytes], Vec[Ctor]);

fn typedecl_vis(t: TypeDecl) => Vis =
  match t { TD(v, _, _, _) => v };

fn typedecl_name(t: TypeDecl) => Bytes =
  match t { TD(_, n, _, _) => n };

fn typedecl_params(t: TypeDecl) => Vec[Bytes] =
  match t { TD(_, _, p, _) => p };

fn typedecl_ctors(t: TypeDecl) => Vec[Ctor] =
  match t { TD(_, _, _, c) => c };

// ‚îÄ‚îÄ TraitDecl (mirrors ast.rs::TraitDecl ‚Äî `trait Name<params> { fn ‚Ä¶ }`) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type TraitDecl = TrD(Vis, Bytes, Vec[Bytes], Vec[FnSig]);

fn traitdecl_vis(t: TraitDecl) => Vis =
  match t { TrD(v, _, _, _) => v };

fn traitdecl_name(t: TraitDecl) => Bytes =
  match t { TrD(_, n, _, _) => n };

fn traitdecl_params(t: TraitDecl) => Vec[Bytes] =
  match t { TrD(_, _, p, _) => p };

fn traitdecl_sigs(t: TraitDecl) => Vec[FnSig] =
  match t { TrD(_, _, _, s) => s };

// ‚îÄ‚îÄ ImplDecl (mirrors ast.rs::ImplDecl ‚Äî `impl Trait<args> for T { fn ‚Ä¶ }`) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type ImplDecl = ImD(Bytes, Vec[TypeRef], TypeRef, Vec[FnDecl]);

fn impldecl_trait_name(i: ImplDecl) => Bytes =
  match i { ImD(n, _, _, _) => n };

fn impldecl_trait_args(i: ImplDecl) => Vec[TypeRef] =
  match i { ImD(_, a, _, _) => a };

fn impldecl_for_ty(i: ImplDecl) => TypeRef =
  match i { ImD(_, _, t, _) => t };

fn impldecl_methods(i: ImplDecl) => Vec[FnDecl] =
  match i { ImD(_, _, _, m) => m };

// ‚îÄ‚îÄ ViaDecl (mirrors ast.rs::ViaDecl ‚Äî DN-53 M-811 `via <field_idx> : <Trait>` delegation) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type ViaDecl = VD(Binary{32}, Bytes, Vec[TypeRef]);

fn viadecl_field_idx(v: ViaDecl) => Binary{32} =
  match v { VD(i, _, _) => i };

fn viadecl_trait_name(v: ViaDecl) => Bytes =
  match v { VD(_, n, _) => n };

fn viadecl_trait_args(v: ViaDecl) => Vec[TypeRef] =
  match v { VD(_, _, a) => a };

// ‚îÄ‚îÄ ObjectDecl (mirrors ast.rs::ObjectDecl ‚Äî DN-53 M-811 `object` composition surface) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type ObjectDecl = OD(Vis, Bytes, Vec[Bytes], Ctor, Vec[ViaDecl], Vec[ImplDecl], Vec[FnDecl]);

fn objectdecl_vis(o: ObjectDecl) => Vis =
  match o { OD(v, _, _, _, _, _, _) => v };

fn objectdecl_name(o: ObjectDecl) => Bytes =
  match o { OD(_, n, _, _, _, _, _) => n };

fn objectdecl_params(o: ObjectDecl) => Vec[Bytes] =
  match o { OD(_, _, p, _, _, _, _) => p };

fn objectdecl_ctor(o: ObjectDecl) => Ctor =
  match o { OD(_, _, _, c, _, _, _) => c };

fn objectdecl_via_decls(o: ObjectDecl) => Vec[ViaDecl] =
  match o { OD(_, _, _, _, vd, _, _) => vd };

fn objectdecl_impls(o: ObjectDecl) => Vec[ImplDecl] =
  match o { OD(_, _, _, _, _, i, _) => i };

fn objectdecl_fns(o: ObjectDecl) => Vec[FnDecl] =
  match o { OD(_, _, _, _, _, _, f) => f };

// ‚îÄ‚îÄ InherentImplDecl (mirrors ast.rs::InherentImplDecl ‚Äî M-664 + DN-103 `impl[T]? T { fn ‚Ä¶ }`) ‚îÄ‚îÄ‚îÄ‚îÄ
// The first field is the impl-level type-parameter slot (DN-103 / M-1026 / ENB-3): unbounded names
// (`impl[T] Foo[T] { ‚Ä¶ }`), Nil for the plain M-664 block. The desugar-prepend of these params onto
// each lifted method is Rust-only (checkty.rs Phase 0) ‚Äî this mirror carries the slot structurally.
type InherentImplDecl = IID(Vec[Bytes], TypeRef, Vec[FnDecl]);

fn inherentimpldecl_params(i: InherentImplDecl) => Vec[Bytes] =
  match i { IID(p, _, _) => p };

fn inherentimpldecl_for_ty(i: InherentImplDecl) => TypeRef =
  match i { IID(_, t, _) => t };

fn inherentimpldecl_methods(i: InherentImplDecl) => Vec[FnDecl] =
  match i { IID(_, _, m) => m };

// ‚îÄ‚îÄ LowerRhs (mirrors ast.rs::LowerRhs ‚Äî DN-54 ¬ß10 the RHS of a `lower` rule; FLAG-ast-5 LR-
// prefix, both variants renamed since `Impl` collides with `Item::Impl`) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type LowerRhs = LRExpr(Expr) | LRImpl(ImplDecl);

// ‚îÄ‚îÄ LowerDecl (mirrors ast.rs::LowerDecl ‚Äî `lower Name[params] = <rhs>`, DN-54 ¬ß3.2/M-812) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type LowerDecl = LD(Bytes, Vec[Bytes], LowerRhs);

fn lowerdecl_name(l: LowerDecl) => Bytes =
  match l { LD(n, _, _) => n };

fn lowerdecl_params(l: LowerDecl) => Vec[Bytes] =
  match l { LD(_, p, _) => p };

fn lowerdecl_rhs(l: LowerDecl) => LowerRhs =
  match l { LD(_, _, r) => r };

// lowerdecl_expr_rhs: mirrors `LowerDecl::expr_rhs`.
fn lowerdecl_expr_rhs(l: LowerDecl) => Option[Expr] =
  match lowerdecl_rhs(l) {
    LRExpr(e) => Some(e),
    LRImpl(_) => None
  };

// lowerdecl_impl_rhs: mirrors `LowerDecl::impl_rhs`.
fn lowerdecl_impl_rhs(l: LowerDecl) => Option[ImplDecl] =
  match lowerdecl_rhs(l) {
    LRImpl(i) => Some(i),
    LRExpr(_) => None
  };

// ‚îÄ‚îÄ DeriveDecl (mirrors ast.rs::DeriveDecl ‚Äî `derive Name for T`, DN-54 ¬ß3.2/¬ß8.1) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type DeriveDecl = DD(Bytes, TypeRef);

fn derivedecl_name(d: DeriveDecl) => Bytes =
  match d { DD(n, _) => n };

fn derivedecl_for_ty(d: DeriveDecl) => TypeRef =
  match d { DD(_, t) => t };

// ‚îÄ‚îÄ Item (mirrors ast.rs::Item ‚Äî a top-level item; every variant is bare/unrenamed, none collide
// per FLAG-ast-4's case-sensitivity reasoning) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Item =
    Use(UsePath)
  | Default(Paradigm)
  | Type(TypeDecl)
  | Trait(TraitDecl)
  | Impl(ImplDecl)
  | Fn(FnDecl)
  | Object(ObjectDecl)
  | Lower(LowerDecl)
  | Derive(DeriveDecl)
  | InherentImpl(InherentImplDecl);

// ‚îÄ‚îÄ Nodule (mirrors ast.rs::Nodule ‚Äî a whole program: header + items) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// Fields, in order: path, std_sys (the `@std-sys` header marker), items.
type Nodule = Nd(Path, Bool, Vec[Item]);

fn nodule_path(n: Nodule) => Path =
  match n { Nd(p, _, _) => p };

fn nodule_std_sys(n: Nodule) => Bool =
  match n { Nd(_, s, _) => s };

fn nodule_items(n: Nodule) => Vec[Item] =
  match n { Nd(_, _, i) => i };

// ‚îÄ‚îÄ Phylum (mirrors ast.rs::Phylum ‚Äî M-662/DN-06 the library-scale grouping above nodule) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Phylum = Phy(Option[Path], Vec[Nodule]);

fn phylum_path(p: Phylum) => Option[Path] =
  match p { Phy(pa, _) => pa };

fn phylum_nodules(p: Phylum) => Vec[Nodule] =
  match p { Phy(_, n) => n };

// phylum_of_one: mirrors `Phylum::of_one` ‚Äî a phylum-of-one wrapping a single bare nodule.
fn phylum_of_one(n: Nodule) => Phylum =
  Phy(None, Cons(n, Nil));

// ‚îÄ‚îÄ Literal (mirrors ast.rs::Literal ‚Äî a literal value; FLAG-ast-4/5 renames `Bytes` -> `LBytes`
// and `Float` -> `LFloat` (both collide with a repr keyword AND with `BaseType::Bytes`/`Float`);
// FLAG-ast-8: no `#[non_exhaustive]` analog) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Literal =
    Bin(Bytes)
  | Trit(Bytes)
  | Int(Binary{64})
  | AmbientInt(Paradigm, Binary{64})
  | List(Vec[Expr])
  | LBytes(Bytes)
  | Str(Bytes)
  | LFloat(Bytes);

// literal_binary: mirrors `Literal::binary`.
fn literal_binary(digits: Bytes) => Literal =
  Bin(digits);

// literal_ternary: mirrors `Literal::ternary`.
fn literal_ternary(trits: Bytes) => Literal =
  Trit(trits);

// literal_string: mirrors `Literal::string`.
fn literal_string(content: Bytes) => Literal =
  Str(content);

// literal_float: mirrors `Literal::float`.
fn literal_float(text: Bytes) => Literal =
  LFloat(text);

// ‚îÄ‚îÄ Pattern (mirrors ast.rs::Pattern ‚Äî a match pattern; FLAG-ast-5 P-prefix throughout, since
// `Lit`/`Tuple` each collide with another type and the rest are prefixed for consistency) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Pattern =
    PWildcard
  | PLit(Literal)
  | PCtor(Bytes, Vec[Pattern])
  | PIdent(Bytes)
  | PTuple(Vec[Pattern])
  | POr(Vec[Pattern]);

// ‚îÄ‚îÄ Arm (mirrors ast.rs::Arm ‚Äî one `match` arm) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Arm = Ar(Pattern, Expr);

fn arm_pattern(a: Arm) => Pattern =
  match a { Ar(p, _) => p };

fn arm_body(a: Arm) => Expr =
  match a { Ar(_, b) => b };

// ‚îÄ‚îÄ Hypha (mirrors ast.rs::Hypha ‚Äî one `hypha <expr>` spawn inside a `colony` block) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// Fields, in order: forage (an optional `@forage(policy)` literal-mask expression), body.
type Hypha = Hy(Option[Expr], Expr);

fn hypha_forage(h: Hypha) => Option[Expr] =
  match h { Hy(f, _) => f };

fn hypha_body(h: Hypha) => Expr =
  match h { Hy(_, b) => b };

// ‚îÄ‚îÄ Expr (mirrors ast.rs::Expr ‚Äî an expression; every variant is bare/unrenamed except where
// FLAG-ast-4/5 note a collision elsewhere in this file) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
// FLAG-parse-12: the `Wrapping` variant (M-791) is represented above and walked (the walk_expr
// fingerprint arm, tag 0x6E), but the parser does NOT yet PRODUCE it ‚Äî there is no `wrapping { e }`
// parse rule (nor a `wrapping` keyword in the lexer). Surface parsing of the wrapping-arithmetic
// opt-in is deferred remaining work (never-silent, G2); the Rust reference parser produces it
// (ast.rs::Expr::Wrapping).
type Expr =
    Let(Bytes, Option[TypeRef], Expr, Expr)
  | If(Expr, Expr, Expr)
  | Match(Expr, Vec[Arm])
  | For(Bytes, Expr, Bytes, Expr, Expr)
  | Swap(Expr, TypeRef, Path)
  | WithParadigm(Paradigm, Expr)
  | Wild(Expr)
  | Spore(Expr)
  | Wrapping(Expr)
  | Consume(Expr)
  // DN-102 (M-1025 ENB-2): the `?` try-operator node. REPRESENTED + traversed here (like
  // `Wrapping`/`Consume`), but the self-hosted lexer/parser does NOT yet PRODUCE it ‚Äî the Rust
  // reference frontend does (ast.rs::Expr::Try), and `myc check` (Rust-backed) handles `?` in a
  // `.myc` file. Represented-not-produced (never-silent, G2; FLAG-try-3).
  | Try(Expr)
  | Colony(Vec[Hypha])
  | Lambda(Vec[Param], Expr)
  | App(Expr, Vec[Expr])
  | Fuse(Expr, Expr)
  | Reclaim(Expr, Expr)
  | Path(Path)
  | Lit(Literal)
  | Ascribe(Expr, TypeRef)
  | TupleLit(Vec[Expr]);

// ‚îÄ‚îÄ Parser (M-740 Stage 3b port of crates/mycelium-l1/src/parse.rs) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

// ‚îÄ‚îÄ single-token classification predicates (each a ONE-LEVEL match over `Tok` directly ‚Äî
