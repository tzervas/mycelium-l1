// ‚îÄ‚îÄ parser primitives (value-semantics restatement of Parser::{cur,pos,at,bump,expect,eat} ‚Äî
// FLAG-parse-7: the remaining token stream IS the parser state, a zipper: `Cons(sp, rest)` means
// `sp` is the current token and `rest` is everything after it; `bump` never advances past the final
// `Eof` sentinel, exactly mirroring Rust's `if self.i + 1 < self.toks.len() { self.i += 1 }`) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn p_cur(ts: Vec[Spanned]) => Tok =
  match ts {
    Nil => Eof,
    Cons(sp, _) => sp_tok(sp)
  };

fn p_pos(ts: Vec[Spanned]) => Pos =
  match ts {
    Nil => P(0b0000_0000_0000_0000_0000_0000_0000_0000, 0b0000_0000_0000_0000_0000_0000_0000_0000),
    Cons(sp, _) => sp_pos(sp)
  };

// p_bump: drop the current token UNLESS it is the last remaining one (mirrors Rust's bump, which
// never advances the index once at the final token ‚Äî the stream tail is always a lone `Eof` cell).
fn p_bump(ts: Vec[Spanned]) => Vec[Spanned] =
  match ts {
    Nil => Nil,
    Cons(_, rest) => match rest {
      Nil => ts,
      Cons(_, _) => rest
    }
  };

// p_eat(ts, is_it): mirrors `Parser::eat` ‚Äî the caller supplies `is_it = is_X(p_cur(ts))`
// (FLAG-parse-5 extended). `Some(ts')` on a match (consumed), `None` otherwise (unchanged).
fn p_eat(ts: Vec[Spanned], is_it: Bool) => Option[Vec[Spanned]] =
  match is_it {
    True => Some(p_bump(ts)),
    False => None
  };

// p_expect(ts, is_it, msg): mirrors `Parser::expect` ‚Äî consumes on a match, else an explicit `PErr`
// at the CURRENT position (captured by the caller before dispatch, since `ts` is still un-bumped).
fn p_expect(ts: Vec[Spanned], is_it: Bool, msg: Bytes) => Result[Vec[Spanned], PErr] =
  match is_it {
    True => Ok(p_bump(ts)),
    False => Err(PE(p_pos(ts), msg))
  };

// p_ident: mirrors `Parser::ident` ‚Äî an `Ident(s)` token, or an explicit refusal.
fn p_ident(ts: Vec[Spanned]) => Result[Pair[Bytes, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    Ident(s) => Ok(Pr(s, p_bump(ts))),
    _ => Err(PE(p_pos(ts), "expected an identifier"))
  };

// ‚îÄ‚îÄ decimal digit-run -> Binary{32}/{64} (FLAG-parse-3/4: Horner's-method multiply-accumulate via
// `add_u`/`shl_u`/`width_cast`, never `mul_s` ‚Äî `mul_s` reads Binary{N} as SIGNED two's-complement,
// the same reason `lib/std/ternary.myc` avoids it for unsigned scaling. `acc*10 = (acc<<3)+(acc<<1)`.
// Overflow is an interpreter-level `add_u` trap, not a parse-time `Err` ‚Äî FLAG-parse-4, unexercised
// by the accept-corpus) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn zero32() => Binary{32} = 0b0000_0000_0000_0000_0000_0000_0000_0000;
fn one32() => Binary{32} = 0b0000_0000_0000_0000_0000_0000_0000_0001;
fn three32() => Binary{32} = 0b0000_0000_0000_0000_0000_0000_0000_0011;
fn zero64() => Binary{64} = 0b0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000;
fn one64() => Binary{64} = 0b0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0001;
fn three64() => Binary{64} = 0b0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0011;

fn digit_value(b: Binary{8}) => Binary{8} =
  sub_u(b, 0b0011_0000); // ASCII '0'

fn bytes_to_u32(digits: Bytes, i: Binary{32}, acc: Binary{32}) => Binary{32} =
  match lt(i, bytes_len(digits)) {
    0b1 =>
      let d32 = width_cast(digit_value(bytes_get(digits, i)), zero32()) in
      let acc10 = add_u(shl_u(acc, three32()), shl_u(acc, one32())) in
      bytes_to_u32(digits, add_u(i, one32()), add_u(acc10, d32)),
    _ => acc
  };

fn decimal_to_u32(digits: Bytes) => Binary{32} =
  bytes_to_u32(digits, zero32(), zero32());

fn bytes_to_u64(digits: Bytes, i: Binary{32}, acc: Binary{64}) => Binary{64} =
  match lt(i, bytes_len(digits)) {
    0b1 =>
      let d64 = width_cast(digit_value(bytes_get(digits, i)), zero64()) in
      let acc10 = add_u(shl_u(acc, three64()), shl_u(acc, one64())) in
      bytes_to_u64(digits, add_u(i, one32()), add_u(acc10, d64)),
    _ => acc
  };

fn decimal_to_u64(digits: Bytes) => Binary{64} =
  bytes_to_u64(digits, zero32(), zero64());

// p_u32_lit: mirrors `Parser::u32_lit` ‚Äî a `TInt(digits)` token, decimal-converted (FLAG-parse-3/4).
fn p_u32_lit(ts: Vec[Spanned]) => Result[Pair[Binary{32}, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    TInt(digits) => Ok(Pr(decimal_to_u32(digits), p_bump(ts))),
    _ => Err(PE(p_pos(ts), "expected a non-negative integer"))
  };

// ‚îÄ‚îÄ recursion-depth budget (A4-02 / DN-40; FLAG-parse-7) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn max_expr_depth() => Binary{32} = 0b0000_0000_0000_0000_0001_0000_0000_0000; // 4096

// enter_depth: charge one level against the budget. `Err` on overflow (never a panic); the caller
// passes the CHARGED depth into whatever it recurses into, and simply drops it (does not thread it
// back out) once that recursion returns ‚Äî the net-zero restatement of `leave_depth` (FLAG-parse-7).
fn enter_depth(ts: Vec[Spanned], depth: Binary{32}) => Result[Binary{32}, PErr] =
  let d2 = add_u(depth, 0b0000_0000_0000_0000_0000_0000_0000_0001) in
  match lt(max_expr_depth(), d2) {
    0b1 => Err(PE(p_pos(ts), "expression nests deeper than the limit of 4096 -- refusing to recurse")),
    _ => Ok(d2)
  };

// ‚îÄ‚îÄ classify_params / collect_name_uses (mirrors parse.rs's free fns of the same name ‚Äî DN-42/
// M-753 v1 width-vs-type param disambiguation by usage) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn contains_bytes(xs: Vec[Bytes], x: Bytes) => Bool =
  match xs {
    Nil => False,
    Cons(h, rest) => match bytes_eq(h, x) { 0b1 => True, _ => contains_bytes(rest, x) }
  };

fn add_bytes_if_absent(xs: Vec[Bytes], x: Bytes) => Vec[Bytes] =
  match contains_bytes(xs, x) {
    True => xs,
    False => Cons(x, xs)
  };

// NameUses: mirrors the pair of BTreeSets `collect_name_uses` accumulates into (width_used,
// type_used) ‚Äî threaded functionally instead of via `&mut` out-params.
type NameUses = NU(Vec[Bytes], Vec[Bytes]);

fn nu_width(n: NameUses) => Vec[Bytes] =
  match n { NU(w, _) => w };

fn nu_type(n: NameUses) => Vec[Bytes] =
  match n { NU(_, t) => t };

fn collect_widthref_use(w: WidthRef, params: Vec[Bytes], acc: NameUses) => NameUses =
  match w {
    WName(n) => match contains_bytes(params, n) {
      True => NU(add_bytes_if_absent(nu_width(acc), n), nu_type(acc)),
      False => acc
    },
    WLit(_) => acc
  };

fn collect_typeref_list_uses(trs: Vec[TypeRef], params: Vec[Bytes], acc: NameUses) => NameUses =
  match trs {
    Nil => acc,
    Cons(t, rest) => collect_typeref_list_uses(rest, params, collect_name_uses(t, params, acc))
  };

fn collect_name_uses(tr: TypeRef, params: Vec[Bytes], acc: NameUses) => NameUses =
  collect_base_name_uses(typeref_base(tr), params, acc);

fn collect_base_name_uses(bt: BaseType, params: Vec[Bytes], acc: NameUses) => NameUses =
  match bt {
    KwBinary(w) => collect_widthref_use(w, params, acc),
    KwTernary(w) => collect_widthref_use(w, params, acc),
    Named(n, args) =>
      let acc2 = match contains_bytes(params, n) {
        True => NU(nu_width(acc), add_bytes_if_absent(nu_type(acc), n)),
        False => acc
      } in
      collect_typeref_list_uses(args, params, acc2),
    KwSeq(elem, _) => collect_name_uses(elem, params, acc),
    FnArrow(a, b) => collect_name_uses(b, params, collect_name_uses(a, params, acc)),
    _ => acc
  };

fn typeparam_names(ps: Vec[TypeParam]) => Vec[Bytes] =
  typeparam_names_acc(ps, Nil : Vec[Bytes]);

fn typeparam_names_acc(ps: Vec[TypeParam], acc: Vec[Bytes]) => Vec[Bytes] =
  match ps {
    Nil => rev_acc(acc, Nil : Vec[Bytes]),
    Cons(p, rest) => typeparam_names_acc(rest, Cons(typeparam_name(p), acc))
  };

fn collect_param_list_uses(vps: Vec[Param], params: Vec[Bytes], acc: NameUses) => NameUses =
  match vps {
    Nil => acc,
    Cons(p, rest) => collect_param_list_uses(rest, params, collect_name_uses(param_ty(p), params, acc))
  };

fn is_bounds_empty(bs: Vec[TraitRef]) => Bool =
  match bs { Nil => True, Cons(_, _) => False };

fn classify_one_param(p: TypeParam, width_used: Vec[Bytes], type_used: Vec[Bytes]) => Result[TypeParam, PErr] =
  let nm = typeparam_name(p) in
  let inw = contains_bytes(width_used, nm) in
  let int_ = contains_bytes(type_used, nm) in
  match inw {
    True => match int_ {
      True => Err(PE(P(zero32(), zero32()), "parameter appears in both a width slot (Binary{N}/Ternary{N}) and a type slot -- ambiguous (DN-42/M-753)")),
      False => match is_bounds_empty(typeparam_bounds(p)) {
        True => Ok(TP(nm, PkWidth, Nil)),
        False => Err(PE(P(zero32(), zero32()), "width parameter cannot carry trait bounds in v1 (DN-42 SS7)"))
      }
    },
    False => Ok(TP(nm, PkType, typeparam_bounds(p)))
  };

fn classify_params_list(ps: Vec[TypeParam], width_used: Vec[Bytes], type_used: Vec[Bytes]) => Result[Vec[TypeParam], PErr] =
  classify_params_list_acc(ps, width_used, type_used, Nil : Vec[TypeParam]);

fn classify_params_list_acc(ps: Vec[TypeParam], width_used: Vec[Bytes], type_used: Vec[Bytes], acc: Vec[TypeParam]) => Result[Vec[TypeParam], PErr] =
  match ps {
    Nil => Ok(rev_acc(acc, Nil : Vec[TypeParam])),
    Cons(p, rest) => match classify_one_param(p, width_used, type_used) {
      Err(e) => Err(e),
      Ok(p2) => classify_params_list_acc(rest, width_used, type_used, Cons(p2, acc))
    }
  };

// classify_params: mirrors the free fn of the same name (parse.rs L133). Rust hardcodes
// `Pos{line:0,col:0}` for these errors (not `self.pos()`) ‚Äî reproduced verbatim (FLAG-parse-8: error
// POSITION fidelity is not compared by the Stage-3 gate, only Ok/Err classification).
fn classify_params(raw_params: Vec[TypeParam], value_params: Vec[Param], ret: TypeRef) => Result[Vec[TypeParam], PErr] =
  let names = typeparam_names(raw_params) in
  let acc1 = collect_param_list_uses(value_params, names, NU(Nil, Nil)) in
  let acc2 = collect_name_uses(ret, names, acc1) in
  classify_params_list(raw_params, nu_width(acc2), nu_type(acc2));

// first_duplicate_bytes: mirrors `first_duplicate_str` (the effect-set / param-name dup check).
fn first_duplicate_bytes(xs: Vec[Bytes]) => Option[Bytes] =
  first_duplicate_bytes_seen(xs, Nil);

fn first_duplicate_bytes_seen(xs: Vec[Bytes], seen: Vec[Bytes]) => Option[Bytes] =
  match xs {
    Nil => None,
    Cons(h, rest) => match contains_bytes(seen, h) {
      True => Some(h),
      False => first_duplicate_bytes_seen(rest, Cons(h, seen))
    }
  };

// ‚îÄ‚îÄ paradigm / scalar / strength / sparsity (leaf type-grammar productions; no depth threading ‚Äî
// none recurse into type/expr/pattern further) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_paradigm(ts: Vec[Spanned]) => Result[Pair[Paradigm, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    TKwBinary => Ok(Pr(PBinary, p_bump(ts))),
    TKwTernary => Ok(Pr(PTernary, p_bump(ts))),
    TKwDense => Ok(Pr(PDense, p_bump(ts))),
    TVsa => Ok(Pr(PVsa, p_bump(ts))),
    _ => Err(PE(p_pos(ts), "expected a paradigm (`Binary|Ternary|Dense|VSA`)"))
  };

fn parse_scalar(ts: Vec[Spanned]) => Result[Pair[Scalar, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    Scalar(sk) => match sk {
      TSF16 => Ok(Pr(SF16, p_bump(ts))),
      TSBf16 => Ok(Pr(SBf16, p_bump(ts))),
      TSF32 => Ok(Pr(SF32, p_bump(ts))),
      TSF64 => Ok(Pr(SF64, p_bump(ts)))
    },
    _ => Err(PE(p_pos(ts), "expected a scalar kind (`F16|BF16|F32|F64`)"))
  };

fn parse_strength(ts: Vec[Spanned]) => Result[Pair[Strength, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    Strength(sk) => match sk {
      TGExact => Ok(Pr(GExact, p_bump(ts))),
      TGProven => Ok(Pr(GProven, p_bump(ts))),
      TGEmpirical => Ok(Pr(GEmpirical, p_bump(ts))),
      TGDeclared => Ok(Pr(GDeclared, p_bump(ts)))
    },
    _ => Err(PE(p_pos(ts), "expected a guarantee strength (`Exact|Proven|Empirical|Declared`)"))
  };

fn braced_u32(ts: Vec[Spanned]) => Result[Pair[Binary{32}, Vec[Spanned]], PErr] =
  match p_expect(ts, is_lbrace(p_cur(ts)), "`{` and a width") {
    Err(e) => Err(e),
    Ok(ts1) => match p_u32_lit(ts1) {
      Err(e) => Err(e),
      Ok(pr1) => match pr1 { Pr(n, ts2) =>
        match p_expect(ts2, is_rbrace(p_cur(ts2)), "`}` to close the width") {
          Err(e) => Err(e),
          Ok(ts3) => Ok(Pr(n, ts3))
        }
      }
    }
  };

fn parse_sparsity(ts: Vec[Spanned]) => Result[Pair[Sparsity, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    TKwDense => Ok(Pr(SpDense, p_bump(ts))),
    KwSparse => match braced_u32(p_bump(ts)) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(k, ts2) => Ok(Pr(SpSparse(k), ts2)) }
    },
    _ => Err(PE(p_pos(ts), "expected a sparsity (`Dense` or `Sparse{...}`)"))
  };

// braced_width: `{` (u32_lit | Ident) `}` ‚Äî DN-42/M-753 width slot (concrete literal or width-param
// name).
fn braced_width(ts: Vec[Spanned]) => Result[Pair[WidthRef, Vec[Spanned]], PErr] =
  match p_expect(ts, is_lbrace(p_cur(ts)), "`{` and a width") {
    Err(e) => Err(e),
    Ok(ts1) => match p_cur(ts1) {
      Ident(s) =>
        match p_expect(p_bump(ts1), is_rbrace(p_cur(p_bump(ts1))), "`}` to close the width") {
          Err(e) => Err(e),
          Ok(ts3) => Ok(Pr(WName(s), ts3))
        },
      _ => match p_u32_lit(ts1) {
        Err(e) => Err(e),
        Ok(pr1) => match pr1 { Pr(v, ts2) =>
          match p_expect(ts2, is_rbrace(p_cur(ts2)), "`}` to close the width") {
            Err(e) => Err(e),
            Ok(ts3) => Ok(Pr(WLit(v), ts3))
          }
        }
      }
    }
  };

// ‚îÄ‚îÄ type grammar (mutually recursive; depth-threaded per FLAG-parse-7 ‚Äî `parse_type_ref` is the
// ONE guarded entry, everything else forwards `depth` unchanged) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_type_ref(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[TypeRef, Vec[Spanned]], PErr] =
  match enter_depth(ts, depth) {
    Err(e) => Err(e),
    Ok(d2) => parse_type_ref_guarded(ts, d2)
  };

fn parse_type_ref_guarded(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[TypeRef, Vec[Spanned]], PErr] =
  match parse_type_ref_atom(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(lhs, ts1) =>
      match is_arrow(p_cur(ts1)) {
        True => Err(PE(p_pos(ts1), "the function-type arrow is now `=>`, not `->` (RFC-0037 D4)")),
        False => match p_eat(ts1, is_fatarrow(p_cur(ts1))) {
          Some(ts2) => match parse_type_ref(ts2, depth) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(rhs, ts3) => Ok(Pr(typeref_unguaranteed(FnArrow(lhs, rhs)), ts3)) }
          },
          None => Ok(Pr(lhs, ts1))
        }
      }
    }
  };

fn parse_type_ref_atom(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[TypeRef, Vec[Spanned]], PErr] =
  match parse_base_type(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(base, ts1) =>
      match p_eat(ts1, is_at(p_cur(ts1))) {
        Some(ts2) => match parse_strength(ts2) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(g, ts3) => Ok(Pr(typeref_with_guarantee(base, g), ts3)) }
        },
        None => Ok(Pr(typeref_unguaranteed(base), ts1))
      }
    }
  };

fn parse_base_type(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[BaseType, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    TKwBinary => match braced_width(p_bump(ts)) {
      Err(e) => Err(e), Ok(pr) => match pr { Pr(w, ts1) => Ok(Pr(KwBinary(w), ts1)) }
    },
    BinShort => match braced_width(p_bump(ts)) {
      Err(e) => Err(e), Ok(pr) => match pr { Pr(w, ts1) => Ok(Pr(KwBinary(w), ts1)) }
    },
    TKwTernary => match braced_width(p_bump(ts)) {
      Err(e) => Err(e), Ok(pr) => match pr { Pr(w, ts1) => Ok(Pr(KwTernary(w), ts1)) }
    },
    TernShort => match braced_width(p_bump(ts)) {
      Err(e) => Err(e), Ok(pr) => match pr { Pr(w, ts1) => Ok(Pr(KwTernary(w), ts1)) }
    },
    TKwDense => parse_dense_tail(p_bump(ts)),
    EmbShort => parse_dense_tail(p_bump(ts)),
    TVsa => parse_vsa_tail(p_bump(ts)),
    HvecShort => parse_vsa_tail(p_bump(ts)),
    TKwSubstrate =>
      match p_expect(p_bump(ts), is_lbrace(p_cur(p_bump(ts))), "`{` after `Substrate`") {
        Err(e) => Err(e),
        Ok(ts1) => match p_ident(ts1) {
          Err(e) => Err(e),
          Ok(pr) => match pr { Pr(name, ts2) =>
            match p_expect(ts2, is_rbrace(p_cur(ts2)), "`}` to close `Substrate{...}`") {
              Err(e) => Err(e),
              Ok(ts3) => Ok(Pr(KwSubstrate(name), ts3))
            }
          }
        }
      },
    TKwSeq =>
      match p_expect(p_bump(ts), is_lbrace(p_cur(p_bump(ts))), "`{` after `Seq`") {
        Err(e) => Err(e),
        Ok(ts1) => match parse_type_ref(ts1, depth) {
          Err(e) => Err(e),
          Ok(pr) => match pr { Pr(elem, ts2) =>
            match p_expect(ts2, is_comma(p_cur(ts2)), "`,` between the element type and the length") {
              Err(e) => Err(e),
              Ok(ts3) => match p_u32_lit(ts3) {
                Err(e) => Err(e),
                Ok(pr2) => match pr2 { Pr(len, ts4) =>
                  match p_expect(ts4, is_rbrace(p_cur(ts4)), "`}` to close `Seq{...}`") {
                    Err(e) => Err(e),
                    Ok(ts5) => Ok(Pr(KwSeq(elem, len), ts5))
                  }
                }
              }
            }
          }
        }
      },
    TKwBytes => Ok(Pr(KwBytes, p_bump(ts))),
    TKwFloat => Ok(Pr(KwFloat, p_bump(ts))),
    Ident(s) => match parse_type_args_opt(p_bump(ts), depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(args, ts1) => Ok(Pr(Named(s, args), ts1)) }
    },
    LBrace => match parse_ambient_repr(ts, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(ap, ts1) => Ok(Pr(Ambient(ap), ts1)) }
    },
    LParen => parse_paren_type_tail(p_bump(ts), depth),
    _ => Err(PE(p_pos(ts), "expected a type"))
  };

fn parse_dense_tail(ts: Vec[Spanned]) => Result[Pair[BaseType, Vec[Spanned]], PErr] =
  match p_expect(ts, is_lbrace(p_cur(ts)), "`{` after `Dense`/`emb`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_u32_lit(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(dim, ts2) =>
        match p_expect(ts2, is_comma(p_cur(ts2)), "`,` between dim and dtype") {
          Err(e) => Err(e),
          Ok(ts3) => match parse_scalar(ts3) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(scalar, ts4) =>
              match p_expect(ts4, is_rbrace(p_cur(ts4)), "`}` to close `Dense{...}`/`emb{...}`") {
                Err(e) => Err(e),
                Ok(ts5) => Ok(Pr(KwDense(dim, scalar), ts5))
              }
            }
          }
        }
      }
    }
  };

fn parse_vsa_tail(ts: Vec[Spanned]) => Result[Pair[BaseType, Vec[Spanned]], PErr] =
  match p_expect(ts, is_lbrace(p_cur(ts)), "`{` after `VSA`/`hvec`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(model, ts2) =>
        match p_expect(ts2, is_comma(p_cur(ts2)), "`,` after the model") {
          Err(e) => Err(e),
          Ok(ts3) => match p_u32_lit(ts3) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(dim, ts4) =>
              match p_expect(ts4, is_comma(p_cur(ts4)), "`,` before the sparsity") {
                Err(e) => Err(e),
                Ok(ts5) => match parse_sparsity(ts5) {
                  Err(e) => Err(e),
                  Ok(pr3) => match pr3 { Pr(sparsity, ts6) =>
                    match p_expect(ts6, is_rbrace(p_cur(ts6)), "`}` to close `VSA{...}`/`hvec{...}`") {
                      Err(e) => Err(e),
                      Ok(ts7) => Ok(Pr(Vsa(model, dim, sparsity), ts7))
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  };

// parse_paren_type_tail: `ts` is positioned right AFTER the opening `(` (M-826 tuple-type / grouping
// disambiguation ‚Äî arity >= 2 is a tuple, a single `(T)` is grouping).
fn parse_paren_type_tail(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[BaseType, Vec[Spanned]], PErr] =
  match parse_type_ref(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(first, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        None => match p_expect(ts1, is_rparen(p_cur(ts1)), "`)` to close the parenthesized type") {
          Err(e) => Err(e),
          Ok(ts2) => Ok(Pr(typeref_base(first), ts2))
        },
        Some(ts2) => match parse_type_ref_tuple_rest(ts2, depth) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(rest, ts3) => match rest {
            Nil => Err(PE(p_pos(ts3), "a tuple type requires arity >= 2; a single-element parenthesized type `(T)` is grouping, not a 1-tuple (M-826)")),
            Cons(_, _) => Ok(Pr(Tuple(Cons(first, rest)), ts3))
          } }
        }
      }
    }
  };

// parse_type_ref_tuple_rest: the elements after the first comma, tolerating a trailing comma before
// `)` (mirrors the Rust `while !at(RParen) { push; if !eat(Comma) break }` loop).
fn parse_type_ref_tuple_rest(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[TypeRef], Vec[Spanned]], PErr] =
  parse_type_ref_tuple_rest_acc(ts, depth, Nil : Vec[TypeRef]);

fn parse_type_ref_tuple_rest_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[TypeRef]) => Result[Pair[Vec[TypeRef], Vec[Spanned]], PErr] =
  match is_rparen(p_cur(ts)) {
    True => match p_expect(ts, True, "`)` to close the tuple type") {
      Err(e) => Err(e),
      Ok(ts1) => Ok(Pr(rev_acc(acc, Nil : Vec[TypeRef]), ts1))
    },
    False => match parse_type_ref(ts, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(t, ts1) =>
        match p_eat(ts1, is_comma(p_cur(ts1))) {
          Some(ts2) => parse_type_ref_tuple_rest_acc(ts2, depth, Cons(t, acc)),
          None => match p_expect(ts1, is_rparen(p_cur(ts1)), "`)` to close the tuple type") {
            Err(e) => Err(e),
            Ok(ts2) => Ok(Pr(rev_acc(Cons(t, acc), Nil : Vec[TypeRef]), ts2))
          }
        }
      }
    }
  };

// parse_ambient_repr: `ts` still positioned AT the opening `{` (RFC-0012 SS4.2 paradigm-less repr).
fn parse_ambient_repr(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[AmbientParams, Vec[Spanned]], PErr] =
  match p_expect(ts, is_lbrace(p_cur(ts)), "`{` to open the paradigm-less repr") {
    Err(e) => Err(e),
    Ok(ts1) => match p_cur(ts1) {
      TInt(_) => match p_u32_lit(ts1) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(n, ts2) =>
          match p_eat(ts2, is_comma(p_cur(ts2))) {
            Some(ts3) => match parse_scalar(ts3) {
              Err(e) => Err(e),
              Ok(pr2) => match pr2 { Pr(scalar, ts4) =>
                match p_expect(ts4, is_rbrace(p_cur(ts4)), "`}` to close the paradigm-less repr") {
                  Err(e) => Err(e),
                  Ok(ts5) => Ok(Pr(APDense(n, scalar), ts5))
                }
              }
            },
            None => match p_expect(ts2, is_rbrace(p_cur(ts2)), "`}` to close the paradigm-less repr") {
              Err(e) => Err(e),
              Ok(ts3) => Ok(Pr(APSize(n), ts3))
            }
          }
        }
      },
      Ident(_) => match p_ident(ts1) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(model, ts2) =>
          match p_expect(ts2, is_comma(p_cur(ts2)), "`,` after the VSA model") {
            Err(e) => Err(e),
            Ok(ts3) => match p_u32_lit(ts3) {
              Err(e) => Err(e),
              Ok(pr2) => match pr2 { Pr(dim, ts4) =>
                match p_expect(ts4, is_comma(p_cur(ts4)), "`,` before the sparsity") {
                  Err(e) => Err(e),
                  Ok(ts5) => match parse_sparsity(ts5) {
                    Err(e) => Err(e),
                    Ok(pr3) => match pr3 { Pr(sparsity, ts6) =>
                      match p_expect(ts6, is_rbrace(p_cur(ts6)), "`}` to close the paradigm-less repr") {
                        Err(e) => Err(e),
                        Ok(ts7) => Ok(Pr(APVsa(model, dim, sparsity), ts7))
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      _ => Err(PE(p_pos(ts1), "expected a paradigm-less repr param (a size `{N}`, `{N, scalar}`, or VSA shape)"))
    }
  };

fn parse_type_args_opt(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[TypeRef], Vec[Spanned]], PErr] =
  match p_eat(ts, is_lbracket(p_cur(ts))) {
    None => Ok(Pr(Nil, ts)),
    Some(ts1) => match parse_type_ref_comma_list(ts1, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(args, ts2) =>
        match p_expect(ts2, is_rbracket(p_cur(ts2)), "`]` to close the type arguments") {
          Err(e) => Err(e),
          Ok(ts3) => Ok(Pr(args, ts3))
        }
      }
    }
  };

// parse_type_ref_comma_list: NON-EMPTY "`one (, one)*`" ‚Äî no trailing tolerance (ctor fields,
// type args; FLAG-parse-5).
fn parse_type_ref_comma_list(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[TypeRef], Vec[Spanned]], PErr] =
  parse_type_ref_comma_list_acc(ts, depth, Nil : Vec[TypeRef]);

fn parse_type_ref_comma_list_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[TypeRef]) => Result[Pair[Vec[TypeRef], Vec[Spanned]], PErr] =
  match parse_type_ref(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(t, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => parse_type_ref_comma_list_acc(ts2, depth, Cons(t, acc)),
        None => Ok(Pr(rev_acc(Cons(t, acc), Nil : Vec[TypeRef]), ts1))
      }
    }
  };

// ‚îÄ‚îÄ literal / pattern / path (mirrors parse_literal/parse_pattern*/parse_path) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_literal(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Literal, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    BinLit(s) => Ok(Pr(Bin(s), p_bump(ts))),
    TritLit(s) => Ok(Pr(Trit(s), p_bump(ts))),
    BytesLit(s) => Ok(Pr(LBytes(s), p_bump(ts))),
    StrLit(s) => Ok(Pr(Str(s), p_bump(ts))),
    FloatLit(s) => Ok(Pr(LFloat(s), p_bump(ts))),
    TInt(digits) => Ok(Pr(Int(decimal_to_u64(digits)), p_bump(ts))),
    LBracket => match parse_expr_list_until(p_bump(ts), depth, is_rbracket(p_cur(p_bump(ts)))) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(elems, ts1) =>
        match p_expect(ts1, is_rbracket(p_cur(ts1)), "`]` to close the list literal") {
          Err(e) => Err(e),
          Ok(ts2) => Ok(Pr(List(elems), ts2))
        }
      }
    },
    _ => Err(PE(p_pos(ts), "expected a literal"))
  };

fn parse_pattern(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Pattern, Vec[Spanned]], PErr] =
  match enter_depth(ts, depth) {
    Err(e) => Err(e),
    Ok(d2) => parse_pattern_guarded(ts, d2)
  };

fn parse_pattern_guarded(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Pattern, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    Ident(s) =>
      let ts1 = p_bump(ts) in
      match bytes_eq(s, "_") {
        0b1 => Ok(Pr(PWildcard, ts1)),
        _ => match p_eat(ts1, is_lparen(p_cur(ts1))) {
          Some(ts2) => match parse_pattern_comma_list(ts2, depth) {
            Err(e) => Err(e),
            Ok(pr) => match pr { Pr(subs, ts3) =>
              match p_expect(ts3, is_rparen(p_cur(ts3)), "`)` to close the constructor pattern") {
                Err(e) => Err(e),
                Ok(ts4) => Ok(Pr(PCtor(s, subs), ts4))
              }
            }
          },
          None => Ok(Pr(PIdent(s), ts1))
        }
      },
    BinLit(_) => parse_pattern_lit(ts, depth),
    TritLit(_) => parse_pattern_lit(ts, depth),
    BytesLit(_) => parse_pattern_lit(ts, depth),
    StrLit(_) => parse_pattern_lit(ts, depth),
    FloatLit(_) => parse_pattern_lit(ts, depth),
    TInt(_) => parse_pattern_lit(ts, depth),
    LBracket => parse_pattern_lit(ts, depth),
    LParen => parse_pattern_paren_tail(p_bump(ts), depth),
    _ => Err(PE(p_pos(ts), "expected a pattern"))
  };

fn parse_pattern_lit(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Pattern, Vec[Spanned]], PErr] =
  match parse_literal(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(l, ts1) => Ok(Pr(PLit(l), ts1)) }
  };

// parse_pattern_comma_list: NON-EMPTY, no trailing tolerance (ctor sub-patterns).
fn parse_pattern_comma_list(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[Pattern], Vec[Spanned]], PErr] =
  parse_pattern_comma_list_acc(ts, depth, Nil : Vec[Pattern]);

fn parse_pattern_comma_list_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[Pattern]) => Result[Pair[Vec[Pattern], Vec[Spanned]], PErr] =
  match parse_pattern(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(p, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => parse_pattern_comma_list_acc(ts2, depth, Cons(p, acc)),
        None => Ok(Pr(rev_acc(Cons(p, acc), Nil : Vec[Pattern]), ts1))
      }
    }
  };

// parse_pattern_paren_tail: `ts` positioned right after `(` (M-826 tuple/grouping disambiguation).
fn parse_pattern_paren_tail(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Pattern, Vec[Spanned]], PErr] =
  match parse_pattern(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(first, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        None => match p_expect(ts1, is_rparen(p_cur(ts1)), "`)` to close the parenthesized pattern") {
          Err(e) => Err(e),
          Ok(ts2) => Ok(Pr(first, ts2))
        },
        Some(ts2) => match parse_pattern_tuple_rest(ts2, depth) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(rest, ts3) => match rest {
            Nil => Err(PE(p_pos(ts3), "a tuple pattern requires arity >= 2 (M-826)")),
            Cons(_, _) => Ok(Pr(PTuple(Cons(first, rest)), ts3))
          } }
        }
      }
    }
  };

fn parse_pattern_tuple_rest(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[Pattern], Vec[Spanned]], PErr] =
  parse_pattern_tuple_rest_acc(ts, depth, Nil : Vec[Pattern]);

fn parse_pattern_tuple_rest_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[Pattern]) => Result[Pair[Vec[Pattern], Vec[Spanned]], PErr] =
  match is_rparen(p_cur(ts)) {
    True => match p_expect(ts, True, "`)` to close the tuple pattern") {
      Err(e) => Err(e),
      Ok(ts1) => Ok(Pr(rev_acc(acc, Nil : Vec[Pattern]), ts1))
    },
    False => match parse_pattern(ts, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(p, ts1) =>
        match p_eat(ts1, is_comma(p_cur(ts1))) {
          Some(ts2) => parse_pattern_tuple_rest_acc(ts2, depth, Cons(p, acc)),
          None => match p_expect(ts1, is_rparen(p_cur(ts1)), "`)` to close the tuple pattern") {
            Err(e) => Err(e),
            Ok(ts2) => Ok(Pr(rev_acc(Cons(p, acc), Nil : Vec[Pattern]), ts2))
          }
        }
      }
    }
  };

// ‚îÄ‚îÄ path (mirrors parse_path ‚Äî a dotted path of identifiers) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn parse_path(ts: Vec[Spanned]) => Result[Pair[Path, Vec[Spanned]], PErr] =
  match p_ident(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(first, ts1) => match parse_path_rest(ts1) {
      Err(e) => Err(e),
      Ok(pr2) => match pr2 { Pr(rest, ts2) => Ok(Pr(Pth(Cons(first, rest)), ts2)) }
    } }
  };

fn parse_path_rest(ts: Vec[Spanned]) => Result[Pair[Vec[Bytes], Vec[Spanned]], PErr] =
  parse_path_rest_acc(ts, Nil : Vec[Bytes]);

fn parse_path_rest_acc(ts: Vec[Spanned], acc: Vec[Bytes]) => Result[Pair[Vec[Bytes], Vec[Spanned]], PErr] =
  match p_eat(ts, is_dot(p_cur(ts))) {
    Some(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(seg, ts2) => parse_path_rest_acc(ts2, Cons(seg, acc)) }
    },
    None => Ok(Pr(rev_acc(acc, Nil : Vec[Bytes]), ts))
  };

// ‚îÄ‚îÄ use (mirrors parse_use ‚Äî `use a.b.c` or the glob form `use a.b.*`) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn parse_use_tail(ts: Vec[Spanned]) => Result[Pair[Pair[Vec[Bytes], Bool], Vec[Spanned]], PErr] =
  parse_use_tail_acc(ts, Nil : Vec[Bytes]);

fn parse_use_tail_acc(ts: Vec[Spanned], acc: Vec[Bytes]) => Result[Pair[Pair[Vec[Bytes], Bool], Vec[Spanned]], PErr] =
  match p_eat(ts, is_dot(p_cur(ts))) {
    None => Ok(Pr(Pr(rev_acc(acc, Nil : Vec[Bytes]), False), ts)),
    Some(ts1) => match p_eat(ts1, is_star(p_cur(ts1))) {
      Some(ts2) => Ok(Pr(Pr(rev_acc(acc, Nil : Vec[Bytes]), True), ts2)),
      None => match p_ident(ts1) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(seg, ts2) => parse_use_tail_acc(ts2, Cons(seg, acc)) }
      }
    }
  };

fn parse_use(ts: Vec[Spanned]) => Result[Pair[UsePath, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tuse(p_cur(ts)), "`use`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(first, ts2) => match parse_use_tail(ts2) {
        Err(e) => Err(e),
        Ok(pr2) => match pr2 { Pr(pp, ts3) => match pp { Pr(rest, glob) => Ok(Pr(UP(Pth(Cons(first, rest)), glob), ts3)) } }
      } }
    }
  };

// ‚îÄ‚îÄ small Bytes/Binary{8} helpers needed by the expr grammar ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn bytes_eq_b(a: Bytes, b: Bytes) => Bool =
  match bytes_eq(a, b) { 0b1 => True, _ => False };

fn one8() => Binary{8} = 0b0000_0001;

// ‚îÄ‚îÄ teach_imperative (mirrors Parser::teach_imperative ‚Äî `while`/`loop`/`break`/`continue`/
// `return` juxtaposed with an expression opener is a teaching diagnostic, `Option[PErr]` instead of
// `Result[(), PErr]` since this surface has no unit/`()` type yet ‚Äî M-826's own noted deferral) ‚îÄ‚îÄ‚îÄ
fn is_imperative_word(w: Bytes) => Bool =
  bool_or(bytes_eq_b(w, "while"), bool_or(bytes_eq_b(w, "loop"), bool_or(bytes_eq_b(w, "break"), bool_or(bytes_eq_b(w, "continue"), bytes_eq_b(w, "return")))));

fn is_juxtaposed_opener(t: Tok) => Bool =
  match t {
    Ident(_) => True, BinLit(_) => True, TritLit(_) => True, TInt(_) => True,
    LBrace => True, TIf => True, TLet => True, TMatch => True, TFor => True, TSwap => True,
    _ => False
  };

fn teach_imperative(ts: Vec[Spanned]) => Option[PErr] =
  match p_cur(ts) {
    Ident(word) => match is_imperative_word(word) {
      True => match is_juxtaposed_opener(p_cur(p_bump(ts))) {
        True => Some(PE(p_pos(ts), "not a Mycelium form -- iterate by recursion or a bounded fold (RFC-0007 SS4.8)")),
        False => None
      },
      False => None
    },
    _ => None
  };

// ‚îÄ‚îÄ infix operator table (RFC-0025/M-705) + the canonical word-call desugar ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn infix_op(t: Tok) => Option[Pair[Binary{8}, Bytes]] =
  match t {
    Star => Some(Pr(0b0100_0110, "mul")),
    Slash => Some(Pr(0b0100_0110, "div")),
    Percent => Some(Pr(0b0100_0110, "rem")),
    Plus => Some(Pr(0b0011_1100, "add")),
    Minus => Some(Pr(0b0011_1100, "sub")),
    Shl => Some(Pr(0b0011_0111, "shl")),
    Shr => Some(Pr(0b0011_0111, "shr")),
    Amp => Some(Pr(0b0011_0010, "band")),
    Caret => Some(Pr(0b0010_1000, "xor")),
    Pipe => Some(Pr(0b0001_1110, "bor")),
    LAngle => Some(Pr(0b0001_1001, "lt")),
    RAngle => Some(Pr(0b0001_1001, "gt")),
    EqEq => Some(Pr(0b0001_0100, "eq")),
    BangEq => Some(Pr(0b0001_0100, "ne")),
    AmpAmp => Some(Pr(0b0000_1011, "and")),
    PipePipe => Some(Pr(0b0000_1010, "or")),
    _ => None
  };

fn op_call(word: Bytes, args: Vec[Expr]) => Expr =
  App(Path(Pth(Cons(word, Nil))), args);

// ‚îÄ‚îÄ expression grammar (depth-threaded per FLAG-parse-7; `parse_expr` is the guarded entry) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_expr(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match enter_depth(ts, depth) {
    Err(e) => Err(e),
    Ok(d2) => parse_expr_inner(ts, d2)
  };

fn parse_expr_inner(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match teach_imperative(ts) {
    Some(e) => Err(e),
    None => match p_cur(ts) {
      Hypha => Err(PE(p_pos(ts), "`hypha <expr>` is only valid inside a `colony { ... }` block (RFC-0008 SS4.7 RT7)")),
      Mesh => Err(PE(p_pos(ts), "`mesh` is reserved for the runtime model, not yet active")),
      Graft => Err(PE(p_pos(ts), "`graft` is reserved for the runtime model, not yet active")),
      Cyst => Err(PE(p_pos(ts), "`cyst` is reserved for the runtime model, not yet active")),
      Xloc => Err(PE(p_pos(ts), "`xloc` is reserved for the runtime model, not yet active")),
      Forage => Err(PE(p_pos(ts), "`forage` is reserved for the runtime model, not yet active")),
      Backbone => Err(PE(p_pos(ts), "`backbone` is reserved for the runtime model, not yet active")),
      Tier => Err(PE(p_pos(ts), "`tier` is the DN-58 SSC execution-mode hint -- write `@tier(mode)` before a `fn` declaration")),
      Grow => Err(PE(p_pos(ts), "`grow` is superseded by `derive` (DN-38 SS8.1/M-812)")),
      TLet => parse_let(ts, depth),
      TIf => parse_if(ts, depth),
      TMatch => parse_match(ts, depth),
      TFor => parse_for(ts, depth),
      TSwap => parse_swap(ts, depth),
      With => parse_with_paradigm(ts, depth),
      TWild => parse_wild(ts, depth),
      TSpore => parse_spore(ts, depth),
      TConsume => parse_consume_expr(ts, depth),
      TColony => parse_colony(ts, depth),
      TLambda => parse_lambda(ts, depth),
      TObject => Err(PE(p_pos(ts), "`object` is valid only at item position, not in expression context (DN-53/M-811)")),
      TLower => Err(PE(p_pos(ts), "`lower Name[params] = <rhs>` is a top-level declaration (DN-54/M-812), not an expression")),
      TDerive => Err(PE(p_pos(ts), "`derive Name for T` is a top-level declaration (DN-54/M-812), not an expression")),
      TFuse => parse_fuse_expr(ts, depth),
      TReclaim => parse_reclaim_expr(ts, depth),
      _ => parse_binexpr(ts, depth, 0b0000_0000)
    }
  };

fn parse_binexpr(ts: Vec[Spanned], depth: Binary{32}, min_bp: Binary{8}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match parse_unary(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(lhs, ts1) => parse_binexpr_loop(lhs, ts1, depth, min_bp) }
  };

fn parse_binexpr_loop(lhs: Expr, ts: Vec[Spanned], depth: Binary{32}, min_bp: Binary{8}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match infix_op(p_cur(ts)) {
    None => Ok(Pr(lhs, ts)),
    Some(bpw) => match bpw { Pr(bp, word) =>
      match lt(bp, min_bp) {
        0b1 => Ok(Pr(lhs, ts)),
        _ =>
          let ts1 = p_bump(ts) in
          match parse_binexpr(ts1, depth, add_u(bp, one8())) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(rhs, ts2) => parse_binexpr_loop(op_call(word, Cons(lhs, Cons(rhs, Nil))), ts2, depth, min_bp) }
          }
      }
    }
  };

fn parse_unary(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    Minus => parse_unary_prefix(ts, depth, "neg"),
    Bang => parse_unary_prefix(ts, depth, "not"),
    _ => parse_app(ts, depth)
  };

fn parse_unary_prefix(ts: Vec[Spanned], depth: Binary{32}, word: Bytes) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match enter_depth(ts, depth) {
    Err(e) => Err(e),
    Ok(d2) =>
      let ts1 = p_bump(ts) in
      match parse_unary(ts1, d2) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(operand, ts2) => Ok(Pr(op_call(word, Cons(operand, Nil)), ts2)) }
      }
  };

fn parse_for(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tfor(p_cur(ts)), "`for`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(x, ts2) =>
        match p_expect(ts2, is_in_(p_cur(ts2)), "`in` after the element binder") {
          Err(e) => Err(e),
          Ok(ts3) => match parse_app(ts3, depth) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(xs, ts4) =>
              match p_expect(ts4, is_comma(p_cur(ts4)), "`,` before the accumulator binding") {
                Err(e) => Err(e),
                Ok(ts5) => match p_ident(ts5) {
                  Err(e) => Err(e),
                  Ok(pr3) => match pr3 { Pr(acc, ts6) =>
                    match p_expect(ts6, is_eq(p_cur(ts6)), "`=` and the initial accumulator") {
                      Err(e) => Err(e),
                      Ok(ts7) => match parse_app(ts7, depth) {
                        Err(e) => Err(e),
                        Ok(pr4) => match pr4 { Pr(init, ts8) =>
                          match p_expect(ts8, is_fatarrow(p_cur(ts8)), "`=>` and the fold body") {
                            Err(e) => Err(e),
                            Ok(ts9) => match parse_expr(ts9, depth) {
                              Err(e) => Err(e),
                              Ok(pr5) => match pr5 { Pr(body, ts10) => Ok(Pr(For(x, xs, acc, init, body), ts10)) }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  };

fn parse_let(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tlet(p_cur(ts)), "`let`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(name, ts2) =>
        match p_eat(ts2, is_colon(p_cur(ts2))) {
          Some(ts3) => match parse_type_ref(ts3, depth) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(ty, ts4) => parse_let_tail(name, Some(ty), ts4, depth) }
          },
          None => parse_let_tail(name, None, ts2, depth)
        }
      }
    }
  };

fn parse_let_tail(name: Bytes, ty: Option[TypeRef], ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_eq(p_cur(ts)), "`=` in the let binding") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_expr(ts1, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(bound, ts2) =>
        match p_expect(ts2, is_in_(p_cur(ts2)), "`in` after the let binding") {
          Err(e) => Err(e),
          Ok(ts3) => match parse_expr(ts3, depth) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(body, ts4) => Ok(Pr(Let(name, ty, bound, body), ts4)) }
          }
        }
      }
    }
  };

fn parse_if(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tif(p_cur(ts)), "`if`") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_expr(ts1, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(cond, ts2) =>
        match p_expect(ts2, is_then(p_cur(ts2)), "`then`") {
          Err(e) => Err(e),
          Ok(ts3) => match parse_expr(ts3, depth) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(conseq, ts4) =>
              match p_expect(ts4, is_else_(p_cur(ts4)), "`else`") {
                Err(e) => Err(e),
                Ok(ts5) => match parse_expr(ts5, depth) {
                  Err(e) => Err(e),
                  Ok(pr3) => match pr3 { Pr(alt, ts6) => Ok(Pr(If(cond, conseq, alt), ts6)) }
                }
              }
            }
          }
        }
      }
    }
  };

fn parse_match(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tmatch(p_cur(ts)), "`match`") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_expr(ts1, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(scrutinee, ts2) =>
        match p_expect(ts2, is_lbrace(p_cur(ts2)), "`{` to open the match arms") {
          Err(e) => Err(e),
          Ok(ts3) => match parse_arm_list(ts3, depth) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(arms, ts4) =>
              match p_expect(ts4, is_rbrace(p_cur(ts4)), "`}` to close the match") {
                Err(e) => Err(e),
                Ok(ts5) => Ok(Pr(Match(scrutinee, arms), ts5))
              }
            }
          }
        }
      }
    }
  };

// parse_arm_list: NON-EMPTY, trailing comma before `}` tolerated.
fn parse_arm_list(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[Arm], Vec[Spanned]], PErr] =
  parse_arm_list_acc(ts, depth, Nil : Vec[Arm]);

fn parse_arm_list_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[Arm]) => Result[Pair[Vec[Arm], Vec[Spanned]], PErr] =
  match parse_arm(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(a, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => match is_rbrace(p_cur(ts2)) {
          True => Ok(Pr(rev_acc(Cons(a, acc), Nil : Vec[Arm]), ts2)),
          False => parse_arm_list_acc(ts2, depth, Cons(a, acc))
        },
        None => Ok(Pr(rev_acc(Cons(a, acc), Nil : Vec[Arm]), ts1))
      }
    }
  };

fn parse_arm(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Arm, Vec[Spanned]], PErr] =
  match parse_pattern(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(first, ts1) =>
      match is_pipe(p_cur(ts1)) {
        True => match parse_or_pattern_rest(ts1, depth) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(alts, ts2) => parse_arm_tail(POr(Cons(first, alts)), ts2, depth) }
        },
        False => parse_arm_tail(first, ts1, depth)
      }
    }
  };

fn parse_or_pattern_rest(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[Pattern], Vec[Spanned]], PErr] =
  parse_or_pattern_rest_acc(ts, depth, Nil : Vec[Pattern]);

fn parse_or_pattern_rest_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[Pattern]) => Result[Pair[Vec[Pattern], Vec[Spanned]], PErr] =
  match p_eat(ts, is_pipe(p_cur(ts))) {
    Some(ts1) => match parse_pattern(ts1, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(p, ts2) => parse_or_pattern_rest_acc(ts2, depth, Cons(p, acc)) }
    },
    None => Ok(Pr(rev_acc(acc, Nil : Vec[Pattern]), ts))
  };

fn parse_arm_tail(pattern: Pattern, ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Arm, Vec[Spanned]], PErr] =
  match p_expect(ts, is_fatarrow(p_cur(ts)), "`=>` in the match arm") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_expr(ts1, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(body, ts2) => Ok(Pr(Ar(pattern, body), ts2)) }
    }
  };

fn parse_swap(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tswap(p_cur(ts)), "`swap`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_expect(ts1, is_lparen(p_cur(ts1)), "`(` after `swap`") {
      Err(e) => Err(e),
      Ok(ts2) => match parse_expr(ts2, depth) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(value, ts3) =>
          match p_expect(ts3, is_comma(p_cur(ts3)), "`,` before the `to:` target") {
            Err(e) => Err(e),
            Ok(ts4) => match p_expect(ts4, is_to(p_cur(ts4)), "the `to:` target label") {
              Err(e) => Err(e),
              Ok(ts5) => match p_expect(ts5, is_colon(p_cur(ts5)), "`:` after `to`") {
                Err(e) => Err(e),
                Ok(ts6) => match parse_type_ref(ts6, depth) {
                  Err(e) => Err(e),
                  Ok(pr2) => match pr2 { Pr(target, ts7) =>
                    match p_expect(ts7, is_comma(p_cur(ts7)), "`,` before the `policy:`") {
                      Err(e) => Err(e),
                      Ok(ts8) => match p_expect(ts8, is_policy(p_cur(ts8)), "the `policy:` label") {
                        Err(e) => Err(e),
                        Ok(ts9) => match p_expect(ts9, is_colon(p_cur(ts9)), "`:` after `policy`") {
                          Err(e) => Err(e),
                          Ok(ts10) => match parse_path(ts10) {
                            Err(e) => Err(e),
                            Ok(pr3) => match pr3 { Pr(pol, ts11) =>
                              match p_expect(ts11, is_rparen(p_cur(ts11)), "`)` to close the swap") {
                                Err(e) => Err(e),
                                Ok(ts12) => Ok(Pr(Swap(value, target, pol), ts12))
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  };

fn parse_with_paradigm(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_with(p_cur(ts)), "`with`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_expect(ts1, is_paradigm(p_cur(ts1)), "`paradigm` after `with`") {
      Err(e) => Err(e),
      Ok(ts2) => match parse_paradigm(ts2) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(parad, ts3) =>
          match p_expect(ts3, is_lbrace(p_cur(ts3)), "`{` to open the `with paradigm` block") {
            Err(e) => Err(e),
            Ok(ts4) => match parse_expr(ts4, depth) {
              Err(e) => Err(e),
              Ok(pr2) => match pr2 { Pr(body, ts5) =>
                match p_expect(ts5, is_rbrace(p_cur(ts5)), "`}` to close the `with paradigm` block") {
                  Err(e) => Err(e),
                  Ok(ts6) => Ok(Pr(WithParadigm(parad, body), ts6))
                }
              }
            }
          }
        }
      }
    }
  };

fn parse_wild(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_twild(p_cur(ts)), "`wild`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_expect(ts1, is_lbrace(p_cur(ts1)), "`{` to open the wild block") {
      Err(e) => Err(e),
      Ok(ts2) => match parse_expr(ts2, depth) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(body, ts3) =>
          match p_expect(ts3, is_rbrace(p_cur(ts3)), "`}` to close the wild block") {
            Err(e) => Err(e),
            Ok(ts4) => Ok(Pr(Wild(body), ts4))
          }
        }
      }
    }
  };

fn parse_spore(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tspore(p_cur(ts)), "`spore`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_expect(ts1, is_lparen(p_cur(ts1)), "`(` after `spore`") {
      Err(e) => Err(e),
      Ok(ts2) => match parse_expr(ts2, depth) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(value, ts3) =>
          match p_expect(ts3, is_rparen(p_cur(ts3)), "`)` to close `spore(...)`") {
            Err(e) => Err(e),
            Ok(ts4) => Ok(Pr(Spore(value), ts4))
          }
        }
      }
    }
  };

fn parse_consume_expr(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tconsume(p_cur(ts)), "`consume`") {
    Err(e) => Err(e),
    Ok(ts1) => match enter_depth(ts1, depth) {
      Err(e) => Err(e),
      Ok(d2) => match parse_app(ts1, d2) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(operand, ts2) => Ok(Pr(Consume(operand), ts2)) }
      }
    }
  };

fn parse_colony(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tcolony(p_cur(ts)), "`colony`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_expect(ts1, is_lbrace(p_cur(ts1)), "`{` to open the `colony` block") {
      Err(e) => Err(e),
      Ok(ts2) => match parse_hypha_list(ts2, depth) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(hyphae, ts3) =>
          match p_expect(ts3, is_rbrace(p_cur(ts3)), "`}` to close the `colony`") {
            Err(e) => Err(e),
            Ok(ts4) => Ok(Pr(Colony(hyphae), ts4))
          }
        }
      }
    }
  };

// parse_hypha_list: NON-EMPTY, trailing comma before `}` tolerated.
fn parse_hypha_list(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[Hypha], Vec[Spanned]], PErr] =
  parse_hypha_list_acc(ts, depth, Nil : Vec[Hypha]);

fn parse_hypha_list_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[Hypha]) => Result[Pair[Vec[Hypha], Vec[Spanned]], PErr] =
  match parse_hypha(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(h, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => match is_rbrace(p_cur(ts2)) {
          True => Ok(Pr(rev_acc(Cons(h, acc), Nil : Vec[Hypha]), ts2)),
          False => parse_hypha_list_acc(ts2, depth, Cons(h, acc))
        },
        None => Ok(Pr(rev_acc(Cons(h, acc), Nil : Vec[Hypha]), ts1))
      }
    }
  };

fn parse_hypha(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Hypha, Vec[Spanned]], PErr] =
  match p_eat(ts, is_at(p_cur(ts))) {
    Some(ts1) => match p_expect(ts1, is_forage(p_cur(ts1)), "`forage` keyword after `@`") {
      Err(e) => Err(e),
      Ok(ts2) => match p_expect(ts2, is_lparen(p_cur(ts2)), "`(` to open the `@forage` policy argument") {
        Err(e) => Err(e),
        Ok(ts3) => match parse_expr(ts3, depth) {
          Err(e) => Err(e),
          Ok(pr) => match pr { Pr(pol, ts4) =>
            match p_expect(ts4, is_rparen(p_cur(ts4)), "`)` to close the `@forage` policy argument") {
              Err(e) => Err(e),
              Ok(ts5) => parse_hypha_tail(Some(pol), ts5, depth)
            }
          }
        }
      }
    },
    None => parse_hypha_tail(None, ts, depth)
  };

fn parse_hypha_tail(frg: Option[Expr], ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Hypha, Vec[Spanned]], PErr] =
  match p_expect(ts, is_hypha(p_cur(ts)), "`hypha` to open a concurrent task in the `colony` block") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_app(ts1, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(body, ts2) => Ok(Pr(Hy(frg, body), ts2)) }
    }
  };

fn parse_app(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match parse_primary(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(e0, ts1) => parse_app_tail(e0, ts1, depth) }
  };

fn parse_app_tail(e: Expr, ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_eat(ts, is_lparen(p_cur(ts))) {
    Some(ts1) => match parse_expr_list_until(ts1, depth, is_rparen(p_cur(ts1))) {
      Err(e2) => Err(e2),
      Ok(pr) => match pr { Pr(args, ts2) =>
        match p_expect(ts2, is_rparen(p_cur(ts2)), "`)` to close the call") {
          Err(e2) => Err(e2),
          Ok(ts3) => parse_app_tail(App(e, args), ts3, depth)
        }
      }
    },
    None => match p_eat(ts, is_colon(p_cur(ts))) {
      Some(ts1) => match parse_type_ref(ts1, depth) {
        Err(e2) => Err(e2),
        Ok(pr) => match pr { Pr(ty, ts2) => Ok(Pr(Ascribe(e, ty), ts2)) }
      },
      None => Ok(Pr(e, ts))
    }
  };

fn parse_expr_list_until(ts: Vec[Spanned], depth: Binary{32}, is_end: Bool) => Result[Pair[Vec[Expr], Vec[Spanned]], PErr] =
  match is_end {
    True => Ok(Pr(Nil, ts)),
    False => parse_expr_comma_list(ts, depth)
  };

fn parse_expr_comma_list(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[Expr], Vec[Spanned]], PErr] =
  parse_expr_comma_list_acc(ts, depth, Nil : Vec[Expr]);

fn parse_expr_comma_list_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[Expr]) => Result[Pair[Vec[Expr], Vec[Spanned]], PErr] =
  match parse_expr(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(e, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => parse_expr_comma_list_acc(ts2, depth, Cons(e, acc)),
        None => Ok(Pr(rev_acc(Cons(e, acc), Nil : Vec[Expr]), ts1))
      }
    }
  };

fn parse_primary(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    BinLit(_) => parse_primary_lit(ts, depth),
    TritLit(_) => parse_primary_lit(ts, depth),
    BytesLit(_) => parse_primary_lit(ts, depth),
    StrLit(_) => parse_primary_lit(ts, depth),
    FloatLit(_) => parse_primary_lit(ts, depth),
    TInt(_) => parse_primary_lit(ts, depth),
    LBracket => parse_primary_lit(ts, depth),
    Ident(_) => match parse_path(ts) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(p, ts1) => Ok(Pr(Path(p), ts1)) }
    },
    LParen => parse_primary_paren_tail(p_bump(ts), depth),
    _ => Err(PE(p_pos(ts), "expected an expression"))
  };

fn parse_primary_lit(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match parse_literal(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(l, ts1) => Ok(Pr(Lit(l), ts1)) }
  };

fn parse_primary_paren_tail(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match parse_expr(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(first, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        None => match p_expect(ts1, is_rparen(p_cur(ts1)), "`)` to close the parenthesized expression") {
          Err(e) => Err(e),
          Ok(ts2) => Ok(Pr(first, ts2))
        },
        Some(ts2) => match parse_expr_tuple_rest(ts2, depth) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(rest, ts3) => match rest {
            Nil => Err(PE(p_pos(ts3), "a tuple literal requires arity >= 2 (M-826)")),
            Cons(_, _) => Ok(Pr(TupleLit(Cons(first, rest)), ts3))
          } }
        }
      }
    }
  };

fn parse_expr_tuple_rest(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[Expr], Vec[Spanned]], PErr] =
  parse_expr_tuple_rest_acc(ts, depth, Nil : Vec[Expr]);

fn parse_expr_tuple_rest_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[Expr]) => Result[Pair[Vec[Expr], Vec[Spanned]], PErr] =
  match is_rparen(p_cur(ts)) {
    True => match p_expect(ts, True, "`)` to close the tuple literal") {
      Err(e) => Err(e),
      Ok(ts1) => Ok(Pr(rev_acc(acc, Nil : Vec[Expr]), ts1))
    },
    False => match parse_expr(ts, depth) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(e, ts1) =>
        match p_eat(ts1, is_comma(p_cur(ts1))) {
          Some(ts2) => parse_expr_tuple_rest_acc(ts2, depth, Cons(e, acc)),
          None => match p_expect(ts1, is_rparen(p_cur(ts1)), "`)` to close the tuple literal") {
            Err(e2) => Err(e2),
            Ok(ts2) => Ok(Pr(rev_acc(Cons(e, acc), Nil : Vec[Expr]), ts2))
          }
        }
      }
    }
  };

fn parse_fuse_expr(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tfuse(p_cur(ts)), "`fuse`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_expect(ts1, is_lparen(p_cur(ts1)), "`(` to open `fuse` operands") {
      Err(e) => Err(e),
      Ok(ts2) => match parse_expr(ts2, depth) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(left, ts3) =>
          match p_expect(ts3, is_comma(p_cur(ts3)), "`,` between `fuse` operands") {
            Err(e) => Err(e),
            Ok(ts4) => match parse_expr(ts4, depth) {
              Err(e) => Err(e),
              Ok(pr2) => match pr2 { Pr(right, ts5) =>
                match p_expect(ts5, is_rparen(p_cur(ts5)), "`)` to close `fuse` operands") {
                  Err(e) => Err(e),
                  Ok(ts6) => Ok(Pr(Fuse(left, right), ts6))
                }
              }
            }
          }
        }
      }
    }
  };

fn parse_reclaim_expr(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_treclaim(p_cur(ts)), "`reclaim`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_expect(ts1, is_lparen(p_cur(ts1)), "`(` to open the `reclaim` policy argument") {
      Err(e) => Err(e),
      Ok(ts2) => match parse_expr(ts2, depth) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(pol, ts3) =>
          match p_expect(ts3, is_rparen(p_cur(ts3)), "`)` to close the `reclaim` policy argument") {
            Err(e) => Err(e),
            Ok(ts4) => match p_expect(ts4, is_lbrace(p_cur(ts4)), "`{` to open the `reclaim` supervised body") {
              Err(e) => Err(e),
              Ok(ts5) => match parse_expr(ts5, depth) {
                Err(e) => Err(e),
                Ok(pr2) => match pr2 { Pr(body, ts6) =>
                  match p_expect(ts6, is_rbrace(p_cur(ts6)), "`}` to close the `reclaim` supervised body") {
                    Err(e) => Err(e),
                    Ok(ts7) => Ok(Pr(Reclaim(pol, body), ts7))
                  }
                }
              }
            }
          }
        }
      }
    }
  };

fn parse_lambda(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Expr, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tlambda(p_cur(ts)), "`lambda`") {
    Err(e) => Err(e),
    Ok(ts1) => match bool_or(is_lbracket(p_cur(ts1)), is_lbrace(p_cur(ts1))) {
      True => Err(PE(p_pos(ts1), "type/const parameters on a `lambda` are not yet wired (RFC-0037 D5/M-704)")),
      False => match p_expect(ts1, is_lparen(p_cur(ts1)), "`(` to open the lambda parameter list") {
        Err(e) => Err(e),
        Ok(ts2) => match parse_params_opt(ts2, depth) {
          Err(e) => Err(e),
          Ok(pr) => match pr { Pr(params, ts3) =>
            match p_expect(ts3, is_rparen(p_cur(ts3)), "`)` to close the lambda parameter list") {
              Err(e) => Err(e),
              Ok(ts4) => match p_expect(ts4, is_fatarrow(p_cur(ts4)), "`=>` between the lambda parameter list and its body") {
                Err(e) => Err(e),
                Ok(ts5) => match parse_expr(ts5, depth) {
                  Err(e) => Err(e),
                  Ok(pr2) => match pr2 { Pr(body, ts6) => Ok(Pr(Lambda(params, body), ts6)) }
                }
              }
            }
          }
        }
      }
    }
  };

// ‚îÄ‚îÄ value params / type params / bounds / const params / effects (mirrors parse_params_opt,
// parse_type_params_opt, parse_type_params_bounded, parse_type_param, parse_bound, parse_trait_ref,
// parse_const_params_opt, parse_effects_opt) ‚Äî item-level (depth 0 for any TypeRef parsed here,
// except `parse_params_opt` which is ALSO reused by `parse_lambda` and so threads the ambient depth
// per FLAG-parse-7) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_params_opt(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[Param], Vec[Spanned]], PErr] =
  match is_rparen(p_cur(ts)) {
    True => Ok(Pr(Nil, ts)),
    False => parse_params_comma_list(ts, depth)
  };

fn parse_params_comma_list(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Vec[Param], Vec[Spanned]], PErr] =
  parse_params_comma_list_acc(ts, depth, Nil : Vec[Param]);

fn parse_params_comma_list_acc(ts: Vec[Spanned], depth: Binary{32}, acc: Vec[Param]) => Result[Pair[Vec[Param], Vec[Spanned]], PErr] =
  match parse_one_param(ts, depth) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(p, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => parse_params_comma_list_acc(ts2, depth, Cons(p, acc)),
        None => Ok(Pr(rev_acc(Cons(p, acc), Nil : Vec[Param]), ts1))
      }
    }
  };

fn parse_one_param(ts: Vec[Spanned], depth: Binary{32}) => Result[Pair[Param, Vec[Spanned]], PErr] =
  match p_ident(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(name, ts1) =>
      match p_expect(ts1, is_colon(p_cur(ts1)), "`:` and the parameter type") {
        Err(e) => Err(e),
        Ok(ts2) => match parse_type_ref(ts2, depth) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(ty, ts3) => Ok(Pr(Prm(name, ty), ts3)) }
        }
      }
    }
  };

// parse_type_params_opt: UNBOUNDED names for `type`/`trait` decls; a `: bound` here is an explicit
// deferred-stage refusal (RFC-0019 SS4.1).
fn parse_type_params_opt(ts: Vec[Spanned]) => Result[Pair[Vec[Bytes], Vec[Spanned]], PErr] =
  match p_eat(ts, is_lbracket(p_cur(ts))) {
    None => Ok(Pr(Nil, ts)),
    Some(ts1) => match parse_type_param_name_list(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(names, ts2) =>
        match p_expect(ts2, is_rbracket(p_cur(ts2)), "`]` to close the type parameters") {
          Err(e) => Err(e),
          Ok(ts3) => Ok(Pr(names, ts3))
        }
      }
    }
  };

fn parse_type_param_name_list(ts: Vec[Spanned]) => Result[Pair[Vec[Bytes], Vec[Spanned]], PErr] =
  parse_type_param_name_list_acc(ts, Nil : Vec[Bytes]);

fn parse_type_param_name_list_acc(ts: Vec[Spanned], acc: Vec[Bytes]) => Result[Pair[Vec[Bytes], Vec[Spanned]], PErr] =
  match parse_one_type_param_name(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(n, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => parse_type_param_name_list_acc(ts2, Cons(n, acc)),
        None => Ok(Pr(rev_acc(Cons(n, acc), Nil : Vec[Bytes]), ts1))
      }
    }
  };

fn parse_one_type_param_name(ts: Vec[Spanned]) => Result[Pair[Bytes, Vec[Spanned]], PErr] =
  match p_ident(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(name, ts1) =>
      match is_colon(p_cur(ts1)) {
        True => Err(PE(p_pos(ts1), "bounds on `type`/`trait` type-parameters are deferred in stage-1 (RFC-0019 SS4.1)")),
        False => Ok(Pr(name, ts1))
      }
    }
  };

// parse_type_params_bounded: BOUNDED type-parameters for function signatures (RFC-0019 SS4.1).
fn parse_type_params_bounded(ts: Vec[Spanned]) => Result[Pair[Vec[TypeParam], Vec[Spanned]], PErr] =
  match p_eat(ts, is_lbracket(p_cur(ts))) {
    None => Ok(Pr(Nil, ts)),
    Some(ts1) => match parse_type_param_comma_list(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(ps, ts2) =>
        match p_expect(ts2, is_rbracket(p_cur(ts2)), "`]` to close the type parameters") {
          Err(e) => Err(e),
          Ok(ts3) => Ok(Pr(ps, ts3))
        }
      }
    }
  };

fn parse_type_param_comma_list(ts: Vec[Spanned]) => Result[Pair[Vec[TypeParam], Vec[Spanned]], PErr] =
  parse_type_param_comma_list_acc(ts, Nil : Vec[TypeParam]);

fn parse_type_param_comma_list_acc(ts: Vec[Spanned], acc: Vec[TypeParam]) => Result[Pair[Vec[TypeParam], Vec[Spanned]], PErr] =
  match parse_type_param(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(p, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => parse_type_param_comma_list_acc(ts2, Cons(p, acc)),
        None => Ok(Pr(rev_acc(Cons(p, acc), Nil : Vec[TypeParam]), ts1))
      }
    }
  };

fn parse_type_param(ts: Vec[Spanned]) => Result[Pair[TypeParam, Vec[Spanned]], PErr] =
  match p_ident(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(name, ts1) =>
      match p_eat(ts1, is_colon(p_cur(ts1))) {
        Some(ts2) => match parse_bound(ts2) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(bounds, ts3) => Ok(Pr(TP(name, PkType, bounds), ts3)) }
        },
        None => Ok(Pr(TP(name, PkType, Nil), ts1))
      }
    }
  };

fn parse_bound(ts: Vec[Spanned]) => Result[Pair[Vec[TraitRef], Vec[Spanned]], PErr] =
  parse_bound_acc(ts, Nil : Vec[TraitRef]);

fn parse_bound_acc(ts: Vec[Spanned], acc: Vec[TraitRef]) => Result[Pair[Vec[TraitRef], Vec[Spanned]], PErr] =
  match parse_trait_ref(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(t, ts1) =>
      match p_eat(ts1, is_plus(p_cur(ts1))) {
        Some(ts2) => parse_bound_acc(ts2, Cons(t, acc)),
        None => Ok(Pr(rev_acc(Cons(t, acc), Nil : Vec[TraitRef]), ts1))
      }
    }
  };

fn parse_trait_ref(ts: Vec[Spanned]) => Result[Pair[TraitRef, Vec[Spanned]], PErr] =
  match p_ident(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(name, ts1) => match parse_type_args_opt(ts1, zero32()) {
      Err(e) => Err(e),
      Ok(pr2) => match pr2 { Pr(args, ts2) => Ok(Pr(TRf(name, args), ts2)) }
    } }
  };

// parse_const_params_opt: `{ Ident (, Ident)* }?` ‚Äî width/const parameter DECLARATIONS (distinct
// `{...}` position from a `Binary{N}` width SLOT ‚Äî never ambiguous, only ever right after the fn
// name/[...] and before `(`).
fn parse_const_params_opt(ts: Vec[Spanned]) => Result[Pair[Vec[TypeParam], Vec[Spanned]], PErr] =
  match p_eat(ts, is_lbrace(p_cur(ts))) {
    None => Ok(Pr(Nil, ts)),
    Some(ts1) => match parse_const_param_comma_list(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(ps, ts2) =>
        match p_expect(ts2, is_rbrace(p_cur(ts2)), "`}` to close the const/width parameters") {
          Err(e) => Err(e),
          Ok(ts3) => Ok(Pr(ps, ts3))
        }
      }
    }
  };

fn parse_const_param_comma_list(ts: Vec[Spanned]) => Result[Pair[Vec[TypeParam], Vec[Spanned]], PErr] =
  parse_const_param_comma_list_acc(ts, Nil : Vec[TypeParam]);

fn parse_const_param_comma_list_acc(ts: Vec[Spanned], acc: Vec[TypeParam]) => Result[Pair[Vec[TypeParam], Vec[Spanned]], PErr] =
  match parse_one_const_param(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(p, ts1) =>
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => parse_const_param_comma_list_acc(ts2, Cons(p, acc)),
        None => Ok(Pr(rev_acc(Cons(p, acc), Nil : Vec[TypeParam]), ts1))
      }
    }
  };

fn parse_one_const_param(ts: Vec[Spanned]) => Result[Pair[TypeParam, Vec[Spanned]], PErr] =
  match p_ident(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(name, ts1) =>
      match is_colon(p_cur(ts1)) {
        True => Err(PE(p_pos(ts1), "const/width parameters cannot carry trait bounds in v1 (DN-42 SS7)")),
        False => Ok(Pr(TP(name, PkWidth, Nil), ts1))
      }
    }
  };

// ‚îÄ‚îÄ effects (RFC-0014 SS3.4/SS4.5; FLAG-parse-6 on the KiB/MiB/GiB unit multiplier) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn effect_budget_shift(unit: Bytes) => Option[Binary{64}] =
  match bytes_eq(unit, "KiB") {
    0b1 => Some(0b0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_1010),
    _ => match bytes_eq(unit, "MiB") {
      0b1 => Some(0b0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0001_0100),
      _ => match bytes_eq(unit, "GiB") {
        0b1 => Some(0b0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0000_0001_1110),
        _ => None
      }
    }
  };

fn append_budget(mb: Option[EffectBudget], rest: Vec[EffectBudget]) => Vec[EffectBudget] =
  match mb { None => rest, Some(eb) => Cons(eb, rest) };

// parse_one_effect_entry: `eff (<=N unit?)?` ‚Äî mirrors the loop body of `parse_effects_opt`.
fn parse_one_effect_entry(ts: Vec[Spanned]) => Result[Pair[Pair[Bytes, Option[EffectBudget]], Vec[Spanned]], PErr] =
  match p_ident(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(name, ts1) =>
      match p_eat(ts1, is_lparen(p_cur(ts1))) {
        None => Ok(Pr(Pr(name, None), ts1)),
        Some(ts2) => match p_expect(ts2, is_langle(p_cur(ts2)), "`<=` to open the budget bound") {
          Err(e) => Err(e),
          Ok(ts3) => match p_expect(ts3, is_eq(p_cur(ts3)), "`=` after `<` to form `<=`") {
            Err(e) => Err(e),
            Ok(ts4) => match p_cur(ts4) {
              TInt(digits) => parse_effect_budget_tail(name, decimal_to_u64(digits), p_pos(ts4), p_bump(ts4)),
              _ => Err(PE(p_pos(ts4), "expected a non-negative integer as the effect budget"))
            }
          }
        }
      }
    }
  };

fn parse_effect_budget_tail(name: Bytes, raw: Binary{64}, budget_pos: Pos, ts: Vec[Spanned]) => Result[Pair[Pair[Bytes, Option[EffectBudget]], Vec[Spanned]], PErr] =
  match eq(raw, zero64()) {
    0b1 => Err(PE(budget_pos, "effect budget must be positive (> 0) (RFC-0014 SS4.5 I4)")),
    _ => match p_cur(ts) {
      Ident(unit) => match effect_budget_shift(unit) {
        None => Err(PE(p_pos(ts), "unknown budget unit -- supported units are `KiB`,`MiB`,`GiB`")),
        Some(shift) =>
          let ts1 = p_bump(ts) in
          match p_expect(ts1, is_rparen(p_cur(ts1)), "`)` to close the effect budget bound") {
            Err(e) => Err(e),
            Ok(ts2) => Ok(Pr(Pr(name, Some(EB(name, shl_u(raw, shift)))), ts2))
          }
      },
      _ => match p_expect(ts, is_rparen(p_cur(ts)), "`)` to close the effect budget bound") {
        Err(e) => Err(e),
        Ok(ts1) => Ok(Pr(Pr(name, Some(EB(name, raw))), ts1))
      }
    }
  };

// parse_effect_entries: comma-separated `eff(<=N)?` entries; a trailing comma before `}` is an
// explicit refusal (kept strict ‚Äî G2).
fn parse_effect_entries(ts: Vec[Spanned]) => Result[Pair[Pair[Vec[Bytes], Vec[EffectBudget]], Vec[Spanned]], PErr] =
  parse_effect_entries_acc(ts, Nil : Vec[Bytes], Nil : Vec[EffectBudget]);

fn parse_effect_entries_acc(ts: Vec[Spanned], names: Vec[Bytes], budgets: Vec[EffectBudget]) => Result[Pair[Pair[Vec[Bytes], Vec[EffectBudget]], Vec[Spanned]], PErr] =
  match parse_one_effect_entry(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(entry, ts1) => match entry { Pr(name, mb) =>
      let names2 = Cons(name, names) in
      let budgets2 = append_budget(mb, budgets) in
      match p_eat(ts1, is_comma(p_cur(ts1))) {
        Some(ts2) => match is_rbrace(p_cur(ts2)) {
          True => Err(PE(p_pos(ts2), "trailing comma before `}` in an effect annotation is not allowed (RFC-0014 SS4.5)")),
          False => parse_effect_entries_acc(ts2, names2, budgets2)
        },
        None => Ok(Pr(Pr(rev_acc(names2, Nil : Vec[Bytes]), rev_acc(budgets2, Nil : Vec[EffectBudget])), ts1))
      }
    } }
  };

// parse_effects_opt: `!{ eff(<=N unit?)? (, ...)* }?` ‚Äî absent `!` => pure (empty set).
fn parse_effects_opt(ts: Vec[Spanned]) => Result[Pair[Pair[Vec[Bytes], Vec[EffectBudget]], Vec[Spanned]], PErr] =
  match p_eat(ts, is_bang(p_cur(ts))) {
    None => Ok(Pr(Pr(Nil, Nil), ts)),
    Some(ts1) => match p_expect(ts1, is_lbrace(p_cur(ts1)), "`{` after `!` to open the effect set (RFC-0014 SS3.4)") {
      Err(e) => Err(e),
      Ok(ts2) => match is_rbrace(p_cur(ts2)) {
        True => match p_expect(ts2, True, "`}` to close the effect set") {
          Err(e) => Err(e),
          Ok(ts3) => Ok(Pr(Pr(Nil, Nil), ts3))
        },
        False => match parse_effect_entries(ts2) {
          Err(e) => Err(e),
          Ok(pr) => match pr { Pr(ee, ts3) => match ee { Pr(effects, budgets) =>
            match p_expect(ts3, is_rbrace(p_cur(ts3)), "`}` to close the effect set") {
              Err(e) => Err(e),
              Ok(ts4) => match first_duplicate_bytes(effects) {
                Some(_) => Err(PE(p_pos(ts4), "duplicate effect in the effect annotation (RFC-0014 SS4.5; never a silent dedup)")),
                None => Ok(Pr(Pr(effects, budgets), ts4))
              }
            }
          } }
        }
      }
    }
  };

// ‚îÄ‚îÄ generic triple (needed by parse_object_body's 3-way accumulator) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
type Tr3[A, B, C] = T3(A, B, C);

// append_typeparams: `a ++ b` via double reversal ‚Äî both passes direct-tail (rev_acc), so the
// depth is O(1) regardless of the [...]/{...} parameter-list lengths.
fn append_typeparams(a: Vec[TypeParam], b: Vec[TypeParam]) => Vec[TypeParam] =
  rev_acc(rev_acc(a, Nil : Vec[TypeParam]), b);

// ‚îÄ‚îÄ fn signature tail + decl forms (mirrors parse_sig_tail/expect_return_arrow/parse_fn_sig/
// parse_fn_decl/parse_tier_fn_decl) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn expect_return_arrow(ts: Vec[Spanned]) => Result[Vec[Spanned], PErr] =
  match is_arrow(p_cur(ts)) {
    True => Err(PE(p_pos(ts), "the arrow is now `=>`, not `->` (RFC-0037 D4)")),
    False => p_expect(ts, is_fatarrow(p_cur(ts)), "`=>` and a result type")
  };

fn parse_sig_tail(ts: Vec[Spanned]) => Result[Pair[FnSig, Vec[Spanned]], PErr] =
  match p_ident(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(name, ts1) =>
      match parse_type_params_bounded(ts1) {
        Err(e) => Err(e),
        Ok(pr2) => match pr2 { Pr(tp_bounded, ts2) =>
          match parse_const_params_opt(ts2) {
            Err(e) => Err(e),
            Ok(pr3) => match pr3 { Pr(tp_const, ts3) =>
              let raw_params = append_typeparams(tp_bounded, tp_const) in
              match first_duplicate_bytes(typeparam_names(raw_params)) {
                Some(_) => Err(PE(p_pos(ts3), "a parameter name is declared twice across the [...]/{...} lists (RFC-0037 D2)")),
                None => match p_expect(ts3, is_lparen(p_cur(ts3)), "`(` to open the parameter list") {
                  Err(e) => Err(e),
                  Ok(ts4) => match parse_params_opt(ts4, zero32()) {
                    Err(e) => Err(e),
                    Ok(pr4) => match pr4 { Pr(value_params, ts5) =>
                      match p_expect(ts5, is_rparen(p_cur(ts5)), "`)` to close the parameter list") {
                        Err(e) => Err(e),
                        Ok(ts6) => match expect_return_arrow(ts6) {
                          Err(e) => Err(e),
                          Ok(ts7) => match parse_type_ref(ts7, zero32()) {
                            Err(e) => Err(e),
                            Ok(pr5) => match pr5 { Pr(ret, ts8) =>
                              match parse_effects_opt(ts8) {
                                Err(e) => Err(e),
                                Ok(pr6) => match pr6 { Pr(ee, ts9) => match ee { Pr(effects, effect_budgets) =>
                                  match classify_params(raw_params, value_params, ret) {
                                    Err(e) => Err(e),
                                    Ok(params) => Ok(Pr(FS(name, params, value_params, ret, effects, effect_budgets), ts9))
                                  }
                                } }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  };

fn parse_fn_sig(ts: Vec[Spanned]) => Result[Pair[FnSig, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tfn(p_cur(ts)), "`fn` in the trait body") {
    Err(e) => Err(e),
    Ok(ts1) => parse_sig_tail(ts1)
  };

// parse_fn_decl: `thaw? fn ...` with the caller-supplied cross-nodule visibility `vis` (M-662).
fn parse_fn_decl(vis: Vis, ts: Vec[Spanned]) => Result[Pair[FnDecl, Vec[Spanned]], PErr] =
  match p_eat(ts, is_thaw(p_cur(ts))) {
    Some(ts1) => parse_fn_decl_tail(vis, True, ts1),
    None => parse_fn_decl_tail(vis, False, ts)
  };

fn parse_fn_decl_tail(vis: Vis, thw: Bool, ts: Vec[Spanned]) => Result[Pair[FnDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tfn(p_cur(ts)), "`fn`") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_sig_tail(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(sig, ts2) =>
        match p_expect(ts2, is_eq(p_cur(ts2)), "`=` before the function body") {
          Err(e) => Err(e),
          Ok(ts3) => match parse_expr(ts3, zero32()) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(body, ts4) => Ok(Pr(FD(vis, thw, None, sig, body), ts4)) }
          }
        }
      }
    }
  };

// parse_tier_fn_decl: `@tier(compiled|interpreted) thaw? fn ...` (DN-58 SSC/M-667).
fn parse_tier_fn_decl(vis: Vis, ts: Vec[Spanned]) => Result[Pair[FnDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_at(p_cur(ts)), "`@` before the `tier` attribute") {
    Err(e) => Err(e),
    Ok(ts1) => match p_expect(ts1, is_tier(p_cur(ts1)), "`tier` keyword after `@`") {
      Err(e) => Err(e),
      Ok(ts2) => match p_expect(ts2, is_lparen(p_cur(ts2)), "`(` to open the `@tier` mode argument") {
        Err(e) => Err(e),
        Ok(ts3) => match p_cur(ts3) {
          Ident(s) => match bytes_eq_b(s, "compiled") {
            True => parse_tier_fn_decl_tail(vis, Compiled, p_bump(ts3)),
            False => match bytes_eq_b(s, "interpreted") {
              True => parse_tier_fn_decl_tail(vis, Interpreted, p_bump(ts3)),
              False => Err(PE(p_pos(ts3), "`@tier` mode must be `compiled` or `interpreted` (DN-58 SSC)"))
            }
          },
          _ => Err(PE(p_pos(ts3), "`@tier` mode must be `compiled` or `interpreted` (DN-58 SSC)"))
        }
      }
    }
  };

fn parse_tier_fn_decl_tail(vis: Vis, mode: ExecutionMode, ts: Vec[Spanned]) => Result[Pair[FnDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_rparen(p_cur(ts)), "`)` to close the `@tier` mode argument") {
    Err(e) => Err(e),
    Ok(ts1) => match p_eat(ts1, is_thaw(p_cur(ts1))) {
      Some(ts2) => parse_tier_fn_decl_tail2(vis, mode, True, ts2),
      None => parse_tier_fn_decl_tail2(vis, mode, False, ts1)
    }
  };

fn parse_tier_fn_decl_tail2(vis: Vis, mode: ExecutionMode, thw: Bool, ts: Vec[Spanned]) => Result[Pair[FnDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tfn(p_cur(ts)), "`fn` after `@tier(mode)`") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_sig_tail(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(sig, ts2) =>
        match p_expect(ts2, is_eq(p_cur(ts2)), "`=` before the function body") {
          Err(e) => Err(e),
          Ok(ts3) => match parse_expr(ts3, zero32()) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(body, ts4) => Ok(Pr(FD(vis, thw, Some(mode), sig, body), ts4)) }
          }
        }
      }
    }
  };

// ‚îÄ‚îÄ ctor / type decl / trait decl ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

// M-1027 / DN-104 ¬ß2: an optional leading `priv` seals the constructor (exports the type NAME but
// withholds cross-nodule construction). Eat it first, then parse the name+fields with the flag.
fn parse_ctor(ts: Vec[Spanned]) => Result[Pair[Ctor, Vec[Spanned]], PErr] =
  match p_eat(ts, is_tpriv(p_cur(ts))) {
    Some(ts0) => parse_ctor_named(ts0, True),
    None => parse_ctor_named(ts, False)
  };

fn parse_ctor_named(ts: Vec[Spanned], sealed: Bool) => Result[Pair[Ctor, Vec[Spanned]], PErr] =
  match p_ident(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(name, ts1) =>
      match p_eat(ts1, is_lparen(p_cur(ts1))) {
        None => Ok(Pr(Ctr(name, Nil, sealed), ts1)),
        Some(ts2) => match parse_type_ref_comma_list(ts2, zero32()) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(fields, ts3) =>
            match p_expect(ts3, is_rparen(p_cur(ts3)), "`)` to close the constructor fields") {
              Err(e) => Err(e),
              Ok(ts4) => Ok(Pr(Ctr(name, fields, sealed), ts4))
            }
          }
        }
      }
    }
  };

fn parse_ctor_pipe_list(ts: Vec[Spanned]) => Result[Pair[Vec[Ctor], Vec[Spanned]], PErr] =
  parse_ctor_pipe_list_acc(ts, Nil : Vec[Ctor]);

fn parse_ctor_pipe_list_acc(ts: Vec[Spanned], acc: Vec[Ctor]) => Result[Pair[Vec[Ctor], Vec[Spanned]], PErr] =
  match parse_ctor(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(c, ts1) =>
      match p_eat(ts1, is_pipe(p_cur(ts1))) {
        Some(ts2) => parse_ctor_pipe_list_acc(ts2, Cons(c, acc)),
        None => Ok(Pr(rev_acc(Cons(c, acc), Nil : Vec[Ctor]), ts1))
      }
    }
  };

fn parse_type_decl(vis: Vis, ts: Vec[Spanned]) => Result[Pair[TypeDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_ttype(p_cur(ts)), "`type`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(name, ts2) =>
        match parse_type_params_opt(ts2) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(params, ts3) =>
            match p_expect(ts3, is_eq(p_cur(ts3)), "`=` before the constructors") {
              Err(e) => Err(e),
              Ok(ts4) => match parse_ctor_pipe_list(ts4) {
                Err(e) => Err(e),
                Ok(pr3) => match pr3 { Pr(ctors, ts5) => Ok(Pr(TD(vis, name, params, ctors), ts5)) }
              }
            }
          }
        }
      }
    }
  };

fn parse_trait_sig_list(ts: Vec[Spanned]) => Result[Pair[Vec[FnSig], Vec[Spanned]], PErr] =
  parse_trait_sig_list_acc(ts, Nil : Vec[FnSig]);

fn parse_trait_sig_list_acc(ts: Vec[Spanned], acc: Vec[FnSig]) => Result[Pair[Vec[FnSig], Vec[Spanned]], PErr] =
  match is_rbrace(p_cur(ts)) {
    True => Ok(Pr(rev_acc(acc, Nil : Vec[FnSig]), ts)),
    False => match parse_fn_sig(ts) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(sig, ts1) =>
        match p_expect(ts1, is_semi(p_cur(ts1)), "`;` to terminate this trait signature") {
          Err(e) => Err(e),
          Ok(ts2) => parse_trait_sig_list_acc(ts2, Cons(sig, acc))
        }
      }
    }
  };

fn parse_trait_decl(vis: Vis, ts: Vec[Spanned]) => Result[Pair[TraitDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_ttrait(p_cur(ts)), "`trait`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(name, ts2) =>
        match parse_type_params_opt(ts2) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(params, ts3) =>
            match p_expect(ts3, is_lbrace(p_cur(ts3)), "`{` to open the trait body") {
              Err(e) => Err(e),
              Ok(ts4) => match parse_trait_sig_list(ts4) {
                Err(e) => Err(e),
                Ok(pr3) => match pr3 { Pr(sigs, ts5) =>
                  match p_expect(ts5, is_rbrace(p_cur(ts5)), "`}` to close the trait body") {
                    Err(e) => Err(e),
                    Ok(ts6) => Ok(Pr(TrD(vis, name, params, sigs), ts6))
                  }
                }
              }
            }
          }
        }
      }
    }
  };

// ‚îÄ‚îÄ impl (trait-instance + inherent; M-664) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_impl_method_list(ts: Vec[Spanned]) => Result[Pair[Vec[FnDecl], Vec[Spanned]], PErr] =
  parse_impl_method_list_acc(ts, Nil : Vec[FnDecl]);

fn parse_impl_method_list_acc(ts: Vec[Spanned], acc: Vec[FnDecl]) => Result[Pair[Vec[FnDecl], Vec[Spanned]], PErr] =
  match is_rbrace(p_cur(ts)) {
    True => Ok(Pr(rev_acc(acc, Nil : Vec[FnDecl]), ts)),
    False => match is_tpub(p_cur(ts)) {
      True => Err(PE(p_pos(ts), "an `impl` method is not `pub`-gated (M-662)")),
      False => match parse_fn_decl(Private, ts) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(m, ts1) =>
          match p_expect(ts1, is_semi(p_cur(ts1)), "`;` to terminate this impl method") {
            Err(e) => Err(e),
            Ok(ts2) => parse_impl_method_list_acc(ts2, Cons(m, acc))
          }
        }
      }
    }
  };

fn parse_impl_body(ts: Vec[Spanned]) => Result[Pair[Vec[FnDecl], Vec[Spanned]], PErr] =
  match p_expect(ts, is_lbrace(p_cur(ts)), "`{` to open the `impl` body") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_impl_method_list(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(methods, ts2) =>
        match p_expect(ts2, is_rbrace(p_cur(ts2)), "`}` to close the `impl` body") {
          Err(e) => Err(e),
          Ok(ts3) => Ok(Pr(methods, ts3))
        }
      }
    }
  };

fn parse_impl_decl(ts: Vec[Spanned]) => Result[Pair[ImplDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_timpl(p_cur(ts)), "`impl`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(trait_name, ts2) =>
        match parse_type_args_opt(ts2, zero32()) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(trait_args, ts3) =>
            match p_expect(ts3, is_tfor(p_cur(ts3)), "`for` after the trait in an `impl`") {
              Err(e) => Err(e),
              Ok(ts4) => match parse_type_ref(ts4, zero32()) {
                Err(e) => Err(e),
                Ok(pr3) => match pr3 { Pr(for_ty, ts5) => match parse_impl_body(ts5) {
                  Err(e) => Err(e),
                  Ok(pr4) => match pr4 { Pr(methods, ts6) => Ok(Pr(ImD(trait_name, trait_args, for_ty, methods), ts6)) }
                } }
              }
            }
          }
        }
      }
    }
  };

// parse_impl_item: the top-level `impl` dispatcher (M-664) ‚Äî disambiguates the trait-instance form
// (`impl Trait for T { ... }`) from the inherent-method form (`impl T { ... }`) by parsing the head
// base type once and branching on the follower (`for` vs `{`).
// DN-103 / M-1026 / ENB-3: an impl-level type-parameter slot (`impl[T] Foo[T] { ‚Ä¶ }`) is parsed
// immediately after `impl`, before the head (unambiguous ‚Äî no base type begins with `[`). Nil for the
// plain M-664 block. The slot rides `parse_impl_item_tail` and lands on the inherent `IID`; a non-empty
// slot on a trait instance is a never-silent refusal (generic trait-instance coherence deferred).
fn parse_impl_item(ts: Vec[Spanned]) => Result[Pair[Item, Vec[Spanned]], PErr] =
  match p_expect(ts, is_timpl(p_cur(ts)), "`impl`") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_type_params_opt(ts1) {
      Err(e) => Err(e),
      Ok(pr0) => match pr0 { Pr(iparams, ts2) => match parse_base_type(ts2, zero32()) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(head, ts3) => parse_impl_item_tail(iparams, head, ts3) }
      } }
    }
  };

fn parse_impl_item_tail(iparams: Vec[Bytes], head: BaseType, ts: Vec[Spanned]) => Result[Pair[Item, Vec[Spanned]], PErr] =
  match is_tfor(p_cur(ts)) {
    True => match is_nil_bytes_list(iparams) {
      False => Err(PE(p_pos(ts), "impl-level type parameters on a trait instance (`impl[T] Trait for ...`) are deferred -- generic trait-instance coherence is not yet supported (DN-103 SS3 / RFC-0019 SS4.5); use a generic inherent block (`impl[T] Foo[T] { ... }`) or impls-as-functions meanwhile (never silent -- G2)")),
      True => match head {
        Named(name, args) =>
          let ts1 = p_bump(ts) in
          match parse_type_ref(ts1, zero32()) {
            Err(e) => Err(e),
            Ok(pr) => match pr { Pr(for_ty, ts2) => match parse_impl_body(ts2) {
              Err(e) => Err(e),
              Ok(pr2) => match pr2 { Pr(methods, ts3) => Ok(Pr(Impl(ImD(name, args, for_ty, methods)), ts3)) }
            } }
          },
        _ => Err(PE(p_pos(ts), "the item before `for` in a trait `impl ... for ...` must be a trait name (RFC-0019 SS4.1)"))
      }
    },
    False => match is_lbrace(p_cur(ts)) {
      True => match parse_impl_body(ts) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(methods, ts1) => Ok(Pr(InherentImpl(IID(iparams, typeref_unguaranteed(head), methods)), ts1)) }
      },
      False => Err(PE(p_pos(ts), "expected `for` (a trait instance) or `{` (an inherent method block) after the type in an `impl`"))
    }
  };

// is_nil_bytes_list: True iff the impl-level type-parameter slot is empty (the plain M-664 block).
fn is_nil_bytes_list(xs: Vec[Bytes]) => Bool =
  match xs { Nil => True, Cons(_, _) => False };

// ‚îÄ‚îÄ object composition (DN-53/M-811) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_object_body(ts: Vec[Spanned]) => Result[Pair[Tr3[Vec[ViaDecl], Vec[ImplDecl], Vec[FnDecl]], Vec[Spanned]], PErr] =
  parse_object_body_acc(ts, Nil : Vec[ViaDecl], Nil : Vec[ImplDecl], Nil : Vec[FnDecl]);

// parse_object_body_acc: the accumulator dispatcher ‚Äî each member arm parses ONE member (incl. its
// `;` terminator) then direct-tail-recurses with the member prepended; the three lists are
// rev_acc'd back to source order once at the `}`.
fn parse_object_body_acc(ts: Vec[Spanned], vds: Vec[ViaDecl], ims: Vec[ImplDecl], fs: Vec[FnDecl]) => Result[Pair[Tr3[Vec[ViaDecl], Vec[ImplDecl], Vec[FnDecl]], Vec[Spanned]], PErr] =
  match is_rbrace(p_cur(ts)) {
    True => Ok(Pr(T3(rev_acc(vds, Nil : Vec[ViaDecl]), rev_acc(ims, Nil : Vec[ImplDecl]), rev_acc(fs, Nil : Vec[FnDecl])), ts)),
    False => match p_cur(ts) {
      Via => match parse_one_object_via(p_bump(ts)) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(vd, ts1) => parse_object_body_acc(ts1, Cons(vd, vds), ims, fs) }
      },
      TImpl => match parse_one_object_impl(ts) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(im, ts1) => parse_object_body_acc(ts1, vds, Cons(im, ims), fs) }
      },
      TFn => match parse_one_object_fn(ts) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(f, ts1) => parse_object_body_acc(ts1, vds, ims, Cons(f, fs)) }
      },
      Thaw => match parse_one_object_fn(ts) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(f, ts1) => parse_object_body_acc(ts1, vds, ims, Cons(f, fs)) }
      },
      TPub => Err(PE(p_pos(ts), "`pub` inside an `object` body is not valid (DN-53 SSA.2.1)")),
      _ => Err(PE(p_pos(ts), "unexpected token inside `object` body -- expected `via`,`impl`,`fn`,`thaw`, or `}`"))
    }
  };

// parse_one_object_via: ONE `via N : Trait[args]?;` clause ‚Äî `ts` positioned right after `via`.
fn parse_one_object_via(ts: Vec[Spanned]) => Result[Pair[ViaDecl, Vec[Spanned]], PErr] =
  match p_cur(ts) {
    TInt(digits) =>
      let field_idx = decimal_to_u32(digits) in
      let ts1 = p_bump(ts) in
      match p_expect(ts1, is_colon(p_cur(ts1)), "`:` after the field index in a `via` clause") {
        Err(e) => Err(e),
        Ok(ts2) => match p_ident(ts2) {
          Err(e) => Err(e),
          Ok(pr) => match pr { Pr(trait_name, ts3) => match parse_type_args_opt(ts3, zero32()) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(trait_args, ts4) =>
              match p_expect(ts4, is_semi(p_cur(ts4)), "`;` to terminate this `via` delegation clause") {
                Err(e) => Err(e),
                Ok(ts5) => Ok(Pr(VD(field_idx, trait_name, trait_args), ts5))
              }
            }
          } }
        }
      },
    _ => Err(PE(p_pos(ts), "expected a non-negative decimal field index after `via` (DN-53 SSA.3.2)"))
  };

// parse_one_object_impl: ONE `impl Trait for T { ... };` member.
fn parse_one_object_impl(ts: Vec[Spanned]) => Result[Pair[ImplDecl, Vec[Spanned]], PErr] =
  match parse_impl_decl(ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(idecl, ts1) =>
      match p_expect(ts1, is_semi(p_cur(ts1)), "`;` to terminate this object `impl` member") {
        Err(e) => Err(e),
        Ok(ts2) => Ok(Pr(idecl, ts2))
      }
    }
  };

// parse_one_object_fn: ONE `fn ...;` / `thaw fn ...;` member.
fn parse_one_object_fn(ts: Vec[Spanned]) => Result[Pair[FnDecl, Vec[Spanned]], PErr] =
  match parse_fn_decl(Private, ts) {
    Err(e) => Err(e),
    Ok(pr) => match pr { Pr(fdecl, ts1) =>
      match p_expect(ts1, is_semi(p_cur(ts1)), "`;` to terminate this object `fn` member") {
        Err(e) => Err(e),
        Ok(ts2) => Ok(Pr(fdecl, ts2))
      }
    }
  };

fn parse_object_decl(vis: Vis, ts: Vec[Spanned]) => Result[Pair[ObjectDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tobject(p_cur(ts)), "`object`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(name, ts2) =>
        match parse_type_params_opt(ts2) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(params, ts3) =>
            match p_expect(ts3, is_lbrace(p_cur(ts3)), "`{` to open the `object` body") {
              Err(e) => Err(e),
              Ok(ts4) => match is_rbrace(p_cur(ts4)) {
                True => Err(PE(p_pos(ts4), "an `object` body must have at least one constructor clause (DN-53 SSA.2.1)")),
                False => match parse_ctor(ts4) {
                  Err(e) => Err(e),
                  Ok(pr3) => match pr3 { Pr(ctor, ts5) =>
                    match p_expect(ts5, is_semi(p_cur(ts5)), "`;` after the constructor clause in an `object` body") {
                      Err(e) => Err(e),
                      Ok(ts6) => match parse_object_body(ts6) {
                        Err(e) => Err(e),
                        Ok(pr4) => match pr4 { Pr(rest, ts7) => match rest { T3(via_decls, impls, fns) =>
                          match p_expect(ts7, is_rbrace(p_cur(ts7)), "`}` to close the `object` body") {
                            Err(e) => Err(e),
                            Ok(ts8) => Ok(Pr(OD(vis, name, params, ctor, via_decls, impls, fns), ts8))
                          }
                        } }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  };

// ‚îÄ‚îÄ lower / derive (DN-54/M-812) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_lower_item_rhs(ts: Vec[Spanned]) => Result[Pair[ImplDecl, Vec[Spanned]], PErr] =
  parse_impl_decl(ts);

fn parse_lower_decl(ts: Vec[Spanned]) => Result[Pair[LowerDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tlower(p_cur(ts)), "`lower`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(name, ts2) =>
        match parse_type_params_opt(ts2) {
          Err(e) => Err(e),
          Ok(pr2) => match pr2 { Pr(params, ts3) =>
            match p_expect(ts3, is_eq(p_cur(ts3)), "`=` after the rule name/params in a `lower` declaration") {
              Err(e) => Err(e),
              Ok(ts4) => match is_timpl(p_cur(ts4)) {
                True => match parse_lower_item_rhs(ts4) {
                  Err(e) => Err(e),
                  Ok(pr3) => match pr3 { Pr(idecl, ts5) => Ok(Pr(LD(name, params, LRImpl(idecl)), ts5)) }
                },
                False => match parse_expr(ts4, zero32()) {
                  Err(e) => Err(e),
                  Ok(pr3) => match pr3 { Pr(e, ts5) => Ok(Pr(LD(name, params, LRExpr(e)), ts5)) }
                }
              }
            }
          }
        }
      }
    }
  };

fn parse_derive_decl(ts: Vec[Spanned]) => Result[Pair[DeriveDecl, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tderive(p_cur(ts)), "`derive`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_ident(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(name, ts2) =>
        match p_expect(ts2, is_tfor(p_cur(ts2)), "`for` after the rule name in a `derive` application") {
          Err(e) => Err(e),
          Ok(ts3) => match parse_type_ref(ts3, zero32()) {
            Err(e) => Err(e),
            Ok(pr2) => match pr2 { Pr(for_ty, ts4) => Ok(Pr(DD(name, for_ty), ts4)) }
          }
        }
      }
    }
  };

// ‚îÄ‚îÄ top-level items (mirrors parse_item/parse_pub_item) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_item(ts: Vec[Spanned]) => Result[Pair[Item, Vec[Spanned]], PErr] =
  match is_tpub(p_cur(ts)) {
    True => parse_pub_item(ts),
    False => match is_at(p_cur(ts)) {
      True => match parse_tier_fn_decl(Private, ts) {
        Err(e) => Err(e),
        Ok(pr) => match pr { Pr(f, ts1) => Ok(Pr(Fn(f), ts1)) }
      },
      False => match p_cur(ts) {
        TUse => match parse_use(ts) { Err(e) => Err(e), Ok(pr) => match pr { Pr(u, ts1) => Ok(Pr(Use(u), ts1)) } },
        TDefault =>
          let ts1 = p_bump(ts) in
          match p_expect(ts1, is_paradigm(p_cur(ts1)), "`paradigm` after `default` (RFC-0012 SS4.2)") {
            Err(e) => Err(e),
            Ok(ts2) => match parse_paradigm(ts2) { Err(e) => Err(e), Ok(pr) => match pr { Pr(p, ts3) => Ok(Pr(Default(p), ts3)) } }
          },
        TType => match parse_type_decl(Private, ts) { Err(e) => Err(e), Ok(pr) => match pr { Pr(t, ts1) => Ok(Pr(Type(t), ts1)) } },
        TTrait => match parse_trait_decl(Private, ts) { Err(e) => Err(e), Ok(pr) => match pr { Pr(t, ts1) => Ok(Pr(Trait(t), ts1)) } },
        TImpl => parse_impl_item(ts),
        TFn => match parse_fn_decl(Private, ts) { Err(e) => Err(e), Ok(pr) => match pr { Pr(f, ts1) => Ok(Pr(Fn(f), ts1)) } },
        Thaw => match parse_fn_decl(Private, ts) { Err(e) => Err(e), Ok(pr) => match pr { Pr(f, ts1) => Ok(Pr(Fn(f), ts1)) } },
        Matured => Err(PE(p_pos(ts), "maturation is declared per nodule/phylum in the header (RFC-0017 SS4.1)")),
        TColony => Err(PE(p_pos(ts), "`colony { ... }` is an expression, not a top-level item (RFC-0008 SS4.7)")),
        Hypha => Err(PE(p_pos(ts), "`hypha <expr>` is only valid inside a `colony` block (RFC-0008 SS4.7 RT7)")),
        Mesh => Err(PE(p_pos(ts), "`mesh` is reserved for the runtime model, not yet active")),
        Graft => Err(PE(p_pos(ts), "`graft` is reserved for the runtime model, not yet active")),
        Cyst => Err(PE(p_pos(ts), "`cyst` is reserved for the runtime model, not yet active")),
        Xloc => Err(PE(p_pos(ts), "`xloc` is reserved for the runtime model, not yet active")),
        Forage => Err(PE(p_pos(ts), "`forage` is reserved for the runtime model, not yet active")),
        Backbone => Err(PE(p_pos(ts), "`backbone` is reserved for the runtime model, not yet active")),
        Tier => Err(PE(p_pos(ts), "`tier` is the DN-58 SSC execution-mode hint -- write `@tier(mode)` before `fn`")),
        TFuse => Err(PE(p_pos(ts), "`fuse(a, b)` is an expression (DN-58 SSA), not a top-level item")),
        TReclaim => Err(PE(p_pos(ts), "`reclaim(policy) { body }` is an expression (DN-58 SSB), not a top-level item")),
        TConsume => Err(PE(p_pos(ts), "`consume <expr>` is an expression (DN-03 SS1/M-664), not a top-level item")),
        Grow => Err(PE(p_pos(ts), "`grow` is superseded by `derive` (DN-38 SS8.1/M-812)")),
        Phylum => Err(PE(p_pos(ts), "a `phylum <path>` header must come before the first `nodule` block (RFC-0006 SS4.3)")),
        TLambda => Err(PE(p_pos(ts), "`lambda(...) => ...` is an expression (RFC-0037 D5), not a top-level item")),
        TObject => match parse_object_decl(Private, ts) { Err(e) => Err(e), Ok(pr) => match pr { Pr(o, ts1) => Ok(Pr(Object(o), ts1)) } },
        TLower => match parse_lower_decl(ts) { Err(e) => Err(e), Ok(pr) => match pr { Pr(l, ts1) => Ok(Pr(Lower(l), ts1)) } },
        TDerive => match parse_derive_decl(ts) { Err(e) => Err(e), Ok(pr) => match pr { Pr(d, ts1) => Ok(Pr(Derive(d), ts1)) } },
        _ => Err(PE(p_pos(ts), "expected a top-level item (`use`,`pub`,`default paradigm`,`type`,`trait`,`impl`,`fn`,`thaw fn`,`lower`, or `derive`)"))
      }
    }
  };

fn parse_pub_item(ts: Vec[Spanned]) => Result[Pair[Item, Vec[Spanned]], PErr] =
  match p_expect(ts, is_tpub(p_cur(ts)), "`pub`") {
    Err(e) => Err(e),
    Ok(ts1) => match p_cur(ts1) {
      TType => match parse_type_decl(Pub, ts1) { Err(e) => Err(e), Ok(pr) => match pr { Pr(t, ts2) => Ok(Pr(Type(t), ts2)) } },
      TTrait => match parse_trait_decl(Pub, ts1) { Err(e) => Err(e), Ok(pr) => match pr { Pr(t, ts2) => Ok(Pr(Trait(t), ts2)) } },
      TFn => match parse_fn_decl(Pub, ts1) { Err(e) => Err(e), Ok(pr) => match pr { Pr(f, ts2) => Ok(Pr(Fn(f), ts2)) } },
      Thaw => match parse_fn_decl(Pub, ts1) { Err(e) => Err(e), Ok(pr) => match pr { Pr(f, ts2) => Ok(Pr(Fn(f), ts2)) } },
      At => match parse_tier_fn_decl(Pub, ts1) { Err(e) => Err(e), Ok(pr) => match pr { Pr(f, ts2) => Ok(Pr(Fn(f), ts2)) } },
      TObject => match parse_object_decl(Pub, ts1) { Err(e) => Err(e), Ok(pr) => match pr { Pr(o, ts2) => Ok(Pr(Object(o), ts2)) } },
      TUse => Err(PE(p_pos(ts1), "`pub use` is not a form (M-662) -- a `use` imports, it does not re-export")),
      TImpl => Err(PE(p_pos(ts1), "`pub impl` is not a form -- an `impl` is not `pub`-gated (M-662/RFC-0019 SS4.5)")),
      TDefault => Err(PE(p_pos(ts1), "`pub default` is not a form -- `default paradigm` is nodule-scope ambient state (M-662)")),
      _ => Err(PE(p_pos(ts1), "`pub` must be followed by `fn`,`trait`,`type`,`object`, or `thaw fn` (M-662)"))
    }
  };

// ‚îÄ‚îÄ nodule / phylum (mirrors parse_nodule/parse_phylum's INTERNAL production ‚Äî the public
// SOURCE-STRING entry points are `parse`/`parse_phylum` below; `parse_phylum` the entry and
// `parse_phylum_prog` the grammar production are DIFFERENT names since Mycelium's flat function
// namespace has no Rust-style free-fn-vs-method separation) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse_nodule_items(ts: Vec[Spanned]) => Result[Pair[Vec[Item], Vec[Spanned]], PErr] =
  parse_nodule_items_acc(ts, Nil : Vec[Item]);

fn parse_nodule_items_acc(ts: Vec[Spanned], acc: Vec[Item]) => Result[Pair[Vec[Item], Vec[Spanned]], PErr] =
  match bool_or(is_eof(p_cur(ts)), is_nodule(p_cur(ts))) {
    True => Ok(Pr(rev_acc(acc, Nil : Vec[Item]), ts)),
    False => match parse_item(ts) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(item, ts1) =>
        match p_expect(ts1, is_semi(p_cur(ts1)), "`;` to terminate this item (DN-57 SS3)") {
          Err(e) => Err(e),
          Ok(ts2) => parse_nodule_items_acc(ts2, Cons(item, acc))
        }
      }
    }
  };

fn parse_nodule_tail(path: Path, std_sys: Bool, ts: Vec[Spanned]) => Result[Pair[Nodule, Vec[Spanned]], PErr] =
  match p_expect(ts, is_semi(p_cur(ts)), "`;` to terminate the nodule header (DN-57 SS3)") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_nodule_items(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(items, ts2) => Ok(Pr(Nd(path, std_sys, items), ts2)) }
    }
  };

fn parse_nodule(ts: Vec[Spanned]) => Result[Pair[Nodule, Vec[Spanned]], PErr] =
  match p_expect(ts, is_nodule(p_cur(ts)), "a `nodule` header to open the program") {
    Err(e) => Err(e),
    Ok(ts1) => match parse_path(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(path, ts2) =>
        match p_eat(ts2, is_atstdsys(p_cur(ts2))) {
          Some(ts3) => parse_nodule_tail(path, True, ts3),
          None => parse_nodule_tail(path, False, ts2)
        }
      }
    }
  };

fn parse_nodule_list(ts: Vec[Spanned]) => Result[Pair[Vec[Nodule], Vec[Spanned]], PErr] =
  parse_nodule_list_acc(ts, Nil : Vec[Nodule]);

fn parse_nodule_list_acc(ts: Vec[Spanned], acc: Vec[Nodule]) => Result[Pair[Vec[Nodule], Vec[Spanned]], PErr] =
  match is_nodule(p_cur(ts)) {
    False => Ok(Pr(rev_acc(acc, Nil : Vec[Nodule]), ts)),
    True => match parse_nodule(ts) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(n, ts1) => parse_nodule_list_acc(ts1, Cons(n, acc)) }
    }
  };

fn parse_phylum_tail(path: Option[Path], ts: Vec[Spanned]) => Result[Pair[Phylum, Vec[Spanned]], PErr] =
  match is_nodule(p_cur(ts)) {
    False => Err(PE(p_pos(ts), "expected a `nodule` header (a `phylum` header must be followed by at least one `nodule` block, RFC-0006 SS4.3)")),
    True => match parse_nodule_list(ts) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(nodules, ts1) => Ok(Pr(Phy(path, nodules), ts1)) }
    }
  };

fn parse_phylum_prog(ts: Vec[Spanned]) => Result[Pair[Phylum, Vec[Spanned]], PErr] =
  match p_eat(ts, is_phylum(p_cur(ts))) {
    Some(ts1) => match parse_path(ts1) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(path, ts2) => parse_phylum_tail(Some(path), ts2) }
    },
    None => parse_phylum_tail(None, ts)
  };

// ‚îÄ‚îÄ public entry points (mirrors crate::parse::{parse, parse_phylum} ‚Äî source text -> AST) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

fn parse(src: Bytes) => Result[Nodule, PErr] =
  match lex(src) {
    Err(e) => Err(e),
    Ok(toks) => match parse_nodule(toks) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(nd, ts1) =>
        match p_expect(ts1, is_eof(p_cur(ts1)), "end of input") {
          Err(e) => Err(e),
          Ok(_ts2) => Ok(nd)
        }
      }
    }
  };

fn parse_phylum(src: Bytes) => Result[Phylum, PErr] =
  match lex(src) {
    Err(e) => Err(e),
    Ok(toks) => match parse_phylum_prog(toks) {
      Err(e) => Err(e),
      Ok(pr) => match pr { Pr(ph, ts1) =>
        match p_expect(ts1, is_eof(p_cur(ts1)), "end of input") {
          Err(e) => Err(e),
          Ok(_ts2) => Ok(ph)
        }
      }
    }
  };

// ‚îÄ‚îÄ AST structural fingerprint (M-740 Stage 3b differential; DN-26 SS7.3 row 3) ‚Äî a preorder walk
// producing (rolling hash, node count). Built ONLY from bitwise `xor`/`shl_u`/`shr_u` (never
// `add_u`/`mul_s` for the hash mix itself) because this language's Binary{N} arithmetic is
// never-silent ‚Äî `add_u` REFUSES on overflow rather than wrapping, so a classic multiply-accumulate
// hash would crash instead of folding. `rotl7` (fixed 7-bit rotate via two safely-in-range shifts,
// no edge-case shift-by-0/-N) + `xor` gives a total, overflow-free mixer; `add_u` is still used for
// the plain node COUNT (bounded by realistic program sizes, nowhere near 2^32 ‚Äî FLAG-parse-4's
// same accepted-in-practice reasoning). Every constructor contributes a distinct small tag; every
// `Bytes` leaf additionally mixes in `bytes_len` (a cheap content proxy ‚Äî catches a mis-scanned
// identifier/literal boundary without a full string hash). Graded `Empirical` (differential
// agreement across trials, VR-5) ‚Äî never `Exact`: this is a real but scoped fingerprint (per the
// task brief, "more than a bare node count", not a cryptographic/collision-proof one).
type Fp = FP(Binary{32}, Binary{32});

fn fp_hash(fp: Fp) => Binary{32} = match fp { FP(h, _) => h };
fn fp_count(fp: Fp) => Binary{32} = match fp { FP(_, c) => c };

fn rotl7(x: Binary{32}) => Binary{32} =
  or(shl_u(x, 0b0000_0000_0000_0000_0000_0000_0000_0111), shr_u(x, 0b0000_0000_0000_0000_0000_0000_0001_1001));

fn fp_tag(fp: Fp, tag: Binary{32}) => Fp =
  match fp { FP(h, c) => FP(xor(rotl7(h), tag), add_u(c, 0b0000_0000_0000_0000_0000_0000_0000_0001)) };

fn fp_bytes(fp: Fp, b: Bytes) => Fp =
  fp_tag(fp, bytes_len(b));

fn fp_u32(fp: Fp, n: Binary{32}) => Fp =
  fp_tag(fp, n);

// ‚îÄ‚îÄ leaf/small-enum walkers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn walk_vis(fp: Fp, v: Vis) => Fp =
  match v { Private => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_0001), Pub => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_0010) };

fn walk_paradigm(fp: Fp, p: Paradigm) => Fp =
  match p {
    PBinary => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_0011),
    PTernary => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_0100),
    PDense => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_0101),
    PVsa => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_0110)
  };

fn walk_scalar(fp: Fp, s: Scalar) => Fp =
  match s {
    SF16 => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_0111),
    SBf16 => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_1000),
    SF32 => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_1001),
    SF64 => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_1010)
  };

fn walk_strength(fp: Fp, s: Strength) => Fp =
  match s {
    GExact => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_1011),
    GProven => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_1100),
    GEmpirical => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_1101),
    GDeclared => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_1110)
  };

fn walk_sparsity(fp: Fp, s: Sparsity) => Fp =
  match s {
    SpDense => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0000_1111),
    SpSparse(k) => fp_u32(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_0000), k)
  };

fn walk_paramkind(fp: Fp, k: ParamKind) => Fp =
  match k { PkType => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_0001), PkWidth => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_0010) };

fn walk_execmode(fp: Fp, e: ExecutionMode) => Fp =
  match e { Interpreted => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_0011), Compiled => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_0100) };

fn walk_widthref(fp: Fp, w: WidthRef) => Fp =
  match w {
    WLit(n) => fp_u32(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_0101), n),
    WName(s) => fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_0110), s)
  };

fn walk_path(fp: Fp, p: Path) => Fp =
  match p { Pth(segs) => walk_bytes_list(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_0111), segs) };

fn walk_bytes_list(fp: Fp, xs: Vec[Bytes]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_bytes_list(fp_bytes(fp, h), rest) };

fn walk_usepath(fp: Fp, u: UsePath) => Fp =
  match u { UP(p, glob) => walk_bool(walk_path(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_1000), p), glob) };

fn walk_bool(fp: Fp, b: Bool) => Fp =
  match b { True => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_1001), False => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_1010) };

// ‚îÄ‚îÄ AmbientParams / BaseType / TypeRef (mutually recursive) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn walk_ambientparams(fp: Fp, a: AmbientParams) => Fp =
  match a {
    APSize(n) => fp_u32(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_1011), n),
    APDense(n, sc) => walk_scalar(fp_u32(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_1100), n), sc),
    APVsa(model, dim, sp) => walk_sparsity(fp_u32(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_1101), model), dim), sp)
  };

fn walk_typeref(fp: Fp, t: TypeRef) => Fp =
  match t { TR(b, g) => walk_guarantee_opt(walk_basetype(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_1110), b), g) };

fn walk_guarantee_opt(fp: Fp, g: Option[Strength]) => Fp =
  match g { None => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0001_1111), Some(s) => walk_strength(fp, s) };

fn walk_typeref_list(fp: Fp, xs: Vec[TypeRef]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_typeref_list(walk_typeref(fp, h), rest) };

fn walk_basetype(fp: Fp, b: BaseType) => Fp =
  match b {
    KwBinary(w) => walk_widthref(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_0000), w),
    KwTernary(w) => walk_widthref(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_0001), w),
    KwDense(n, sc) => walk_scalar(fp_u32(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_0010), n), sc),
    Vsa(model, dim, sp) => walk_sparsity(fp_u32(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_0011), model), dim), sp),
    KwSubstrate(name) => fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_0100), name),
    KwSeq(elem, len) => fp_u32(walk_typeref(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_0101), elem), len),
    KwBytes => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_0110),
    KwFloat => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_0111),
    Named(name, args) => walk_typeref_list(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_1000), name), args),
    Ambient(ap) => walk_ambientparams(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_1001), ap),
    FnArrow(a, r) => walk_typeref(walk_typeref(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_1010), a), r),
    Tuple(elems) => walk_typeref_list(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_1011), elems)
  };

fn walk_traitref(fp: Fp, t: TraitRef) => Fp =
  match t { TRf(name, args) => walk_typeref_list(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_1100), name), args) };

fn walk_traitref_list(fp: Fp, xs: Vec[TraitRef]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_traitref_list(walk_traitref(fp, h), rest) };

fn walk_typeparam(fp: Fp, t: TypeParam) => Fp =
  match t { TP(name, k, bounds) => walk_traitref_list(walk_paramkind(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_1101), name), k), bounds) };

fn walk_typeparam_list(fp: Fp, xs: Vec[TypeParam]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_typeparam_list(walk_typeparam(fp, h), rest) };

fn walk_param(fp: Fp, p: Param) => Fp =
  match p { Prm(name, ty) => walk_typeref(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_1110), name), ty) };

fn walk_param_list(fp: Fp, xs: Vec[Param]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_param_list(walk_param(fp, h), rest) };

fn walk_bytes_list2(fp: Fp, xs: Vec[Bytes]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_bytes_list2(fp_bytes(fp, h), rest) };

// FLAG-parse-10: the budget VALUE is not mixed into the fingerprint (only its effect name) --
// narrowing a Binary{64} budget to Binary{32} for the hash risks the SAME checked-narrow
// refusal as FLAG-parse-4/-9, and no accept-corpus file uses `(<=N)` syntax at all (verified
// during authoring), so this is an honest, unexercised, zero-cost-to-skip narrowing.
fn walk_effectbudget_list(fp: Fp, xs: Vec[EffectBudget]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => match h { EB(name, _bound) => walk_effectbudget_list(fp_bytes(fp, name), rest) } };

fn walk_fnsig(fp: Fp, s: FnSig) => Fp =
  match s { FS(name, params, vparams, ret, effects, budgets) =>
    walk_effectbudget_list(
      walk_bytes_list2(
        walk_typeref(
          walk_param_list(
            walk_typeparam_list(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0010_1111), name), params),
            vparams),
          ret),
        effects),
      budgets)
  };

// M-1027 / DN-104: the `sealed` (`priv`) flag joins the structural fingerprint via tag 110 (the next
// sequential entry after the 1..109 table), folded ONLY when sealed ‚Äî so an unsealed ctor's fingerprint
// stays byte-identical to the pre-M-1027 form (backward-compatible; the Rust mirror `fp::ctor` matches).
fn walk_ctor_seal(fp: Fp, s: Bool) => Fp =
  match s { False => fp, True => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_1110) };

fn walk_ctor(fp: Fp, c: Ctor) => Fp =
  match c { Ctr(name, fields, sealed) => walk_ctor_seal(walk_typeref_list(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_0000), name), fields), sealed) };

fn walk_ctor_list(fp: Fp, xs: Vec[Ctor]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_ctor_list(walk_ctor(fp, h), rest) };

fn walk_typedecl(fp: Fp, t: TypeDecl) => Fp =
  match t { TD(vis, name, params, ctors) => walk_ctor_list(walk_bytes_list2(walk_vis(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_0001), name), vis), params), ctors) };

fn walk_fnsig_list(fp: Fp, xs: Vec[FnSig]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_fnsig_list(walk_fnsig(fp, h), rest) };

fn walk_traitdecl(fp: Fp, t: TraitDecl) => Fp =
  match t { TrD(vis, name, params, sigs) => walk_fnsig_list(walk_bytes_list2(walk_vis(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_0010), name), vis), params), sigs) };

fn walk_fndecl(fp: Fp, f: FnDecl) => Fp =
  match f { FD(vis, thw, tr_opt, sig, body) =>
    walk_expr(walk_fnsig(walk_tier_opt(walk_bool(walk_vis(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_0011), vis), thw), tr_opt), sig), body)
  };

fn walk_tier_opt(fp: Fp, t: Option[ExecutionMode]) => Fp =
  match t { None => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_0100), Some(m) => walk_execmode(fp, m) };

fn walk_fndecl_list(fp: Fp, xs: Vec[FnDecl]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_fndecl_list(walk_fndecl(fp, h), rest) };

fn walk_impldecl(fp: Fp, i: ImplDecl) => Fp =
  match i { ImD(name, args, for_ty, methods) =>
    walk_fndecl_list(walk_typeref(walk_typeref_list(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_0101), name), args), for_ty), methods)
  };

fn walk_viadecl(fp: Fp, v: ViaDecl) => Fp =
  match v { VD(idx, name, args) => walk_typeref_list(fp_bytes(fp_u32(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_0110), idx), name), args) };

fn walk_viadecl_list(fp: Fp, xs: Vec[ViaDecl]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_viadecl_list(walk_viadecl(fp, h), rest) };

fn walk_impldecl_list(fp: Fp, xs: Vec[ImplDecl]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_impldecl_list(walk_impldecl(fp, h), rest) };

fn walk_objectdecl(fp: Fp, o: ObjectDecl) => Fp =
  match o { OD(vis, name, params, ctor, vias, impls, fns) =>
    walk_fndecl_list(
      walk_impldecl_list(
        walk_viadecl_list(
          walk_ctor(walk_bytes_list2(walk_vis(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_0111), name), vis), params), ctor),
          vias),
        impls),
      fns)
  };

// DN-103 / M-1026: fold the impl-level type-parameter slot (unbounded names) first ‚Äî matching how
// TypeDecl/TraitDecl/LowerDecl fold their `params` ‚Äî so the fingerprint distinguishes `impl[T] Foo[T]`
// from `impl Foo[T]` (lock-step with the oracle `fp::inherentimpldecl`, no new tag-table entry).
fn walk_inherentimpldecl(fp: Fp, i: InherentImplDecl) => Fp =
  match i { IID(params, for_ty, methods) => walk_fndecl_list(walk_typeref(fp_tag(walk_bytes_list2(fp, params), 0b0000_0000_0000_0000_0000_0000_0011_1000), for_ty), methods) };

fn walk_lowerrhs(fp: Fp, r: LowerRhs) => Fp =
  match r {
    LRExpr(e) => walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_1001), e),
    LRImpl(i) => walk_impldecl(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_1010), i)
  };

fn walk_lowerdecl(fp: Fp, l: LowerDecl) => Fp =
  match l { LD(name, params, rhs) => walk_lowerrhs(walk_bytes_list2(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_1011), name), params), rhs) };

fn walk_derivedecl(fp: Fp, d: DeriveDecl) => Fp =
  match d { DD(name, for_ty) => walk_typeref(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_1100), name), for_ty) };

// ‚îÄ‚îÄ Literal / Pattern / Arm / Hypha / Expr (the bulk of every real program) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn walk_expr_list(fp: Fp, xs: Vec[Expr]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_expr_list(walk_expr(fp, h), rest) };

fn walk_literal(fp: Fp, l: Literal) => Fp =
  match l {
    Bin(s) => fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_1101), s),
    Trit(s) => fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_1110), s),
    Int(n) => fp_u32(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0011_1111), width_cast(n, zero32())),
    AmbientInt(par, n) => fp_u32(walk_paradigm(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_0000), par), width_cast(n, zero32())),
    List(elems) => walk_expr_list(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_0001), elems),
    LBytes(s) => fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_0010), s),
    Str(s) => fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_0011), s),
    LFloat(s) => fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_0100), s)
  };

fn walk_pattern(fp: Fp, p: Pattern) => Fp =
  match p {
    PWildcard => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_0101),
    PLit(l) => walk_literal(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_0110), l),
    PCtor(name, subs) => walk_pattern_list(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_0111), name), subs),
    PIdent(name) => fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_1000), name),
    PTuple(subs) => walk_pattern_list(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_1001), subs),
    POr(alts) => walk_pattern_list(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_1010), alts)
  };

fn walk_pattern_list(fp: Fp, xs: Vec[Pattern]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_pattern_list(walk_pattern(fp, h), rest) };

fn walk_arm(fp: Fp, a: Arm) => Fp =
  match a { Ar(pat, body) => walk_expr(walk_pattern(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_1011), pat), body) };

fn walk_arm_list(fp: Fp, xs: Vec[Arm]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_arm_list(walk_arm(fp, h), rest) };

fn walk_expr_opt(fp: Fp, e: Option[Expr]) => Fp =
  match e { None => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_1100), Some(x) => walk_expr(fp, x) };

fn walk_hypha(fp: Fp, h: Hypha) => Fp =
  match h { Hy(frg, body) => walk_expr(walk_expr_opt(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_1101), frg), body) };

fn walk_hypha_list(fp: Fp, xs: Vec[Hypha]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_hypha_list(walk_hypha(fp, h), rest) };

fn walk_typeref_opt(fp: Fp, t: Option[TypeRef]) => Fp =
  match t { None => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_1110), Some(x) => walk_typeref(fp, x) };

fn walk_expr(fp: Fp, e: Expr) => Fp =
  match e {
    Let(name, ty, bound, body) => walk_expr(walk_expr(walk_typeref_opt(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0100_1111), name), ty), bound), body),
    If(cond, conseq, alt) => walk_expr(walk_expr(walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_0000), cond), conseq), alt),
    Match(scrutinee, arms) => walk_arm_list(walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_0001), scrutinee), arms),
    For(x, xs, acc, init, body) => walk_expr(walk_expr(walk_expr(fp_bytes(fp_bytes(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_0010), x), acc), xs), init), body),
    Swap(value, target, pol) => walk_path(walk_typeref(walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_0011), value), target), pol),
    WithParadigm(par, body) => walk_expr(walk_paradigm(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_0100), par), body),
    Wild(body) => walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_0101), body),
    Spore(value) => walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_0110), value),
    Wrapping(value) => walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_1110), value),
    Try(value) => walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_1111), value),
    Consume(value) => walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_0111), value),
    Colony(hyphae) => walk_hypha_list(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_1000), hyphae),
    Lambda(params, body) => walk_expr(walk_param_list(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_1001), params), body),
    App(head, args) => walk_expr_list(walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_1010), head), args),
    Fuse(left, right) => walk_expr(walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_1011), left), right),
    Reclaim(pol, body) => walk_expr(walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_1100), pol), body),
    Path(p) => walk_path(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_1101), p),
    Lit(l) => walk_literal(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_1110), l),
    Ascribe(inner, ty) => walk_typeref(walk_expr(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0101_1111), inner), ty),
    TupleLit(elems) => walk_expr_list(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_0000), elems)
  };

// ‚îÄ‚îÄ Item / Nodule (the top) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn walk_item(fp: Fp, i: Item) => Fp =
  match i {
    Use(u) => walk_usepath(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_0001), u),
    Default(par) => walk_paradigm(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_0010), par),
    Type(t) => walk_typedecl(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_0011), t),
    Trait(t) => walk_traitdecl(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_0100), t),
    Impl(i2) => walk_impldecl(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_0101), i2),
    Fn(f) => walk_fndecl(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_0110), f),
    Object(o) => walk_objectdecl(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_0111), o),
    Lower(l) => walk_lowerdecl(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_1000), l),
    Derive(d) => walk_derivedecl(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_1001), d),
    InherentImpl(i3) => walk_inherentimpldecl(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_1010), i3)
  };

fn walk_item_list(fp: Fp, xs: Vec[Item]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_item_list(walk_item(fp, h), rest) };

fn walk_nodule(fp: Fp, n: Nodule) => Fp =
  match n { Nd(path, std_sys, items) => walk_item_list(walk_bool(walk_path(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_1011), path), std_sys), items) };

// fingerprint_nodule: the top-level entry ‚Äî a fresh (0,0) accumulator walked over a parsed Nodule.
fn fingerprint_nodule(n: Nodule) => Fp =
  walk_nodule(FP(0b0000_0000_0000_0000_0000_0000_0000_0000, 0b0000_0000_0000_0000_0000_0000_0000_0000), n);

// ‚îÄ‚îÄ corpus-differential driver helpers (Binary{32} extraction for L1-eval, matching the
// established Stage-1/2/3a `assert_l1_only_u32` convention) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

// parse_ok_code: 1 if `src` parses Ok, 0 if Err (the classification-parity leg).
fn parse_ok_code(src: Bytes) => Binary{32} =
  match parse(src) { Ok(_) => 0b0000_0000_0000_0000_0000_0000_0000_0001, Err(_) => 0b0000_0000_0000_0000_0000_0000_0000_0000 };

// parse_fingerprint_hash / parse_fingerprint_count: the fingerprint's two legs, `Eof`-safe default
// (0) on a parse error (the caller only compares these on inputs BOTH sides accepted).
fn parse_fingerprint_hash(src: Bytes) => Binary{32} =
  match parse(src) { Ok(n) => fp_hash(fingerprint_nodule(n)), Err(_) => 0b0000_0000_0000_0000_0000_0000_0000_0000 };

fn parse_fingerprint_count(src: Bytes) => Binary{32} =
  match parse(src) { Ok(n) => fp_count(fingerprint_nodule(n)), Err(_) => 0b0000_0000_0000_0000_0000_0000_0000_0000 };

// stage3_verdict: the ONE-EVAL-PER-FILE Stage-3 gate driver (DN-26 SS7.3 runtime-budget economy:
// the Rust harness checks THIS nodule once, then calls this fn once per corpus file with the
// oracle-computed expectations as arguments ‚Äî one elaboration, many eval calls). Verdict codes:
// 1 = full agreement; 0 = Ok/Err classification mismatch; 2 = fingerprint HASH mismatch;
// 3 = fingerprint NODE-COUNT mismatch. For a want_ok=0 (oracle-rejected) input the fingerprint
// legs are vacuous (never compared ‚Äî DN-26 SS7.3 compares shape only on mutually-accepted files).
fn stage3_verdict(src: Bytes, want_ok: Binary{32}, want_hash: Binary{32}, want_count: Binary{32}) => Binary{32} =
  match parse(src) {
    Err(_) => match eq(want_ok, zero32()) { 0b1 => one32(), _ => zero32() },
    Ok(n) => match eq(want_ok, one32()) {
      0b1 => stage3_verdict_fp(fingerprint_nodule(n), want_hash, want_count),
      _ => zero32()
    }
  };

fn stage3_verdict_fp(fp: Fp, want_hash: Binary{32}, want_count: Binary{32}) => Binary{32} =
  match eq(fp_hash(fp), want_hash) {
    0b1 => match eq(fp_count(fp), want_count) { 0b1 => one32(), _ => three32() },
    _ => 0b0000_0000_0000_0000_0000_0000_0000_0010
  };

// ‚îÄ‚îÄ phylum-level fingerprint + verdict (the FLAG-parse-9 parse_phylum leg: tag 108 = Phy,
// 109 = a header-less phylum path (None); a headed path mixes walk_path directly, the same
// Option-mixing convention walk_guarantee_opt/walk_tier_opt use) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
fn walk_phylum_path_opt(fp: Fp, p: Option[Path]) => Fp =
  match p { None => fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_1101), Some(x) => walk_path(fp, x) };

fn walk_nodule_list(fp: Fp, xs: Vec[Nodule]) => Fp =
  match xs { Nil => fp, Cons(h, rest) => walk_nodule_list(walk_nodule(fp, h), rest) };

fn walk_phylum(fp: Fp, ph: Phylum) => Fp =
  match ph { Phy(path, nodules) => walk_nodule_list(walk_phylum_path_opt(fp_tag(fp, 0b0000_0000_0000_0000_0000_0000_0110_1100), path), nodules) };

fn fingerprint_phylum(ph: Phylum) => Fp =
  walk_phylum(FP(0b0000_0000_0000_0000_0000_0000_0000_0000, 0b0000_0000_0000_0000_0000_0000_0000_0000), ph);

// stage3_phylum_verdict: the parse_phylum leg of the Stage-3 gate (same verdict codes as
// stage3_verdict; same one-eval-per-file economy).
fn stage3_phylum_verdict(src: Bytes, want_ok: Binary{32}, want_hash: Binary{32}, want_count: Binary{32}) => Binary{32} =
  match parse_phylum(src) {
    Err(_) => match eq(want_ok, zero32()) { 0b1 => one32(), _ => zero32() },
    Ok(ph) => match eq(want_ok, one32()) {
      0b1 => stage3_verdict_fp(fingerprint_phylum(ph), want_hash, want_count),
      _ => zero32()
    }
  };
