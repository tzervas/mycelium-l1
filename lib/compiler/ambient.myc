// ── expand_to_source verdict drivers: exact byte-for-byte comparison against the oracle's rendered
// text (passed in as a Bytes argument — no hashing needed, the same "pass a Bytes value in" idiom
// `compiler_stage3.rs`'s `bytes_value(source)` already establishes for corpus source text). ────────
fn stage4_expand_verdict_1(want_expand: Bytes) => Binary{32} =
  match bytes_eq(expand_to_source(test_input_1()), want_expand) { 0b1 => one32(), _ => zero32() };

fn stage4_expand_verdict_2(want_expand: Bytes) => Binary{32} =
  match bytes_eq(expand_to_source(test_input_2()), want_expand) { 0b1 => one32(), _ => zero32() };

fn stage4_expand_verdict_resolved_2(want_expand: Bytes) => Binary{32} =
  match resolve(test_input_2()) {
    Err(_) => zero32(),
    Ok(n) => match bytes_eq(expand_to_source(n), want_expand) { 0b1 => one32(), _ => zero32() }
  };

