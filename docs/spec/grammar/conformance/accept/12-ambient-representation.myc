// exercises: ambient representation (RFC-0012; M-344) — a nodule-scope `default paradigm`, a
// paradigm-less repr `{N}` in signatures, a `with paradigm` override block, and a bare decimal
// that adopts the ambient paradigm (width from the checked context)
nodule signals.ambient;
default paradigm Binary;

fn mask(x: {8}, m: {8}) => {8} =
  xor(x, m);

fn widen(x: {8}) => Ternary{6} =
  with paradigm Ternary {
    swap(x, to: {6}, policy: roundtrip)
  };

fn ones() => {8} = 255;
